@page "/projects"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="page-header">
    <div>
        <h1 class="page-title"><img src="icons/octopus.svg" class="icon-line" style="width:42px;height:42px;" />문어발</h1>
        <p class="page-subtitle">진행중 · 일시중단 프로젝트</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal" style="display:inline-flex; align-items:center; gap:6px;"><img src="icons/plus.svg" class="icon-line" style="width:14px;height:14px; flex-shrink:0;" /> 새 프로젝트</button>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_projects.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon"><img src="icons/octopus.svg" class="icon-line" style="width:48px;height:48px;" /></div>
        <p>진행중인 프로젝트가 없어요.<br />새 프로젝트를 추가해 보세요!</p>
    </div>
}
else
{
    <!-- 컨트롤 바: 필터 + 정렬 + 뷰 전환 -->
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; gap:8px; flex-wrap:wrap;">
        <!-- 왼쪽: 필터 + 정렬 -->
        <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">

            <!-- 상태 필터 -->
            <div style="display:flex; gap:4px;">
                <button class="btn btn-sm @(_statusFilter == "all" ? "btn-sage" : "btn-ghost")"
                        @onclick='async () => { _statusFilter = "all"; await JS.InvokeVoidAsync("localStorage.setItem", "sched_filter", _statusFilter); }'>전체</button>
                <button class="btn btn-sm @(_statusFilter == "진행중" ? "btn-sage" : "btn-ghost")"
                        @onclick='async () => { _statusFilter = "진행중"; await JS.InvokeVoidAsync("localStorage.setItem", "sched_filter", _statusFilter); }'>진행중</button>
                <button class="btn btn-sm @(_statusFilter == "일시중단" ? "btn-sage" : "btn-ghost")"
                        @onclick='async () => { _statusFilter = "일시중단"; await JS.InvokeVoidAsync("localStorage.setItem", "sched_filter", _statusFilter); }'>중단</button>
            </div>

            <!-- 정렬 기준 -->
            <span style="font-size:0.82rem; color:var(--text-mid);">정렬</span>
            <select class="form-control" style="width:auto; padding:5px 10px; font-size:0.82rem;" @bind="_sortField"
                        @bind:after="SaveSchedulePrefs">
                <option value="created">등록일</option>
                <option value="start">시작일</option>
                <option value="updated">수정일</option>
                <option value="title">이름순</option>
            </select>

            <!-- 오름/내림차순 -->
            <button class="btn btn-sm btn-ghost" @onclick="ToggleSortDir" title="@(_sortAsc ? "오름차순" : "내림차순")">
                @if (_sortAsc)
                {
                    <img src="icons/arrow-up.svg" class="icon-line" style="width:14px;height:14px;" /><span> 오름</span>
                }
                else
                {
                    <img src="icons/arrow-down.svg" class="icon-line" style="width:14px;height:14px;" /><span> 내림</span>
                }
            </button>
        </div>

        <!-- 오른쪽: 뷰 전환 -->
        <div style="display:flex; gap:4px;">
            <button class="btn btn-sm @(_isListView ? "btn-ghost" : "btn-sage")" @onclick='async () => { _isListView = false; await JS.InvokeVoidAsync("localStorage.setItem", "sched_listview", "false"); }' title="카드형"><img src="icons/squares-four.svg" class="icon-line" style="width:16px;height:16px;" /></button>
            <button class="btn btn-sm @(_isListView ? "btn-sage" : "btn-ghost")" @onclick='async () => { _isListView = true; await JS.InvokeVoidAsync("localStorage.setItem", "sched_listview", "true"); }' title="리스트형"><img src="icons/list.svg" class="icon-line" style="width:16px;height:16px;" /></button>
        </div>
    </div>

    @if (!FilteredSortedProjects.Any())
    {
        <div class="empty-state" style="padding:40px 0;">
            <p style="color:var(--text-mid);">해당 상태의 프로젝트가 없어요.</p>
        </div>
    }
    else if (!_isListView)
    {
        <!-- 카드형 -->
        <div class="grid-3">
            @foreach (var proj in FilteredSortedProjects)
            {
                <div class="card" style="cursor:pointer;" @onclick="() => GoToDetail(proj.Id)">
                    @if (proj.Photos.Count > 0)
                    {
                        <img src="@proj.Photos[0].Base64Data" class="photo-thumb"
                             style="width:100%; height:160px; object-fit:cover; border-radius:var(--radius-sm); margin-bottom:12px;"
                             alt="프로젝트 사진" />
                    }

                    <div class="flex-between mb-1">
                        <div class="card-title" style="margin-bottom:0;">@proj.Title</div>
                        @if (proj.Status == ProjectStatus.일시중단)
                        {
                            <span class="badge" style="background:#fef0f0; color:#c0392b; border:1px solid #f5c0c0;">일시중단</span>
                        }
                        else
                        {
                            <span class="badge" style="background:#fffbe6; color:#b58a00; border:1px solid #f5d97a;">진행중</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(proj.PatternName))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid); margin-bottom:4px; display:flex; align-items:center; gap:4px;"><img src="icons/book-open-text.svg" class="icon-line" style="width:14px;height:14px; flex-shrink:0;" /> @proj.PatternName</div>
                    }

                    @if (!string.IsNullOrEmpty(proj.PatternMemo))
                    {
                        <p style="font-size:0.85rem; color:var(--text-mid); margin-bottom:6px; white-space:pre-wrap; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">@proj.PatternMemo</p>
                    }

                    <div style="display:flex; gap:12px; font-size:0.8rem; color:var(--text-light); margin-bottom:14px;">
                        @if (proj.StartDate.HasValue)
                        {
                            <span>시작 @proj.StartDate.Value.ToString("yy.MM.dd")</span>
                        }
                        @if (proj.EndDate.HasValue)
                        {
                            <span>→ @proj.EndDate.Value.ToString("yy.MM.dd") 목표</span>
                        }
                    </div>

                    <div style="display:flex; gap:8px; flex-wrap:wrap;" @onclick:stopPropagation="true">
                        <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(proj)"><img src="icons/pencil.svg" class="icon-line" style="width:14px;height:14px;" /> 수정</button>
                        @if (proj.Status == ProjectStatus.진행중)
                        {
                            <button class="btn btn-sm" style="background:#f5e6c0; color:#8a6010; border:1px solid #e8c97a;"
                                    @onclick="() => ToggleSuspend(proj)"><img src="icons/pause.svg" class="icon-line" style="width:14px;height:14px;" /> 일시중단</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-ghost"
                                    @onclick="() => ToggleSuspend(proj)"><img src="icons/play.svg" class="icon-line" style="width:14px;height:14px;" /> 재개</button>
                        }
                        <button class="btn btn-sm btn-sage" @onclick="() => CompleteProject(proj.Id)"><img src="icons/check-fat.svg" class="icon-line" style="width:14px;height:14px;" /> 완료</button>
                        <button class="btn btn-danger btn-sm" @onclick='() => Confirm("이 프로젝트를 삭제하면 복구할 수 없어요.", async () => await DeleteProject(proj.Id))'><img src="icons/trash.svg" class="icon-line" style="width:14px;height:14px;" /></button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- 리스트형 -->
        <div style="display:flex; flex-direction:column; gap:8px;">
            @foreach (var proj in FilteredSortedProjects)
            {
                <div class="card" style="cursor:pointer; display:flex; align-items:center; gap:14px; padding:12px 16px;"
                     @onclick="() => GoToDetail(proj.Id)">
                    @if (proj.Photos.Count > 0)
                    {
                        <img src="@proj.Photos[0].Base64Data"
                             style="width:52px; height:52px; object-fit:cover; border-radius:var(--radius-sm); border:1px solid var(--border); flex-shrink:0;"
                             alt="사진" />
                    }
                    else
                    {
                        <div style="width:52px; height:52px; background:var(--ivory-dark); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; flex-shrink:0;"><img src="icons/yarn.svg" class="icon-line" style="width:26px;height:26px;" /></div>
                    }

                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:2px;">
                            <span style="font-weight:700; font-size:0.95rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@proj.Title</span>
                            @if (proj.Status == ProjectStatus.일시중단)
                            {
                                <span class="badge" style="background:#fef0f0; color:#c0392b; border:1px solid #f5c0c0; flex-shrink:0;">일시중단</span>
                            }
                        </div>
                        <div style="font-size:0.78rem; color:var(--text-mid); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            @if (!string.IsNullOrEmpty(proj.PatternName)) { <span>@proj.PatternName</span> }
                            @if (proj.StartDate.HasValue) { <span style="margin-left:8px;">· @proj.StartDate.Value.ToString("yy.MM.dd") 시작</span> }
                        </div>
                    </div>

                    <div style="display:flex; gap:6px; flex-shrink:0;" @onclick:stopPropagation="true">
                        <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(proj)"><img src="icons/pencil.svg" class="icon-line" style="width:14px;height:14px;" /></button>
                        @if (proj.Status == ProjectStatus.진행중)
                        {
                            <button class="btn btn-sm" style="background:#f5e6c0; color:#8a6010; border:1px solid #e8c97a; padding:4px 8px;"
                                    @onclick="() => ToggleSuspend(proj)"><img src="icons/pause.svg" class="icon-line" style="width:14px;height:14px;" /></button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-ghost" @onclick="() => ToggleSuspend(proj)"><img src="icons/play.svg" class="icon-line" style="width:14px;height:14px;" /></button>
                        }
                        <button class="btn btn-sage btn-sm" @onclick="() => CompleteProject(proj.Id)"><img src="icons/check-fat.svg" class="icon-line" style="width:14px;height:14px;" /></button>
                        <button class="btn btn-danger btn-sm" @onclick='() => Confirm("이 프로젝트를 삭제하면 복구할 수 없어요.", async () => await DeleteProject(proj.Id))'><img src="icons/trash.svg" class="icon-line" style="width:14px;height:14px;" /></button>
                    </div>
                </div>
            }
        </div>
    }
}

<!-- 완성작 미리보기 팝업 -->
<CompletedPopup Show="_showCompletedPopup" Project="_completedPreview"
    Yarns="_yarns" Tools="_tools"
    OnClose="CloseCompletedPopup" OnSaved="LoadData" />


@if (_showModal)
{
    <div class="modal-backdrop">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(_editingProject?.Id == Guid.Empty ? "새 프로젝트" : "프로젝트 수정")</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseModal"><img src="icons/x.svg" class="icon-line" style="width:12px;height:12px;" /></button>
            </div>

            @if (_editingProject != null)
            {
                @* ── 도안명 / 출처 ── *@
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">도안명 *</label>
                        <input class="form-control" @bind="_editingProject.PatternName" placeholder="예: 마시멜로 후드 집업" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">도안 출처</label>
                        <input class="form-control" @bind="_editingProject.PatternSource" placeholder="작가명, 책 이름, URL 등" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">도안 메모</label>
                    <textarea class="form-control" rows="2" @bind="_editingProject.PatternMemo" placeholder="사이즈, 수정 사항 등"></textarea>
                </div>

                @* ── 날짜 ── *@
                <div style="display:flex; gap:16px;">
                    <div class="form-group" style="flex:1; min-width:0;">
                        <label class="form-label">시작일</label>
                        <input type="date" class="form-control" style="width:100%; box-sizing:border-box;"
                               value="@_editingProject.StartDate?.ToString("yyyy-MM-dd")"
                               @onchange="e => _editingProject.StartDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                    </div>
                    <div class="form-group" style="flex:1; min-width:0;">
                        <label class="form-label">@(_editingProject!.Status == ProjectStatus.완료 ? "완성일" : "목표 완성일")</label>
                        <input type="date" class="form-control" style="width:100%; box-sizing:border-box;"
                               value="@_editingProject.EndDate?.ToString("yyyy-MM-dd")"
                               @onchange="e => _editingProject.EndDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                    </div>
                </div>

                @* ── 사용 바늘 ── *@
                <div class="form-group">
                    <label class="form-label">사용 바늘</label>
                    <div style="display:flex; gap:6px; margin-bottom:6px;">
                        <button type="button" class="btn btn-sm @(_editingProject.NeedleType == NeedleType.대바늘 ? "btn-sage" : "btn-ghost")"
                                @onclick='() => _editingProject.NeedleType = (_editingProject.NeedleType == NeedleType.대바늘 ? (NeedleType?)null : NeedleType.대바늘)'>대바늘</button>
                        <button type="button" class="btn btn-sm @(_editingProject.NeedleType == NeedleType.코바늘 ? "btn-sage" : "btn-ghost")"
                                @onclick='() => _editingProject.NeedleType = (_editingProject.NeedleType == NeedleType.코바늘 ? (NeedleType?)null : NeedleType.코바늘)'>코바늘</button>
                    </div>
                    <input class="form-control" @bind="_editingProject.NeedleNote" placeholder="예: 4mm 대바늘 80cm줄, 3.5mm 코바늘" />
                </div>

                @* ── 사용 실 ── *@
                <div class="form-group">
                    <label class="form-label">사용 실</label>
                    <select class="form-control" style="margin-bottom:8px;" @onchange="OnAddYarn">
                        <option value="">+ 실 추가</option>
                        @foreach (var y in _yarns)
                        {
                            <option value="@y.Id">@y.Brand @y.Name (@y.Color)</option>
                        }
                    </select>
                    @foreach (var usage in _editingProject.YarnUsages)
                    {
                        var yarn = _yarns.Find(y => y.Id == usage.YarnId);
                        bool isCone = yarn?.YarnType == YarnType.콘사;
                        bool hasConeWeight = isCone && yarn?.WeightGram > 0;
                        string unitLabel = hasConeWeight ? "g" : isCone ? "콘" : "볼";
                        decimal displayVal = hasConeWeight ? usage.BallsUsed * yarn!.WeightGram : usage.BallsUsed;
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; padding:6px 10px;
                                    border-radius:9px; background:#f8f8f8; border:1px solid var(--border);">
                            @if (yarn != null)
                            {
                                <span class="color-dot" style="background:@yarn.ColorCode; flex-shrink:0;"></span>
                                <span style="flex:1; font-size:0.88rem;">@yarn.Brand @yarn.Name (@yarn.Color)</span>
                            }
                            <input class="form-control" type="number" min="1" style="width:80px;"
                                   value="@displayVal.ToString("G29")"
                                   @onchange="e => { if (decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var n)) usage.BallsUsed = hasConeWeight ? n / yarn!.WeightGram : n; }" />
                            <span style="font-size:0.82rem; color:var(--text-mid);">@unitLabel</span>
                            <button class="btn btn-danger btn-sm" @onclick="() => _editingProject.YarnUsages.Remove(usage)"><img src="icons/x.svg" class="icon-line" style="width:12px;height:12px;" /></button>
                        </div>
                    }
                </div>

                @* ── 스와치 연결 ── *@
                <div class="form-group">
                    <label class="form-label">스와치</label>
                    @if (!_allSwatches.Any())
                    {
                        <p style="font-size:0.82rem; color:var(--text-light);">스와치 페이지에서 먼저 스와치를 만들어주세요.</p>
                    }
                    else
                    {
                        <select class="form-control" @onchange="OnScheduleSwatchSelect">
                            <option value="">+ 스와치 연결</option>
                            @foreach (var s in _allSwatches)
                            {
                                var sy = _yarns.Find(y => y.Id == s.YarnId);
                                bool isLinked = s.ProjectId == _editingProject!.Id && _editingProject.Id != Guid.Empty;
                                <option value="@s.Id" disabled="@isLinked">
                                    @(string.IsNullOrEmpty(s.Name) ? "이름 없는 스와치" : s.Name)
                                    @(sy != null ? $" ({sy.Brand} {sy.Name})" : "")
                                </option>
                            }
                        </select>
                        @if (_allSwatches.Any(s => s.ProjectId == _editingProject!.Id && _editingProject.Id != Guid.Empty))
                        {
                            <div style="margin-top:8px;">
                                @foreach (var s in _allSwatches.Where(s => s.ProjectId == _editingProject!.Id && _editingProject.Id != Guid.Empty))
                                {
                                    var sy = _yarns.Find(y => y.Id == s.YarnId);
                                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; padding:8px 12px;
                                                border-radius:var(--radius-sm); background:var(--ivory-mid); border:1px solid var(--border);">
                                        <div style="flex:1; min-width:0;">
                                            <div style="font-size:0.88rem; font-weight:600; color:var(--text-dark);">
                                                @(string.IsNullOrEmpty(s.Name) ? "이름 없는 스와치" : s.Name)
                                                @if (!string.IsNullOrEmpty(s.Stitch))
                                                {
                                                    <span style="font-weight:400; color:var(--text-mid); margin-left:6px;">(@s.Stitch)</span>
                                                }
                                                @if (s.NeedleSizeMm > 0)
                                                {
                                                    <span style="font-weight:400; color:var(--text-mid); margin-left:4px;">@(s.NeedleSizeMm)mm</span>
                                                }
                                            </div>
                                            @if (sy != null)
                                            {
                                                <div style="font-size:0.75rem; color:var(--text-light); display:flex; align-items:center; gap:4px; margin-top:3px;">
                                                    <span class="color-dot" style="background:@sy.ColorCode; width:8px; height:8px;"></span>
                                                    @sy.Brand @sy.Name
                                                </div>
                                            }
                                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px; font-size:0.8rem;">
                                                <div>
                                                    <div style="font-size:0.7rem; color:var(--text-light);">세탁 전</div>
                                                    @if (s.PreWashStitches > 0 || s.PreWashRows > 0)
                                                    {
                                                        <div>@(s.PreWashStitches)코 × @(s.PreWashRows)단</div>
                                                    }
                                                    @if (s.PreWashWidthCm > 0 || s.PreWashHeightCm > 0)
                                                    {
                                                        <div style="color:var(--text-mid);">@(s.PreWashWidthCm)cm × @(s.PreWashHeightCm)cm</div>
                                                    }
                                                </div>
                                                @if (s.PostWashStitches > 0 || s.PostWashWidthCm > 0)
                                                {
                                                    <div>
                                                        <div style="font-size:0.7rem; color:var(--text-light);">세탁 후</div>
                                                        @if (s.PostWashStitches > 0 || s.PostWashRows > 0)
                                                        {
                                                            <div>@(s.PostWashStitches)코 × @(s.PostWashRows)단</div>
                                                        }
                                                        @if (s.PostWashWidthCm > 0 || s.PostWashHeightCm > 0)
                                                        {
                                                            <div style="color:var(--text-mid);">@(s.PostWashWidthCm)cm × @(s.PostWashHeightCm)cm</div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        <button class="btn btn-danger btn-sm" style="padding:2px 8px; flex-shrink:0;" @onclick="() => s.ProjectId = null"><img src="icons/x.svg" class="icon-line" style="width:12px;height:12px;" /></button>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>

                @* ── 카테고리 + 캘린더 색상 ── *@
                <div class="form-group" style="margin-top:28px;">
                    <label class="form-label">카테고리</label>
                    <div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:10px;">
                        @foreach (var cat in Enum.GetValues<ProjectCategory>().Where(c => c != ProjectCategory.미분류))
                        {
                            <button type="button"
                                    class="btn btn-sm @(_editingProject.Category == cat ? "btn-sage" : "btn-ghost")"
                                    @onclick="() => _editingProject.Category = (_editingProject.Category == cat ? ProjectCategory.미분류 : cat)">
                                @cat
                            </button>
                        }
                    </div>
                    <label class="form-label" style="margin-top:20px; display:block;">캘린더 색상</label>
                    <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                        @foreach (var hex in _colorOptions)
                        {
                            bool selected = _editingProject.ColorCode == hex;
                            string dotBorder    = selected ? "3px solid #333"       : "2px solid transparent";
                            string dotShadow    = selected ? "0 0 0 2px #fff inset" : "none";
                            string dotTransform = selected ? "scale(1.2)"           : "scale(1)";
                            <div @onclick="() => _editingProject.ColorCode = hex"
                                 style="width:28px; height:28px; border-radius:50%; background:@hex; cursor:pointer;
                                        border:@dotBorder; box-shadow:@dotShadow; transform:@dotTransform;">
                            </div>
                        }
                        <input type="color"
                               value="@(string.IsNullOrEmpty(_editingProject.ColorCode) ? "#b8e0c8" : _editingProject.ColorCode)"
                               @onchange="e => _editingProject.ColorCode = e.Value?.ToString() ?? string.Empty"
                               style="width:28px; height:28px; border-radius:50%; border:2px solid var(--border);
                                      padding:0; cursor:pointer; overflow:hidden;"
                               title="직접 색상 선택" />
                    </div>
                </div>

                @* ── 메모 ── *@
                <div class="form-group" style="margin-top:28px;">
                    <label class="form-label">메모</label>
                    <textarea class="form-control" rows="2" @bind="_editingProject.Memo" placeholder="기타 메모"></textarea>
                </div>
            }

            <div class="modal-footer" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
                @if (_editingProject?.Id != Guid.Empty)
                {
                            <button class="btn btn-ghost" style="color:var(--text-light); display:inline-flex;align-items:center;gap:4px;" @onclick="MoveToWishlist" disabled="@_saving"><img src="icons/arrow-u-up-left.svg" class="icon-line" style="width:13px;height:13px;flex-shrink:0;" />@(_saving ? "복귀 중..." : "위시리스트로 복귀")</button>
                }
                else
                {
                    <span></span>
                }
                <div style="display:flex; gap:8px;">
                    <button class="btn btn-ghost" @onclick="CloseModal">취소</button>
                    <button class="btn btn-primary" @onclick="SaveProject" disabled="@_saving">@(_saving ? "저장 중..." : "저장")</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 삭제 확인 모달 -->
@if (_showConfirm)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;padding:20px;">
        <div style="background:#fff;border-radius:16px;max-width:320px;width:100%;padding:24px 20px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,0.18);" @onclick:stopPropagation="true">
            <div style="margin-bottom:12px;display:flex;justify-content:center;"><img src="icons/trash.svg" class="icon-line" style="width:32px;height:32px;" /></div>
            <div style="font-size:1rem; font-weight:600; margin-bottom:8px; color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem; color:var(--text-mid); margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => _showConfirm = false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _saving = false;
    bool _showConfirm = false;
    string _confirmMsg = "";
    Func<Task>? _confirmAction;

    void Confirm(string msg, Func<Task> action)
    {
        _confirmMsg    = msg;
        _confirmAction = action;
        _showConfirm   = true;
    }

    async Task ExecuteConfirm()
    {
        _showConfirm = false;
        if (_confirmAction != null)
            await _confirmAction();
        _confirmAction = null;
    }

    bool _loading = true;
    bool _isListView = false;
    bool _showCompletedPopup = false;
    List<Guid>? _swatchSnapshot;
    KnitProject? _completedPreview;

    class PopMeasureItem
    {
        public string Label { get; set; } = "";
        public string Before { get; set; } = "";
        public string After  { get; set; } = "";
        public bool IsCustom { get; set; } = false;
    }
    string _sortField = "created";
    bool _sortAsc = false;          // false = 내림차순(기본), true = 오름차순
    string _statusFilter = "all";   // "all" | "진행중" | "일시중단"
    List<KnitProject> _projects = new();

    // 컬러피커 프리셋
    static readonly string[] _colorOptions = new[]
    {
        "#f2b8c6", "#f7e4a0", "#b8e0c8", "#c8b8e8", "#b8d8f0",
        "#ffb74d", "#a5d6a7", "#ef9a9a", "#90caf9", "#ce93d8"
    };

    IEnumerable<KnitProject> FilteredSortedProjects
    {
        get
        {
            // 1) 상태 필터
            var filtered = _statusFilter switch
            {
                "진행중"   => _projects.Where(p => p.Status == ProjectStatus.진행중),
                "일시중단" => _projects.Where(p => p.Status == ProjectStatus.일시중단),
                _          => _projects.AsEnumerable(),
            };

            // 2) 정렬 (오름/내림 모두 지원)
            Func<KnitProject, object> keySelector = _sortField switch
            {
                "start"   => p => (object)(p.StartDate ?? DateTime.MaxValue),
                "updated" => p => (object)p.CreatedAt,
                "title"   => p => (object)p.Title,
                _         => p => (object)p.CreatedAt,
            };

            return _sortAsc
                ? filtered.OrderBy(keySelector)
                : filtered.OrderByDescending(keySelector);
        }
    }

    async Task ToggleSortDir()
    {
        _sortAsc = !_sortAsc;
        await SaveSchedulePrefs();
    }

    bool _showModal = false;
    List<Yarn> _yarns = new();
    List<KnitTool> _tools = new();
    List<Swatch> _allSwatches = new();
    KnitProject? _editingProject;

    protected override async Task OnInitializedAsync()
    {
        // 마지막 상태 복원
        var filter   = await JS.InvokeAsync<string?>("localStorage.getItem", "sched_filter");
        var sort     = await JS.InvokeAsync<string?>("localStorage.getItem", "sched_sort");
        var sortAsc  = await JS.InvokeAsync<string?>("localStorage.getItem", "sched_sortasc");
        var listview = await JS.InvokeAsync<string?>("localStorage.getItem", "sched_listview");
        if (!string.IsNullOrEmpty(filter))   _statusFilter = filter;
        if (!string.IsNullOrEmpty(sort))     _sortField    = sort;
        if (!string.IsNullOrEmpty(sortAsc))  _sortAsc      = sortAsc == "true";
        if (!string.IsNullOrEmpty(listview)) _isListView   = listview == "true";
        await LoadData();
        _loading = false;
        // ProjectDetail에서 완료 후 신호 확인
        var completedId = await JS.InvokeAsync<string?>("localStorage.getItem", "knitlog_completed_popup");
        if (!string.IsNullOrEmpty(completedId) && Guid.TryParse(completedId, out var cpid))
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "knitlog_completed_popup");
            var allProj = await Storage.GetProjectsAsync();
            _completedPreview = allProj.FirstOrDefault(p => p.Id == cpid);
            if (_completedPreview != null) { _showCompletedPopup = true; StateHasChanged(); }
        }
    }

    async Task SaveSchedulePrefs()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "sched_filter",  _statusFilter);
        await JS.InvokeVoidAsync("localStorage.setItem", "sched_sort",    _sortField);
        await JS.InvokeVoidAsync("localStorage.setItem", "sched_sortasc", _sortAsc.ToString().ToLower());
        await JS.InvokeVoidAsync("localStorage.setItem", "sched_listview",_isListView.ToString().ToLower());
    }

    async Task LoadData()
    {
        var all = await Storage.GetProjectsAsync();
        _projects = all.Where(p => p.Status == ProjectStatus.진행중 || p.Status == ProjectStatus.일시중단).ToList();
        _yarns = await Storage.GetYarnsAsync();
        _tools = await Storage.GetToolsAsync();
        _allSwatches = await Storage.GetSwatchesAsync();
    }

    void GoToDetail(Guid id) => Nav.NavigateTo("projects/" + id + "?from=projects");

    void OpenAddModal()
    {
        _editingProject = new KnitProject
        {
            Id = Guid.Empty,
            Status = ProjectStatus.진행중,
            StartDate = DateTime.Today
        };
        _showModal = true;
    }

    void OpenEditModal(KnitProject proj)
    {
        // 취소 시 복원을 위해 JSON 딥카피
        var json = System.Text.Json.JsonSerializer.Serialize(proj);
        _editingProject = System.Text.Json.JsonSerializer.Deserialize<KnitProject>(json)!;
        // 스와치 연결 상태 스냅샷 (projectId 기준)
        _swatchSnapshot = _allSwatches
            .Where(s => s.ProjectId == proj.Id)
            .Select(s => s.Id)
            .ToList();
        _showModal = true;
    }

    async Task MoveToWishlist()
    {
        if (_editingProject == null) return;
        _editingProject.Status = ProjectStatus.위시리스트;
        // UI 즉시 반응
        _projects.Remove(_editingProject);
        CloseModal();
        StateHasChanged();
        // 백그라운드 저장
        await Storage.SaveProjectAsync(_editingProject);
        await LoadData();
    }

    void CloseModal()
    {
        // 스와치 연결 상태 복원
        if (_swatchSnapshot != null && _editingProject != null)
        {
            foreach (var s in _allSwatches.Where(s => s.ProjectId == _editingProject.Id).ToList())
                s.ProjectId = null;
            foreach (var id in _swatchSnapshot)
            {
                var s = _allSwatches.FirstOrDefault(x => x.Id == id);
                if (s != null) s.ProjectId = _editingProject.Id;
            }
            _swatchSnapshot = null;
        }
        _showModal = false;
        _editingProject = null;
    }

    void OnAddYarn(ChangeEventArgs e)
    {
        if (_editingProject == null) return;
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val)) return;
        var yarnId = Guid.Parse(val);
        if (!_editingProject.YarnUsages.Any(u => u.YarnId == yarnId))
            _editingProject.YarnUsages.Add(new ProjectYarnUsage { YarnId = yarnId, BallsUsed = 1 });
    }

    void OnScheduleSwatchSelect(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val) || _editingProject == null) return;
        if (!Guid.TryParse(val, out var swatchId)) return;
        var swatch = _allSwatches.FirstOrDefault(s => s.Id == swatchId);
        if (swatch == null) return;
        if (_editingProject.Id == Guid.Empty) return;
        // 기존 연결 스와치 해제 (단일 연결)
        foreach (var s in _allSwatches.Where(s => s.ProjectId == _editingProject.Id))
            s.ProjectId = null;
        swatch.ProjectId = _editingProject.Id;
    }

    void ToggleTool(Guid toolId)
    {
        if (_editingProject == null) return;
        if (_editingProject.ToolIds.Contains(toolId))
            _editingProject.ToolIds.Remove(toolId);
        else
            _editingProject.ToolIds.Add(toolId);
    }

    async Task SaveProject()
    {
        _saving = true; StateHasChanged();
        if (_editingProject == null || string.IsNullOrWhiteSpace(_editingProject.PatternName)) return;
        if (string.IsNullOrWhiteSpace(_editingProject.Title))
            _editingProject.Title = _editingProject.PatternName;
        if (_editingProject.Id == Guid.Empty)
            _editingProject.Id = Guid.NewGuid();
        await Storage.SaveProjectAsync(_editingProject);
        foreach (var s in _allSwatches)
            await Storage.SaveSwatchAsync(s);
        _swatchSnapshot = null;
        await LoadData();
        CloseModal();
        _saving = false;
        await JS.InvokeVoidAsync("showToast", "저장됐어요");
        }

    async Task ToggleSuspend(KnitProject proj)
    {
        _saving = true; StateHasChanged();
        proj.Status = proj.Status == ProjectStatus.진행중
            ? ProjectStatus.일시중단
            : ProjectStatus.진행중;
        await Storage.SaveProjectAsync(proj);
        await LoadData();

        _saving = false;
        }

    async Task CompleteProject(Guid id)
    {
        var proj = _projects.FirstOrDefault(p => p.Id == id);
        if (proj == null) return;

        // 1. 팝업 즉시 띄우기 (사용자에게 빠르게 반응)
        proj.Status = KnitLog.Models.ProjectStatus.완료;
        if (!proj.EndDate.HasValue) proj.EndDate = DateTime.Today;
        _completedPreview = proj;
        _showCompletedPopup = true;
        StateHasChanged();

        // 2. 백그라운드 저장
        await Storage.CompleteProjectAsync(id);

        // 3. 목록 갱신
        await LoadData();
    }

    void CloseCompletedPopup()
    {
        _showCompletedPopup = false;
        _completedPreview = null;
    }











    async Task DeleteProject(Guid id)
    {
        await Storage.DeleteProjectAsync(id);
        await LoadData();
    }

    async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        if (_editingProject == null) return;
        foreach (var file in e.GetMultipleFiles(10))
        {
            var buf = new byte[file.Size];
            await file.OpenReadStream(10 * 1024 * 1024).ReadAsync(buf);
            var base64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(buf)}";
            _editingProject.Photos.Add(new ProjectPhoto
            {
                FileName = file.Name,
                Base64Data = base64,
                TakenAt = DateTime.Now
            });
        }
    }

    void RemovePhoto(Guid photoId)
    {
        _editingProject?.Photos.RemoveAll(p => p.Id == photoId);
    }
}
