@* =====================================================================
   Pages/Swatches.razor  —  스와치 목록 & 관리
   ===================================================================== *@
@page "/swatches"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage

<div class="page-header">
    <div>
        <h1 class="page-title">🧪 스와치</h1>
        <p class="page-subtitle">실별 게이지와 수축률을 기록해요</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal">+ 스와치 추가</button>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_swatches.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">🧪</div>
        <p>아직 스와치가 없어요.<br/>첫 번째 스와치를 기록해보세요!</p>
    </div>
}
else
{
    <div class="grid-3">
        @foreach (var s in _swatches)
        {
            var yarn = _yarns.Find(y => y.Id == s.YarnId);
            var project = _projects.Find(p => p.Id == s.ProjectId);
            
            <div class="card swatch-card">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
                    <div>
                        <div class="card-title" style="margin-bottom:4px;">
                            @(string.IsNullOrEmpty(s.Name) ? "스와치" : s.Name)
                        </div>
                        @if (yarn != null)
                        {
                            <div style="display:flex; align-items:center; gap:6px; font-size:0.82rem; color:var(--text-mid);">
                                <span class="color-dot" style="background:@yarn.ColorCode; width:12px; height:12px;"></span>
                                @yarn.Brand @yarn.Name
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(s.YarnNameDirect))
                        {
                            <div style="font-size:0.82rem; color:var(--text-mid);">🧵 @s.YarnNameDirect</div>
                        }
                    </div>
                    <div style="display:flex; gap:6px;">
                        <button class="btn btn-ghost btn-sm" title="게이지 계산기" @onclick="() => OpenCalcModal(s)">🧮</button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => OpenEditModal(s)">✏️</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteSwatch(s.Id)">✕</button>
                    </div>
                </div>

                @* 바늘 & 뜨개법 *@
                <div style="display:flex; gap:8px; margin-bottom:12px; flex-wrap:wrap;">
                    @if (s.NeedleSizeMm > 0)
                    {
                        <span class="badge" style="background:var(--sky-pale); color:#1a5276;"> @s.NeedleSizeMm mm</span>
                    }
                    <span class="badge" style="background:var(--lavender-pale); color:#4e3290;">@s.Stitch</span>
                </div>

                @* 게이지 표 *@
                <div style="background:var(--ivory-dark); border-radius:var(--radius-sm); padding:12px; margin-bottom:12px; font-size:0.82rem;">
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center; margin-bottom:6px;">
                        <div style="color:var(--text-light); font-size:0.75rem;"></div>
                        <div style="color:var(--text-mid); font-weight:600;">세탁 전</div>
                        <div style="color:var(--text-mid); font-weight:600;">세탁 후</div>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center; margin-bottom:4px;">
                        <div style="color:var(--text-light); text-align:left;">코수</div>
                        <div>@s.PreWashStitches</div>
                        <div>@s.PostWashStitches</div>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center; margin-bottom:4px;">
                        <div style="color:var(--text-light); text-align:left;">단수</div>
                        <div>@s.PreWashRows</div>
                        <div>@s.PostWashRows</div>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center; margin-bottom:4px;">
                        <div style="color:var(--text-light); text-align:left;">가로</div>
                        <div>@s.PreWashWidthCm cm</div>
                        <div>@s.PostWashWidthCm cm</div>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center;">
                        <div style="color:var(--text-light); text-align:left;">세로</div>
                        <div>@s.PreWashHeightCm cm</div>
                        <div>@s.PostWashHeightCm cm</div>
                    </div>
                </div>

                @* 변화율 *@
                @{
                    var wRate = CalcRate(s.PreWashStitches, s.PostWashStitches, s.PreWashWidthCm, s.PostWashWidthCm);
                    var hRate = CalcRate(s.PreWashRows, s.PostWashRows, s.PreWashHeightCm, s.PostWashHeightCm);
                }
                @if (wRate.HasValue || hRate.HasValue)
                {
                    <div style="display:flex; gap:8px; margin-bottom:10px;">
                        @if (wRate.HasValue)
                        {
                            var wColor = wRate.Value < 0 ? "#c0392b" : "#267848";
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:8px; text-align:center;">
                                <div style="font-size:0.75rem; color:var(--text-light);">가로 변화율</div>
                                <div style="font-size:1.1rem; font-weight:700; color:@wColor;">
                                    @(wRate.Value > 0 ? "+" : "")@wRate.Value%
                                </div>
                            </div>
                        }
                        @if (hRate.HasValue)
                        {
                            var hColor = hRate.Value < 0 ? "#c0392b" : "#267848";
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:8px; text-align:center;">
                                <div style="font-size:0.75rem; color:var(--text-light);">세로 변화율</div>
                                <div style="font-size:1.1rem; font-weight:700; color:@hColor;">
                                    @(hRate.Value > 0 ? "+" : "")@hRate.Value%
                                </div>
                            </div>
                        }
                    </div>
                }

                @* 연결 프로젝트 *@
                @if (project != null)
                {
                    <div style="font-size:0.8rem; color:var(--text-mid); border-top:1px solid var(--border); padding-top:8px; margin-top:4px;">
                        🔗 @project.Title
                    </div>
                }

                @* 메모 *@
                @if (!string.IsNullOrEmpty(s.Memo))
                {
                    <div style="font-size:0.8rem; color:var(--text-light); margin-top:6px; white-space:pre-wrap;">@s.Memo</div>
                }
            </div>
        }
    </div>
}

@* ── 추가/수정 모달 ── *@
@if (_showModal)
{
    var pw2 = CalcRate(_editing.PreWashStitches, _editing.PostWashStitches, _editing.PreWashWidthCm, _editing.PostWashWidthCm); 
    var ph2 = CalcRate(_editing.PreWashRows, _editing.PostWashRows, _editing.PreWashHeightCm, _editing.PostWashHeightCm);

    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(_isEditMode ? "스와치 수정" : "스와치 추가")</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseModal">✕</button>
            </div>

            <div class="modal-body" style="max-height: 70vh; overflow-y: auto; padding-right: 4px;">
                <div class="form-group">
                    <label class="form-label">스와치 이름 (선택)</label>
                    <input class="form-control" @bind="_editing.Name" placeholder="예: 러스크 메리야스" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">사용 실 — 자스에서 선택</label>
                        <select class="form-control" value="@_editing.YarnId" @onchange="OnYarnChanged">
                            <option value="">선택 안 함</option>
                            @foreach (var y in _yarns)
                            {
                                <option value="@y.Id">@y.Brand @y.Name (@y.Color)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">또는 직접 입력</label>
                        <input class="form-control" @bind="_editing.YarnNameDirect" placeholder="" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">연결 프로젝트/위시리스트</label>
                        <select class="form-control" value="@_editing.ProjectId" @onchange="OnProjectChanged">
                            <option value="">선택 안 함</option>
                            @foreach (var p in _projects)
                            {
                                <option value="@p.Id">[@p.Status] @p.Title</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">바늘 굵기 (mm)</label>
                        <input class="form-control" type="number" step="0.25" @bind="_editing.NeedleSizeMm" placeholder="예: 4.5" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">뜨개 방법</label>
                        <input class="form-control" @bind="_editing.Stitch" placeholder="예: 메리야스, 가터, 2x2 고무단" />
                    </div>
                </div>

                @* 세탁 전 *@
                <div style="background:var(--mint-pale); border-radius:var(--radius-sm); padding:14px; margin-bottom:16px;">
                    <div style="font-size:0.88rem; font-weight:600; color:#267848; margin-bottom:10px;">세탁 전</div>
                    <div class="form-row">
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">코수</label>
                            <input class="form-control" type="number" step="0.5" @bind="_editing.PreWashStitches" />
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">단수</label>
                            <input class="form-control" type="number" step="0.5" @bind="_editing.PreWashRows" />
                        </div>
                    </div>
                    <div class="form-row" style="margin-top:10px;">
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">가로 (cm)</label>
                            <input class="form-control" type="number" step="0.1" @bind="_editing.PreWashWidthCm" />
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">세로 (cm)</label>
                            <input class="form-control" type="number" step="0.1" @bind="_editing.PreWashHeightCm" />
                        </div>
                    </div>
                </div>

                @* 세탁 후 *@
                <div style="background:var(--yellow-pale); border-radius:var(--radius-sm); padding:14px; margin-bottom:16px;">
                    <div style="font-size:0.88rem; font-weight:600; color:#8a6a08; margin-bottom:10px;">세탁 후</div>
                    <div class="form-row">
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">코수</label>
                            <input class="form-control" type="number" step="0.5" @bind="_editing.PostWashStitches" />
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">단수</label>
                            <input class="form-control" type="number" step="0.5" @bind="_editing.PostWashRows" />
                        </div>
                    </div>
                    <div class="form-row" style="margin-top:10px;">
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">가로 (cm)</label>
                            <input class="form-control" type="number" step="0.1" @bind="_editing.PostWashWidthCm" />
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">세로 (cm)</label>
                            <input class="form-control" type="number" step="0.1" @bind="_editing.PostWashHeightCm" />
                        </div>
                    </div>

                    @* 변화율 미리보기 *@
                    @if (pw2.HasValue || ph2.HasValue)
                    {
                        <div style="display:flex; gap:8px; margin-top:12px;">
                            @if (pw2.HasValue)
                            {
                                string pwColor = pw2.Value < 0 ? "#c0392b" : "#267848";
                                <div style="flex:1; background:white; border-radius:var(--radius-sm); padding:8px; text-align:center;">
                                    <div style="font-size:0.72rem; color:var(--text-light);">가로 변화율</div>
                                    <div style="font-weight:700; color:@pwColor;">
                                        @(pw2.Value > 0 ? "+" : "")@pw2.Value%
                                    </div>
                                </div>
                            }
                            @if (ph2.HasValue)
                            {
                                string phColor = ph2.Value < 0 ? "#c0392b" : "#267848";
                                <div style="flex:1; background:white; border-radius:var(--radius-sm); padding:8px; text-align:center;">
                                    <div style="font-size:0.72rem; color:var(--text-light);">세로 변화율</div>
                                    <div style="font-weight:700; color:@phColor;">
                                        @(ph2.Value > 0 ? "+" : "")@ph2.Value%
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label">메모</label>
                    <textarea class="form-control" rows="3" @bind="_editing.Memo" placeholder="세탁 방법, 특이사항 등"></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">취소</button>
                <button class="btn btn-primary" @onclick="SaveSwatch">저장</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = false;
    private bool _showModal = false;
    private bool _isEditMode = false;
    
    private List<SwatchModel> _swatches = new();
    private List<YarnModel> _yarns = new();
    private List<ProjectModel> _projects = new();
    private SwatchModel _editing = new();

    // 데이터 모델 정의 (실제 프로젝트 모델 구조에 맞게 커스텀해 쓰세요)
    public class SwatchModel {
        public Guid Id { get; set; } = Guid.Empty;
        public string Name { get; set; } = "";
        public Guid? YarnId { get; set; }
        public string YarnNameDirect { get; set; } = "";
        public Guid? ProjectId { get; set; }
        public double NeedleSizeMm { get; set; }
        public string Stitch { get; set; } = "";
        public double PreWashStitches { get; set; }
        public double PostWashStitches { get; set; }
        public double PreWashRows { get; set; }
        public double PostWashRows { get; set; }
        public double PreWashWidthCm { get; set; }
        public double PostWashWidthCm { get; set; }
        public double PreWashHeightCm { get; set; }
        public double PostWashHeightCm { get; set; }
        public string Memo { get; set; } = "";

        // 깊은 복사를 위한 메서드 (수정 취소 시 원본 유지 목적)
        public SwatchModel Clone() => (SwatchModel)this.MemberwiseClone();
    }
    public class YarnModel { public Guid Id { get; set; } public string Brand { get; set; } = ""; public string Name { get; set; } = ""; public string Color { get; set; } = ""; public string ColorCode { get; set; } = "#cccccc"; }
    public class ProjectModel { public Guid Id { get; set; } public string Title { get; set; } = ""; public string Status { get; set; } = ""; }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            // 초기 데이터 로딩 예시 (원래 사용하시던 스토리지 로드 코드가 있다면 여기에 넣으세요)
            // _swatches = await Storage.GetSwatchesAsync() ?? new();
            // _yarns = await Storage.GetYarnsAsync() ?? new();
            // _projects = await Storage.GetProjectsAsync() ?? new();
        }
        finally
        {
            _loading = false;
        }
    }

    private double? CalcRate(double preCount, double postCount, double preCm, double postCm)
    {
        if (preCount <= 0 || postCount <= 0 || preCm <= 0 || postCm <= 0) return null;
        
        double preDensity = preCount / preCm;
        double postDensity = postCount / postCm;
        
        if (preDensity == 0) return null;
        return Math.Round(((postDensity - preDensity) / preDensity) * 100, 1);
    }

    private void OpenAddModal() 
    { 
        _isEditMode = false;
        _editing = new SwatchModel(); 
        _showModal = true; 
    }

    private void OpenEditModal(SwatchModel swatch) 
    { 
        _isEditMode = true;
        // 원본 데이터를 직접 수정하면 취소했을 때 엉망이 되므로 Clone(복사본)을 수정합니다.
        _editing = swatch.Clone(); 
        _showModal = true; 
    }

    private void OpenCalcModal(SwatchModel swatch) { /* 게이지 계산기 로직 필요 시 작성 */ }
    private void CloseModal() => _showModal = false;

    private void SaveSwatch()
    {
        if (!_isEditMode)
        {
            // 1. 신규 추가인 경우
            _editing.Id = Guid.NewGuid(); // 고유 ID 부여
            _swatches.Add(_editing);      // 보여줄 목록 리스트에 확실하게 집어넣기! 🌟
        }
        else
        {
            // 2. 기존 데이터 수정인 경우
            var index = _swatches.FindIndex(s => s.Id == _editing.Id);
            if (index != -1)
            {
                _swatches[index] = _editing; // 목록 리스트의 아이템 복사본으로 교체
            }
        }

        // 실제 브라우저나 파일에 저장하는 비동기 서비스가 있다면 추가하세요
        // Storage.SaveSwatches(_swatches);

        _showModal = false;
        StateHasChanged(); // 변경된 리스트로 화면을 강제 갱신합니다. 🔄
    }

    private void DeleteSwatch(Guid id) 
    { 
        var swatch = _swatches.Find(s => s.Id == id);
        if (swatch != null)
        {
            _swatches.Remove(swatch);
            // Storage.SaveSwatches(_swatches);
            StateHasChanged();
        }
    }
    
    private void OnYarnChanged(ChangeEventArgs e) 
    { 
        if (Guid.TryParse(e.Value?.ToString(), out Guid yarnId)) _editing.YarnId = yarnId;
        else _editing.YarnId = null;
    }

    private void OnProjectChanged(ChangeEventArgs e) 
    { 
        if (Guid.TryParse(e.Value?.ToString(), out Guid projId)) _editing.ProjectId = projId;
        else _editing.ProjectId = null;
    }
}