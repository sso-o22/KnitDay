@* =====================================================================
   Pages/Swatches.razor  —  스와치 목록 & 관리
   ===================================================================== *@
@page "/swatches"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject IJSRuntime JS

<div class="page-header">
    <div>
        <h1 class="page-title"><img src="icons/swatches.svg" class="icon-line" style="width:36px;height:36px;" />스와치</h1>
        <p class="page-subtitle">실별 게이지와 수축률을 기록해요</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal" style="display:inline-flex;align-items:center;gap:5px;"><img src="icons/plus.svg" class="icon-line" style="width:14px;height:14px;flex-shrink:0;" />스와치 추가</button>
</div>

@* ── 필터 ── *@
@if (_swatches.Count > 0)
{
    <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:16px;">
        @* 1행: 프로젝트 연결 유무 *@
        <div style="display:flex; flex-wrap:wrap; gap:6px; align-items:center;">
            @foreach (var (label, val) in new[]{("전체",""),("연결됨","linked"),("연결 없음","unlinked")})
            {
                <button class="btn btn-sm @(_filterProject==val?"btn-primary":"btn-ghost")"
                        @onclick="() => SetFilterProject(val)">@label</button>
            }
        </div>
        @* 2행: 뜨개 방법 *@
        <div style="display:flex; flex-wrap:wrap; gap:6px; align-items:center;">
            @foreach (var (label, val) in new[]{("전체방법",""),("메리야스","메리야스"),("무늬","무늬"),("가터","가터"),("고무단","고무단")})
            {
                <button class="btn btn-sm @(_filterStitch==val?"btn-primary":"btn-ghost")"
                        @onclick="() => SetFilterStitch(val)">@label</button>
            }
        </div>
        @* 3행: 바늘 mm 콤보박스 + 초기화 *@
        <div style="display:flex; gap:8px; align-items:center;">
            <select class="form-control" style="width:auto; min-width:110px; font-size:0.82rem;"
                    value="@_filterNeedle" @onchange="OnFilterNeedleChanged">
                <option value="">전체 바늘</option>
                @foreach (var mm in NeedleOptions)
                {
                    <option value="@mm">@mm mm</option>
                }
            </select>
            @if (_filterProject != "" || _filterStitch != "" || _filterNeedle != "")
            {
                <button class="btn btn-ghost btn-sm" @onclick="ResetFilters">✕ 초기화</button>
            }
        </div>
        <div style="display:flex; gap:6px; margin-bottom:16px; align-items:center; flex-wrap:wrap;">
            <span style="font-size:0.78rem; color:var(--text-light);">정렬</span>
            @foreach (var (label, val) in new[]{("등록일↓","created_desc"),("이름순","name_asc"),("바늘↑","needle_asc")})
            {
                <button class="btn btn-sm @(_swatchSort==val?"btn-sage":"btn-ghost")"
                        @onclick="async () => await SetSwatchSort(val)">@label</button>
            }
        </div>
    </div>
}

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_swatches.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon"><img src="icons/swatches.svg" class="icon-line" style="width:48px;height:48px;" /></div>
        <p>아직 스와치가 없어요.<br/>첫 번째 스와치를 기록해보세요!</p>
    </div>
}
else
{
    <div class="grid-3">
        @foreach (var s in SortedSwatches)
        {
            var yarn = _yarns.Find(y => y.Id == s.YarnId);
            var project = _projects.Find(p => p.Id == s.ProjectId);
            <div class="card swatch-card">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
                    <div>
                        <div class="card-title" style="margin-bottom:4px;">
                            @(string.IsNullOrEmpty(s.Name) ? "스와치" : s.Name)
                        </div>
                        @if (yarn != null)
                        {
                            <div style="display:flex; align-items:center; gap:6px; font-size:0.82rem; color:var(--text-mid); overflow:hidden;">
                                <span class="color-dot" style="background:@yarn.ColorCode; width:12px; height:12px; flex-shrink:0;"></span>
                                <span style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@yarn.Brand @yarn.Name</span>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(s.YarnNameDirect))
                        {
                            <div style="font-size:0.82rem; color:var(--text-mid); display:flex;align-items:center;gap:4px;"><img src="icons/yarn.svg" class="icon-line" style="width:13px;height:13px;flex-shrink:0;" />@s.YarnNameDirect</div>
                        }
                    </div>
                    <div style="display:flex; gap:6px;">
                        <button class="btn btn-ghost btn-sm" title="게이지 계산기" @onclick="() => OpenCalcModal(s)" style="display:inline-flex;align-items:center;"><img src="icons/calculator.svg" class="icon-line" style="width:14px;height:14px;flex-shrink:0;" /></button>
                        <button class="btn btn-ghost btn-sm" style="display:inline-flex;align-items:center;" @onclick="() => OpenEditModal(s)"><img src="icons/pencil.svg" class="icon-line" style="width:14px;height:14px;flex-shrink:0;" /></button>
                        <button class="btn btn-danger btn-sm" style="display:inline-flex;align-items:center;" @onclick='() => Confirm("이 스와치를 삭제하면 복구할 수 없어요.", async () => await DeleteSwatch(s.Id))'><img src="icons/trash.svg" class="icon-line" style="width:14px;height:14px;flex-shrink:0;" /></button>
                    </div>
                </div>

                @* 바늘 & 뜨개법 *@
                <div style="display:flex; gap:8px; margin-bottom:12px; flex-wrap:wrap;">
                    @if (s.NeedleSizeMm > 0)
                    {
                        <span class="badge" style="background:var(--sky-pale); color:#1a5276;"> @s.NeedleSizeMm mm</span>
                    }
                    <span class="badge" style="background:var(--lavender-pale); color:#4e3290;">@s.Stitch</span>
                </div>

                @* 게이지 표 *@
                <div style="background:var(--ivory-dark); border-radius:var(--radius-sm); padding:12px; margin-bottom:12px; font-size:0.82rem;">
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center; margin-bottom:6px;">
                        <div style="color:var(--text-light); font-size:0.75rem;"></div>
                        <div style="color:var(--text-mid); font-weight:600;">세탁 전</div>
                        <div style="color:var(--text-mid); font-weight:600;">세탁 후</div>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center; margin-bottom:4px;">
                        <div style="color:var(--text-light); text-align:left;">코수</div>
                        <div>@s.PreWashStitches</div>
                        <div>@s.PostWashStitches</div>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center; margin-bottom:4px;">
                        <div style="color:var(--text-light); text-align:left;">단수</div>
                        <div>@s.PreWashRows</div>
                        <div>@s.PostWashRows</div>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center; margin-bottom:4px;">
                        <div style="color:var(--text-light); text-align:left;">가로</div>
                        <div>@s.PreWashWidthCm cm</div>
                        <div>@s.PostWashWidthCm cm</div>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px; text-align:center;">
                        <div style="color:var(--text-light); text-align:left;">세로</div>
                        <div>@s.PreWashHeightCm cm</div>
                        <div>@s.PostWashHeightCm cm</div>
                    </div>
                </div>

                @* 변화율 *@
                @{
                    var wRate = CalcRate(s.PreWashStitches, s.PostWashStitches, s.PreWashWidthCm, s.PostWashWidthCm);
                    var hRate = CalcRate(s.PreWashRows, s.PostWashRows, s.PreWashHeightCm, s.PostWashHeightCm);
                }
                @if (wRate.HasValue || hRate.HasValue)
                {
                    <div style="display:flex; gap:8px; margin-bottom:10px;">
                        @if (wRate.HasValue)
                        {
                            var wColor = wRate.Value < 0 ? "#c0392b" : "#267848";
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:8px; text-align:center;">
                                <div style="font-size:0.75rem; color:var(--text-light);">가로 변화율</div>
                                <div style="font-size:1.1rem; font-weight:700; color:@wColor;">
                                    @(wRate.Value > 0 ? "+" : "")@wRate.Value%
                                </div>
                            </div>
                        }
                        @if (hRate.HasValue)
                        {
                            var hColor = hRate.Value < 0 ? "#c0392b" : "#267848";
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:8px; text-align:center;">
                                <div style="font-size:0.75rem; color:var(--text-light);">세로 변화율</div>
                                <div style="font-size:1.1rem; font-weight:700; color:@hColor;">
                                    @(hRate.Value > 0 ? "+" : "")@hRate.Value%
                                </div>
                            </div>
                        }
                    </div>
                }

                @* 연결 프로젝트 *@
                @if (project != null)
                {
                    <div style="font-size:0.8rem; color:var(--text-mid); border-top:1px solid var(--border); padding-top:8px; margin-top:4px;">
                        <span style="display:inline-flex;align-items:center;gap:4px;"><img src="icons/link-simple.svg" class="icon-line" style="width:13px;height:13px;flex-shrink:0;" />@project.Title</span>
                    </div>
                }

                @* 메모 *@
                @if (!string.IsNullOrEmpty(s.Memo))
                {
                    <div style="font-size:0.8rem; color:var(--text-light); margin-top:6px; white-space:pre-wrap;">@s.Memo</div>
                }

                @* 사진 *@
                @if (!string.IsNullOrEmpty(s.PhotoBase64))
                {
                    <div style="margin-top:10px;">
                        <img src="@s.PhotoBase64" style="width:100%; border-radius:var(--radius-sm); object-fit:cover; max-height:180px;" />
                    </div>
                }
            </div>
        }
    </div>
}

@* ── 추가/수정 모달 ── *@
@{ var pw2 = _showModal ? CalcRate(_editing.PreWashStitches, _editing.PostWashStitches, _editing.PreWashWidthCm, _editing.PostWashWidthCm) : null; var ph2 = _showModal ? CalcRate(_editing.PreWashRows, _editing.PostWashRows, _editing.PreWashHeightCm, _editing.PostWashHeightCm) : null; }
@if (_showModal)
{
    <div class="modal-backdrop">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(_editing.Id == Guid.Empty ? "스와치 추가" : "스와치 수정")</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseModal">✕</button>
            </div>

            <div class="form-group">
                <label class="form-label">스와치 이름 (선택)</label>
                <input class="form-control" @bind="_editing.Name" placeholder="예: 러스크 메리야스" />
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                <div class="form-group">
                    <label class="form-label">사용 실 — 창고에서 선택</label>
                    <select class="form-control" value="@_editing.YarnId" @onchange="OnYarnChanged">
                        <option value="">선택 안 함</option>
                        @foreach (var y in _yarns)
                        {
                            <option value="@y.Id">@y.Brand @y.Name (@y.Color)</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">또는 직접 입력</label>
                    <input class="form-control" @bind="_editing.YarnNameDirect" placeholder="" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                <div class="form-group">
                    <label class="form-label">연결 프로젝트/위시리스트</label>
                    <select class="form-control" value="@_editing.ProjectId" @onchange="OnProjectChanged">
                        <option value="">선택 안 함</option>
                        @foreach (var p in _projects)
                        {
                            <option value="@p.Id">[@p.Status] @p.Title</option>
                        }
                    </select>
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                <div class="form-group">
                    <label class="form-label">바늘 굵기 (mm)</label>
                    <input class="form-control" type="number" step="0.25" placeholder="예: 4.5"
                                   value="@(_editing.NeedleSizeMm == 0 ? "" : _editing.NeedleSizeMm.ToString())"
                                   @onchange="e => _editing.NeedleSizeMm = double.TryParse(e.Value?.ToString(), out var d) ? d : 0" />
                </div>
                <div class="form-group">
                    <label class="form-label">뜨개 방법</label>
                    <select class="form-control" value="@_stitchSelect" @onchange="OnStitchSelectChanged">
                        <option value="메리야스">메리야스</option>
                        <option value="무늬">무늬</option>
                        <option value="가터">가터</option>
                        <option value="고무단">고무단</option>
                        <option value="직접입력">직접 입력</option>
                    </select>
                    @if (_stitchSelect == "직접입력")
                    {
                        <input class="form-control" style="margin-top:6px;" @bind="_editing.Stitch" placeholder="예: 2x2 고무단, 바스켓 무늬" />
                    }
                </div>
            </div>

            @* 세탁 전 *@
            <div style="background:var(--ivory-mid); border-radius:var(--radius-sm); padding:14px; margin-bottom:16px;">
                <div style="font-size:0.88rem; font-weight:600; color:var(--theme-active); margin-bottom:10px;">세탁 전</div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">코수</label>
                        <input class="form-control" type="number" step="0.5" @bind="_editing.PreWashStitches" />
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">단수</label>
                        <input class="form-control" type="number" step="0.5" @bind="_editing.PreWashRows" />
                    </div>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:10px;">
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">가로 (cm)</label>
                        <input class="form-control" type="number" step="0.1" @bind="_editing.PreWashWidthCm" />
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">세로 (cm)</label>
                        <input class="form-control" type="number" step="0.1" @bind="_editing.PreWashHeightCm" />
                    </div>
                </div>
            </div>

            @* 세탁 후 *@
            <div style="background:var(--ivory-mid); border-radius:var(--radius-sm); padding:14px; margin-bottom:16px;">
                <div style="font-size:0.88rem; font-weight:600; color:var(--theme-active); margin-bottom:10px;">세탁 후</div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">코수</label>
                        <input class="form-control" type="number" step="0.5" @bind="_editing.PostWashStitches" />
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">단수</label>
                        <input class="form-control" type="number" step="0.5" @bind="_editing.PostWashRows" />
                    </div>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:10px;">
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">가로 (cm)</label>
                        <input class="form-control" type="number" step="0.1" @bind="_editing.PostWashWidthCm" />
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">세로 (cm)</label>
                        <input class="form-control" type="number" step="0.1" @bind="_editing.PostWashHeightCm" />
                    </div>
                </div>

                @* 변화율 미리보기 *@
                @if (pw2.HasValue || ph2.HasValue)
                {
                    <div style="display:flex; gap:8px; margin-top:12px;">
                        @if (pw2.HasValue)
                        {
                            string pwColor = pw2.Value < 0 ? "#c0392b" : "#267848";
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:8px; text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light);">가로 변화율</div>
                                <div style="font-weight:700; color:@pwColor;">
                                    @(pw2.Value > 0 ? "+" : "")@pw2.Value%
                                </div>
                            </div>
                        }
                        @if (ph2.HasValue)
                        {
                            string phColor = ph2.Value < 0 ? "#c0392b" : "#267848";
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:8px; text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light);">세로 변화율</div>
                                <div style="font-weight:700; color:@phColor;">
                                    @(ph2.Value > 0 ? "+" : "")@ph2.Value%
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="form-group">
                <label class="form-label">메모</label>
                <textarea class="form-control" rows="3" @bind="_editing.Memo" placeholder="세탁 방법, 특이사항 등"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">사진</label>
                @if (!string.IsNullOrEmpty(_editing.PhotoBase64))
                {
                    <div style="position:relative; margin-bottom:8px;">
                        <img src="@_editing.PhotoBase64" style="width:100%; border-radius:var(--radius-sm); object-fit:cover; max-height:200px;" />
                        <button class="btn btn-danger btn-sm" style="position:absolute; top:6px; right:6px;"
                                @onclick="ClearPhoto">✕</button>
                    </div>
                }
                <InputFile OnChange="OnPhotoSelected" accept="image/*" class="form-control" style="font-size:0.82rem;" />
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">취소</button>
                <button class="btn btn-primary" @onclick="SaveSwatch" disabled="@_saving">@(_saving ? "저장 중..." : "저장")</button>
            </div>
        </div>
    </div>
}

@* ── 게이지 계산기 모달 ── *@
@{ var csg = _showCalcModal && _calcSwatch != null ? CalcSwatchStitchGauge(_calcSwatch) : 0.0; var crg = _showCalcModal && _calcSwatch != null ? CalcSwatchRowGauge(_calcSwatch) : 0.0; }
@if (_showCalcModal && _calcSwatch != null)
{
    <div class="modal-backdrop">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">게이지 계산기</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseCalcModal">✕</button>
            </div>
            <div style="background:var(--mint-pale); border-radius:var(--radius-sm); padding:12px; margin-bottom:16px; font-size:0.82rem;">
                <div style="font-weight:600; color:#267848; margin-bottom:6px; display:flex; align-items:center; gap:5px;"><img src="icons/push-pin.svg" class="icon-line" style="width:14px;height:14px;flex-shrink:0;" />@(string.IsNullOrEmpty(_calcSwatch.Name) ? "이 스와치" : _calcSwatch.Name)의 게이지</div>
                <div style="display:flex; gap:16px;">
                    @if (csg > 0)
                    {
                        <span>코: <strong>@csg.ToString("F1")</strong> / 10cm</span>
                    }
                    @if (crg > 0)
                    {
                        <span>단: <strong>@crg.ToString("F1")</strong> / 10cm</span>
                    }
                    @if (csg == 0 && crg == 0)
                    {
                        <span style="color:#c0392b;display:inline-flex;align-items:center;gap:4px;"><img src="icons/warning.svg" class="icon-line" style="width:14px;height:14px;" />코수/단수와 가로/세로 길이를 모두 입력해야 게이지를 계산할 수 있어요.</span>
                    }
                </div>
            </div>

            <div style="background:var(--ivory-mid); border-radius:var(--radius-sm); padding:14px; margin-bottom:14px;">
                <div style="font-size:0.88rem; font-weight:600; color:var(--theme-active); margin-bottom:8px;">① 콧수/단수 수정 계산기</div>
                <p style="font-size:0.78rem; color:var(--text-mid); margin-bottom:12px;">원작 게이지 + 도안 콧수/단수 → 내 게이지에 맞는 수정 콧수/단수</p>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label" style="font-size:0.78rem;">원작 코 게이지 (10cm당)</label>
                        <input class="form-control" type="number" step="0.5" @bind="_c1OrigStitch" placeholder="예: 20" />
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label" style="font-size:0.78rem;">원작 단 게이지 (10cm당)</label>
                        <input class="form-control" type="number" step="0.5" @bind="_c1OrigRow" placeholder="예: 28" />
                    </div>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:10px;">
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label" style="font-size:0.78rem;">도안 콧수</label>
                        <input class="form-control" type="number" step="1" @bind="_c1PatStitch" placeholder="예: 120" />
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label" style="font-size:0.78rem;">도안 단수</label>
                        <input class="form-control" type="number" step="1" @bind="_c1PatRow" placeholder="예: 80" />
                    </div>
                </div>
                @if (Calc1Result != null)
                {
                    <div style="display:flex; gap:8px; margin-top:12px;">
                        @if (Calc1Result.Value.s.HasValue)
                        {
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:10px; text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:4px;">수정 콧수</div>
                                <div style="font-size:1.3rem; font-weight:700; color:#4e3290;">@Calc1Result.Value.s.Value 코</div>
                            </div>
                        }
                        @if (Calc1Result.Value.r.HasValue)
                        {
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:10px; text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:4px;">수정 단수</div>
                                <div style="font-size:1.3rem; font-weight:700; color:#4e3290;">@Calc1Result.Value.r.Value 단</div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div style="background:var(--ivory-mid); border-radius:var(--radius-sm); padding:14px; margin-bottom:16px;">
                <div style="font-size:0.88rem; font-weight:600; color:var(--theme-active); margin-bottom:8px;">② 길이 예측 계산기</div>
                <p style="font-size:0.78rem; color:var(--text-mid); margin-bottom:12px;">도안 콧수/단수 → 내 게이지로 뜨면 나오는 실제 길이</p>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label" style="font-size:0.78rem;">도안 콧수</label>
                        <input class="form-control" type="number" step="1" @bind="_c2Stitch" placeholder="예: 120" />
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label" style="font-size:0.78rem;">도안 단수</label>
                        <input class="form-control" type="number" step="1" @bind="_c2Row" placeholder="예: 80" />
                    </div>
                </div>
                @if (Calc2Result != null)
                {
                    <div style="display:flex; gap:8px; margin-top:12px;">
                        @if (Calc2Result.Value.w.HasValue)
                        {
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:10px; text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:4px;">예상 가로 길이</div>
                                <div style="font-size:1.3rem; font-weight:700; color:#1a5276;">@Calc2Result.Value.w.Value cm</div>
                            </div>
                        }
                        @if (Calc2Result.Value.h.HasValue)
                        {
                            <div style="flex:1; background:var(--ivory-dark); border-radius:var(--radius-sm); padding:10px; text-align:center;">
                                <div style="font-size:0.72rem; color:var(--text-light); margin-bottom:4px;">예상 세로 길이</div>
                                <div style="font-size:1.3rem; font-weight:700; color:#1a5276;">@Calc2Result.Value.h.Value cm</div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseCalcModal">닫기</button>
            </div>
        </div>
    </div>
}

<!-- 삭제 확인 모달 -->
@if (_showConfirm)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.32);display:flex;align-items:center;justify-content:center;z-index:9999;padding:20px;box-sizing:border-box;">
        <div style="background:var(--white);border-radius:16px;max-width:320px;width:100%;padding:24px 20px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,0.18);" @onclick:stopPropagation="true">
            <div style="margin-bottom:12px;display:flex;justify-content:center;"><img src="icons/trash.svg" class="icon-line" style="width:32px;height:32px;" /></div>
            <div style="font-size:1rem; font-weight:600; margin-bottom:8px; color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem; color:var(--text-mid); margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => _showConfirm = false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _saving = false;
    bool _showConfirm = false;
    string _confirmMsg = "";
    Func<Task>? _confirmAction;

    void Confirm(string msg, Func<Task> action)
    {
        _confirmMsg    = msg;
        _confirmAction = action;
        _showConfirm   = true;
    }

    async Task ExecuteConfirm()
    {
        _showConfirm = false;
        if (_confirmAction != null)
            await _confirmAction();
        _confirmAction = null;
    }

    bool _loading     = true;
    bool _showModal   = false;
    bool _showCalcModal = false;
    Swatch? _calcSwatch;
    List<Swatch>      _swatches = new();
    List<Yarn>        _yarns    = new();
    List<KnitProject> _projects = new();
    Swatch _editing = new();

    // 필터
    string _filterProject = "";
    string _swatchSort = "created_desc";
    string _filterStitch  = "";
    string _filterNeedle  = "";

    // 뜨개방법 콤보
    string _stitchSelect = "메리야스";

    // 바늘 필터 옵션 (실제 데이터 기반)
    IEnumerable<string> NeedleOptions => _swatches
        .Where(s => s.NeedleSizeMm > 0)
        .Select(s => s.NeedleSizeMm.ToString("G"))
        .Distinct()
        .OrderBy(x => double.Parse(x));

    // 필터 적용
    IEnumerable<Swatch> FilteredSwatches => _swatches.Where(s =>
    {
        if (_filterProject == "linked" && s.ProjectId == null) return false;
        if (_filterProject == "unlinked" && s.ProjectId != null) return false;
        if (_filterStitch != "" && !s.Stitch.Contains(_filterStitch)) return false;
        if (_filterNeedle != "" && s.NeedleSizeMm.ToString("G") != _filterNeedle) return false;
        return true;
    });

    IEnumerable<Swatch> SortedSwatches => _swatchSort switch
    {
        "name_asc"   => FilteredSwatches.OrderBy(s => s.Name),
        "needle_asc" => FilteredSwatches.OrderBy(s => s.NeedleSizeMm),
        _            => FilteredSwatches.OrderByDescending(s => s.CreatedAt),
    };

    // 독립 계산기 모달 입력값
    double _c1OrigStitch = 0;
    double _c1OrigRow    = 0;
    int    _c1PatStitch  = 0;
    int    _c1PatRow     = 0;
    int    _c2Stitch     = 0;
    int    _c2Row        = 0;

    // 변화율 계산
    // - 코/단 기준: 같은 크기에서 코수 감소 = 편물 커짐(+) → 부호 반전
    // - 길이 기준: 길이 증가 = 편물 커짐(+) → 그대로
    double? CalcRate(double preStitch, double postStitch, double preCm, double postCm)
    {
        if (preStitch > 0 && postStitch > 0 && preStitch != postStitch)
            return Math.Round(-(postStitch - preStitch) / preStitch * 100, 1);
        if (preCm > 0 && postCm > 0 && preCm != postCm)
            return Math.Round((postCm - preCm) / preCm * 100, 1);
        return null;
    }

    double CalcSwatchStitchGauge(Swatch s)
    {
        if (s.PostWashStitches > 0 && s.PostWashWidthCm > 0) return s.PostWashStitches / s.PostWashWidthCm * 10;
        if (s.PreWashStitches  > 0 && s.PreWashWidthCm  > 0) return s.PreWashStitches  / s.PreWashWidthCm  * 10;
        return 0;
    }

    double CalcSwatchRowGauge(Swatch s)
    {
        if (s.PostWashRows > 0 && s.PostWashHeightCm > 0) return s.PostWashRows / s.PostWashHeightCm * 10;
        if (s.PreWashRows  > 0 && s.PreWashHeightCm  > 0) return s.PreWashRows  / s.PreWashHeightCm  * 10;
        return 0;
    }

    (int? s, int? r)? Calc1Result
    {
        get
        {
            if (_calcSwatch == null) return null;
            var sg = CalcSwatchStitchGauge(_calcSwatch);
            var rg = CalcSwatchRowGauge(_calcSwatch);
            int? s = null, r = null;
            if (_c1OrigStitch > 0 && _c1PatStitch > 0 && sg > 0)
                s = (int)Math.Round(_c1PatStitch * sg / _c1OrigStitch);
            if (_c1OrigRow > 0 && _c1PatRow > 0 && rg > 0)
                r = (int)Math.Round(_c1PatRow * rg / _c1OrigRow);
            if (s.HasValue || r.HasValue) return (s, r);
            return null;
        }
    }

    (double? w, double? h)? Calc2Result
    {
        get
        {
            if (_calcSwatch == null) return null;
            var sg = CalcSwatchStitchGauge(_calcSwatch);
            var rg = CalcSwatchRowGauge(_calcSwatch);
            double? w = null, h = null;
            if (_c2Stitch > 0 && sg > 0) w = Math.Round(_c2Stitch / sg * 10, 1);
            if (_c2Row    > 0 && rg > 0) h = Math.Round(_c2Row    / rg * 10, 1);
            if (w.HasValue || h.HasValue) return (w, h);
            return null;
        }
    }

    void OpenCalcModal(Swatch s)
    {
        _calcSwatch = s;
        _c1OrigStitch = 0; _c1OrigRow = 0;
        _c1PatStitch  = 0; _c1PatRow  = 0;
        _c2Stitch     = 0; _c2Row     = 0;
        _showCalcModal = true;
    }

    void CloseCalcModal() => _showCalcModal = false;

    protected override async Task OnInitializedAsync()
    {
        _swatches = await Storage.GetSwatchesAsync();
        _yarns    = await Storage.GetYarnsAsync();
        _projects = await Storage.GetProjectsAsync();
        _filterProject = await JS.InvokeAsync<string?>("localStorage.getItem", "sw_fp") ?? "";
        _filterStitch  = await JS.InvokeAsync<string?>("localStorage.getItem", "sw_fs") ?? "";
        _filterNeedle  = await JS.InvokeAsync<string?>("localStorage.getItem", "sw_fn") ?? "";
        _swatchSort    = await JS.InvokeAsync<string?>("localStorage.getItem", "sw_sort") ?? "created_desc";
        _loading  = false;
    }

    void OpenAddModal()
    {
        _editing = new Swatch();
        _stitchSelect = "메리야스";
        _showModal = true;
    }

    void OnYarnChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        _editing.YarnId = !string.IsNullOrEmpty(val) ? Guid.Parse(val) : null;
    }

    void OnProjectChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        _editing.ProjectId = !string.IsNullOrEmpty(val) ? Guid.Parse(val) : null;
    }

    void OpenEditModal(Swatch s)
    {
        _editing = new Swatch
        {
            Id = s.Id, Name = s.Name, YarnId = s.YarnId, YarnNameDirect = s.YarnNameDirect,
            ProjectId = s.ProjectId, NeedleSizeMm = s.NeedleSizeMm, Stitch = s.Stitch,
            PreWashStitches = s.PreWashStitches, PreWashRows = s.PreWashRows,
            PreWashWidthCm = s.PreWashWidthCm, PreWashHeightCm = s.PreWashHeightCm,
            PostWashStitches = s.PostWashStitches, PostWashRows = s.PostWashRows,
            PostWashWidthCm = s.PostWashWidthCm, PostWashHeightCm = s.PostWashHeightCm,
            Memo = s.Memo, PhotoBase64 = s.PhotoBase64, CreatedAt = s.CreatedAt
        };
        var presets = new[] { "메리야스", "무늬", "가터", "고무단" };
        _stitchSelect = presets.Contains(s.Stitch) ? s.Stitch : "직접입력";
        _showModal = true;
    }

    void CloseModal() => _showModal = false;

    void OnFilterProjectChanged(ChangeEventArgs e) => _filterProject = e.Value?.ToString() ?? "";
    void OnFilterStitchChanged(ChangeEventArgs e)  => _filterStitch  = e.Value?.ToString() ?? "";
    async Task OnFilterNeedleChanged(ChangeEventArgs e) { _filterNeedle = e.Value?.ToString() ?? ""; await JS.InvokeVoidAsync("localStorage.setItem", "sw_fn", _filterNeedle); }
    async Task SetFilterProject(string val)
    {
        _filterProject = val;
        await JS.InvokeVoidAsync("localStorage.setItem", "sw_fp", val);
    }

    async Task SetFilterStitch(string val)
    {
        _filterStitch = val;
        await JS.InvokeVoidAsync("localStorage.setItem", "sw_fs", val);
    }

    async Task SetSwatchSort(string val)
    {
        _swatchSort = val;
        await JS.InvokeVoidAsync("localStorage.setItem", "sw_sort", val);
    }

    async Task ResetFilters() { _filterProject = ""; _filterStitch = ""; _filterNeedle = ""; await JS.InvokeVoidAsync("localStorage.removeItem", "sw_fp"); await JS.InvokeVoidAsync("localStorage.removeItem", "sw_fs"); await JS.InvokeVoidAsync("localStorage.removeItem", "sw_fn"); }
    void ClearPhoto() => _editing.PhotoBase64 = "";

    void OnStitchSelectChanged(ChangeEventArgs e)
    {
        _stitchSelect = e.Value?.ToString() ?? "메리야스";
        if (_stitchSelect != "직접입력")
            _editing.Stitch = _stitchSelect;
    }

    async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        var maxSize = 5 * 1024 * 1024; // 5MB
        using var stream = file.OpenReadStream(maxSize);
        using var ms = new System.IO.MemoryStream();
        await stream.CopyToAsync(ms);
        var bytes = ms.ToArray();
        var base64 = Convert.ToBase64String(bytes);
        _editing.PhotoBase64 = $"data:{file.ContentType};base64,{base64}";
    }

    async Task SaveSwatch()
    {
        _saving = true; StateHasChanged();
        if (_editing.Id == Guid.Empty) _editing.Id = Guid.NewGuid();
        await Storage.SaveSwatchAsync(_editing);
        _swatches = await Storage.GetSwatchesAsync();
        _showModal = false;
        _saving = false;
        await JS.InvokeVoidAsync("showToast", "저장됐어요");
        }

    async Task DeleteSwatch(Guid id)
    {
        await Storage.DeleteSwatchAsync(id);
        _swatches = await Storage.GetSwatchesAsync();
    }
}