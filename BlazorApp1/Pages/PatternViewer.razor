@page "/pattern-viewer/{ProjectId:guid}"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<!--
  PC:  사이드바(220px) 오른쪽 main-content 안에서 전체 차지
  모바일: 사이드바 없으므로 position:fixed로 전체화면
-->
<div class="pv-root"
     @onmousemove="OnGlobalMouseMove"
     @onmouseup="OnGlobalMouseUp"
     @ontouchmove="OnGlobalTouchMove"
     @ontouchend="OnGlobalTouchEnd">

    <!-- PDF 스크롤 영역 (꽉 차게) -->
    <div id="scroll-container" class="pv-scroll">
        <div id="pdf-wrapper" style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:8px 0;">
            @if (_pdfLoaded)
            {
                @for (int pg = 1; pg <= _totalPages; pg++)
                {
                    var pageNum = pg;
                    <div class="page-container" id="page-container-@pageNum" style="position:relative;display:inline-block;">
                        @if (_isImageMode)
                        {
                            <img id="pdf-canvas-@pageNum" src="@_imageDataUrl"
                                 style="display:block;width:@(_imageOrigW * _zoom)px;height:@(_imageOrigH * _zoom)px;" />
                        }
                        else
                        {
                            <canvas id="pdf-canvas-@pageNum" style="display:block;"></canvas>
                        }
                        <canvas id="anno-canvas-@pageNum" style="position:absolute;top:0;left:0;z-index:10;cursor:@GetCursor();"
                                @onclick="e => OnAnnoCanvasClick(e, pageNum)"></canvas>

                        @* ── 행 높이 수동 지정: 두 선 드래그 ── *@
                        @if (_tool == "rowheightdraw" && _rowDrawPage == pageNum)
                        {
                            @* 선 A *@
                            <div id="rowdraw-line-a-@pageNum"
                                 style="position:absolute;left:0;top:@(_rowLineAY)px;width:100%;height:12px;
                                        margin-top:-6px;cursor:ns-resize;z-index:32;touch-action:none;
                                        display:flex;align-items:center;">
                                <div style="width:100%;height:2px;background:rgba(30,120,255,0.9);pointer-events:none;"></div>
                            </div>
                            @* 선 B *@
                            <div id="rowdraw-line-b-@pageNum"
                                 style="position:absolute;left:0;top:@(_rowLineBY)px;width:100%;height:12px;
                                        margin-top:-6px;cursor:ns-resize;z-index:32;touch-action:none;
                                        display:flex;align-items:center;">
                                <div style="width:100%;height:2px;background:rgba(255,80,30,0.9);pointer-events:none;"></div>
                            </div>
                            @* 두 선 사이 영역 + 거리 표시 *@
                            <div style="position:absolute;left:0;top:@(Math.Min(_rowLineAY, _rowLineBY))px;width:100%;height:@(Math.Abs(_rowLineAY - _rowLineBY))px;
                                        background:rgba(80,160,255,0.12);pointer-events:none;z-index:31;">
                                @if (Math.Abs(_rowLineAY - _rowLineBY) > 14)
                                {
                                    <span style="position:absolute;right:8px;top:50%;transform:translateY(-50%);
                                                 font-size:11px;font-weight:700;color:rgba(30,80,200,0.95);
                                                 background:rgba(255,255,255,0.85);border-radius:4px;padding:2px 5px;">
                                        @($"{Math.Abs(_rowLineAY - _rowLineBY) / _zoom:F1}px")
                                    </span>
                                }
                            </div>
                        }
                        @if (_showPreviewLines && _detectPage == pageNum)
                        {
                            foreach (var lineY in _previewLineYs)
                            {
                                <div style="position:absolute;left:0;top:@(lineY * _zoom)px;
                                            width:@(_pageWidth * _zoom)px;height:1px;
                                            background:@_gridLineColor;
                                            pointer-events:none;z-index:25;"></div>
                            }
                        }

                        @* ── 행 마커 ── *@
                        @foreach (var marker in _rowMarkers.Where(m => m.Page == pageNum))
                        {
                            var markerY   = marker.Y * _zoom;
                            var markerH   = Math.Max(marker.RowHeight * _zoom, 4);
                            var markerW   = marker.PageWidth * _zoom;
                            var alpha     = marker.IsCurrent ? "0.45" : "0.30";
                            var rgb       = HexToRgb(marker.Color);
                            var darkRgb   = DarkenRgb(marker.Color);
                            var borderH   = Math.Max(2, markerH * 0.12);
                            <div style="position:absolute;left:0;top:@(markerY)px;
                                        width:@(markerW)px;height:@(markerH)px;
                                        background:rgba(@rgb,@alpha);
                                        @(marker.IsCurrent
                                            ? $"box-shadow:0 -{borderH}px 0 0 rgba({darkRgb},0.8),0 {borderH}px 0 0 rgba({darkRgb},0.8);"
                                            : "")
                                        pointer-events:none;z-index:15;
                                        transition:top 0.15s ease,height 0.15s ease;">
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- ── 프로젝트명 / 파일명 표시줄 ── -->
    @if (_project != null)
    {
        <div class="pv-title-bar">
            <span class="pv-title-project">@_project.Title</span>
            @if (!string.IsNullOrEmpty(_project.PatternFileName))
            {
                <span class="pv-title-sep">·</span>
                <span class="pv-title-file">@_project.PatternFileName</span>
            }
        </div>
    }

    <!-- ── 상단 오버레이 툴바 ── -->
    <!-- 구조: [나가기 + 타이머] [가운데: 페이지/줌] [도안 불러오기] -->
    <div class="top-bar">
        <!-- 왼쪽: 나가기 + 타이머 -->
        <div class="tb-left">
            <button class="tb-btn" @onclick="GoBack">←</button>
            @if (_project is not null)
            {
                <div class="tb-div"></div>
                <span style="font-size:11px;opacity:0.4;">⏱</span>
                <span class="tb-txt" style="font-variant-numeric:tabular-nums;letter-spacing:0.3px;">@_timerDisplay</span>
                @if (_activeSession == null)
                {
                    <button class="tb-icon-btn" @onclick="StartSession">▶</button>
                }
                else
                {
                    <button class="tb-icon-btn" @onclick="EndSession">⏸</button>
                }
            }
        </div>

        <!-- 가운데: 페이지수만 -->
        <div class="tb-center">
            @if (_totalPages > 0)
            {
                <span class="tb-txt">@_currentPage / @_totalPages</span>
            }
        </div>

        <!-- 오른쪽: 줌 + 도안 불러오기 -->
        <div class="tb-right">
            @if (_totalPages > 0)
            {
                <div class="tb-zoom">
                    <button class="tb-zoom-btn" @onclick="ZoomOut">−</button>
                    <span class="tb-txt" style="min-width:36px;text-align:center;">@((int)(_zoom*100))%</span>
                    <button class="tb-zoom-btn" @onclick="ZoomIn">+</button>
                </div>
                <div class="tb-div"></div>
            }
            <span class="tb-label" style="cursor:pointer;" @onclick="OnLoadPatternClick">
                📄
            </span>
            <InputFile id="pdf-file-input" OnChange="OnPdfSelected" accept="application/pdf,image/png,image/jpeg,image/webp" style="display:none;" />
        </div>
    </div>

    <!-- ── 필기 도구 플로팅 위젯 (좌측 상단, 툴바 아래) ── -->
    <div class="draw-wrap">
        <button class="draw-fab" id="draw-fab-btn" @onclick="ToggleDrawMode" title="필기 모드">
            <img src="@(_drawMode ? "icons/draw-mode-on.svg" : "icons/draw-mode-off.svg")" style="width:22px;height:22px;" />
        </button>
        <div class="draw-panel" id="draw-panel-div">
            <div class="draw-panel-inner">
                <!-- 행1: 도구 선택 (펜 → 형광펜 → 지우개 → 행감지) -->
                <div class="dp-row">
                    <button class="dp-btn @(_tool=="pen"?"dp-on":"")" @onclick='()=>SetTool("pen")' title="펜">
                        <img src="icons/pen.svg" style="width:20px;height:20px;" />
                    </button>
                    <button class="dp-btn @(_tool=="highlighter"?"dp-on":"")" @onclick='()=>SetTool("highlighter")' title="형광펜">
                        <img src="icons/highlighter.svg" style="width:20px;height:20px;" />
                    </button>
                    <button class="dp-btn @(_tool=="eraser"?"dp-on":"")" @onclick='()=>SetTool("eraser")' title="지우개">
                        <img src="icons/eraser.svg" style="width:20px;height:20px;" />
                    </button>
                    <button class="dp-btn @(_tool=="rowmarker"?"dp-on":"")" @onclick='()=>SetTool("rowmarker")' title="행 감지">
                        <img src="icons/row-detect.svg" style="width:20px;height:20px;" />
                    </button>
                </div>

                @if (_tool == "rowmarker" || _tool == "rowheightdraw")
                {
                    <div class="dp-sep"></div>
                    @* 색상: 행마커 / 감지선 *@
                    <div class="dp-row" style="justify-content:center;gap:4px;">
                        <input type="color" value="@_rowMarkerColor" @oninput="OnRowMarkerColorChange" title="행 마커 색상"
                               style="width:28px;height:28px;border:none;border-radius:50%;padding:2px;cursor:pointer;background:transparent;" />
                        <input type="color" value="@_gridLineColor" @oninput="OnGridLineColorChange" title="감지선 색상"
                               style="width:28px;height:28px;border:none;border-radius:50%;padding:2px;cursor:pointer;background:transparent;" />
                    </div>
                    <div class="dp-sep"></div>
                    @* 행 높이 감지 버튼 *@
                    <div class="dp-row" style="justify-content:center;gap:3px;">
                        <button class="dp-btn" title="자동 행 감지" @onclick="DetectRowHeight" style="width:28px;height:28px;">
                            <img src="icons/search.svg" style="width:18px;height:18px;" />
                        </button>
                        <button class="dp-btn @(_tool=="rowheightdraw"?"dp-on":"")" title="직접 한 행 높이 지정" @onclick="StartRowHeightDraw" style="width:28px;height:28px;">
                            <img src="icons/row-height.svg" style="width:18px;height:18px;" />
                        </button>
                    </div>
                    @* 두 선 지정 모드: 적용 버튼 *@
                    @if (_tool == "rowheightdraw")
                    {
                        <div class="dp-row" style="justify-content:center;margin-top:4px;">
                            <button class="dp-btn" style="width:52px;height:26px;font-size:11px;font-weight:700;background:#2979ff;color:#fff;border-radius:6px;"
                                    @onclick="ConfirmRowHeightLines">✓ 적용</button>
                        </div>
                        <div class="dp-val" style="font-size:9px;text-align:center;margin-top:2px;">
                            @($"{Math.Abs(_rowLineAY - _rowLineBY) / _zoom:F1}px")
                        </div>
                    }
                    @* 감지 결과 피드백 *@
                    @if (_detectPage > 0)
                    {
                        @if (_detectedRowH > 0)
                        {
                            <div class="dp-val" style="font-size:9px;text-align:center;color:#2a7a2a;margin-top:2px;">
                                @($"{_detectedRowH * _zoom:F0}px")
                            </div>
                            <div class="dp-val" style="font-size:8px;text-align:center;">
                                @($"{_detectedLineCount}줄")
                            </div>
                            @if (_showPreviewLines)
                            {
                                <div class="dp-row" style="justify-content:center;margin-top:2px;">
                                    <button class="dp-btn dp-confirm-btn" style="font-size:10px;width:36px;height:22px;"
                                            @onclick="ConfirmDetect" title="확인">✓</button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="dp-val" style="font-size:8px;text-align:center;color:#c05050;margin-top:2px;">감지 실패</div>
                        }
                    }
                    @* 수동 행 높이 입력 *@
                    <div class="dp-row" style="justify-content:center;margin-top:2px;">
                        <input type="number" min="2" max="500" value="@((int)(_detectedRowH * _zoom > 0 ? _detectedRowH * _zoom : 20))"
                               @onchange="OnRowHeightManualChange"
                               style="width:36px;font-size:10px;text-align:center;padding:2px;border:1px solid #ccc;border-radius:4px;" />
                    </div>
                    <div class="dp-sep"></div>
                    @* + 버튼 (위로 이동) *@
                    @if (_rowMarkers.Any(m => m.IsCurrent))
                    {
                        <div class="dp-row" style="justify-content:center;gap:4px;">
                            <button class="dp-btn" title="다음 행으로" @onclick="MoveRowMarkerUp" style="width:28px;height:28px;">
                                <img src="icons/Plus.svg" style="width:20px;height:20px;" />
                            </button>
                            <button class="dp-btn" title="되돌리기" @onclick="UndoRowMarker" style="width:28px;height:28px;">
                                <img src="icons/Undo.svg" style="width:18px;height:18px;" />
                            </button>
                        </div>
                    }
                    else if (_rowMarkers.Any())
                    {
                        <div class="dp-row" style="justify-content:center;">
                            <button class="dp-btn" title="되돌리기" @onclick="UndoRowMarker" style="width:28px;height:28px;">
                                <img src="icons/Undo.svg" style="width:18px;height:18px;" />
                            </button>
                        </div>
                    }
                    @* 전체 삭제 *@
                    @if (_rowMarkers.Any())
                    {
                        <div class="dp-sep"></div>
                        <div class="dp-row" style="justify-content:center;">
                            <button class="dp-btn" title="행 마커 전체 삭제" @onclick="ClearRowMarkers" style="width:28px;height:28px;">
                                <img src="icons/Delete.svg" style="width:20px;height:20px;" />
                            </button>
                        </div>
                    }
                }

                @if (_tool == "pen" || _tool == "eraser" || _tool == "highlighter")
                {
                    <div class="dp-sep"></div>

                    @if (_tool == "pen" || _tool == "highlighter")
                    {
                        <!-- 색상 -->
                        <div class="dp-row" style="justify-content:center;">
                            <input type="color" value="@ActiveColor" @oninput="OnColorChange"
                                   @key="@($"color-{_tool}")"
                                   style="width:28px;height:28px;border:none;border-radius:50%;padding:2px;cursor:pointer;background:transparent;" />
                        </div>
                    }

                    <!-- 굵기 팝오버 버튼 -->
                    <button id="dp-size-btn" class="dp-btn @(_showSizePopup ? "dp-on" : "")"
                            title="굵기"
                            @onclick="OpenSizePopup">
                        <span style="font-size:13px;font-weight:700;">@ActiveSize</span>
                    </button>

                    @if (_tool == "pen")
                    {
                        <div class="dp-sep"></div>
                        <!-- 투명도 팝오버 버튼 -->
                        <button id="dp-opacity-btn" class="dp-btn @(_showOpacityPopup ? "dp-on" : "")"
                                title="투명도"
                                @onclick="OpenOpacityPopup">
                            <span style="font-size:9px;font-weight:700;line-height:1.1;text-align:center;">@ActiveOpacity<br/>%</span>
                        </button>
                    }

                    <div class="dp-sep"></div>
                    <!-- 되돌리기 -->
                    <div class="dp-row" style="justify-content:center;">
                        <button class="dp-btn" @onclick="UndoLastPath" title="되돌리기">
                            <img src="icons/Undo.svg" style="width:18px;height:18px;" />
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── 카운터 플로팅 위젯 (드래그 가능) ── -->
    @if (_project is not null && _project.Counters.Any())
    {
        @if (_showCounterWidget)
        {
            <div class="cw-wrap @(_cwX < 0 ? "cw-default-pos" : "")"
                 style="@(_cwX >= 0 ? $"position:fixed;left:{_cwX}px;top:{_cwY}px;" : "")z-index:600;touch-action:none;cursor:grab;"
                 @onmousedown="CwDragStart">
                <div class="cw-inner" @onmousedown:stopPropagation="true" @ontouchstart:stopPropagation="true">
                    <!-- 드래그 핸들 -->
                    <div class="cw-header"
                         style="cursor:grab;"
                         @onmousedown="CwDragStart"
                         @ontouchstart="CwTouchStart">
                        <span style="font-size:11px;font-weight:700;color:#444;">🧶 카운터</span>
                        <button class="cw-close" @onclick="()=>_showCounterWidget=false" @onmousedown:stopPropagation="true">✕</button>
                    </div>
                    @{var c = _project.Counters[_activeCounterIndex];}
                    <div class="cw-nav">
                        <button class="cw-nav-btn" @onclick="PrevCounter" disabled="@(_project.Counters.Count<=1)">‹</button>
                        <div style="text-align:center;flex:1;">
                            <div style="font-size:12px;color:#333;font-weight:600;">@c.Label</div>
                            <div style="font-size:10px;color:#aaa;">@(_activeCounterIndex+1)/@_project.Counters.Count</div>
                        </div>
                        <button class="cw-nav-btn" @onclick="NextCounter" disabled="@(_project.Counters.Count<=1)">›</button>
                    </div>
                    <div class="cw-controls">
                        <button class="cw-btn minus" @onclick="()=>DecrementCounter(c)">−</button>
                        <span class="cw-val">@c.Value</span>
                        <button class="cw-btn plus"  @onclick="()=>IncrementCounter(c)">+</button>
                    </div>
                    @if (c.LastUpdatedAt.HasValue)
                    {
                        <div style="font-size:10px;color:#bbb;text-align:center;margin-top:4px;">
                            @FormatLastUpdated(c.LastUpdatedAt.Value)
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <button class="cw-fab" @onclick="()=>_showCounterWidget=true">🧶</button>
        }
    }
    <!-- ── (도형 기능 제거됨) ── -->
</div>

<!-- ── 필기툴 팝오버: pv-root 완전 바깥, position:fixed로 독립 렌더링 ── -->
@if (_drawMode && _showSizePopup && (_tool == "pen" || _tool == "eraser" || _tool == "highlighter"))
{
    <div style="position:fixed;top:@(_sizePopoverTop)px;left:@(_popoverLeft)px;z-index:9000;
                background:rgba(255,255,255,0.97);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
                border:1.5px solid rgba(0,0,0,0.1);border-radius:14px;padding:12px 14px;
                box-shadow:0 4px 20px rgba(0,0,0,0.18);white-space:nowrap;"
         @onclick:stopPropagation="true" @onmousedown:stopPropagation="true" @ontouchstart:stopPropagation="true">
        <div style="font-size:13px;font-weight:700;color:#333;margin-bottom:10px;text-align:center;">굵기</div>
        <div style="display:flex;align-items:center;gap:8px;">
            <button class="dp-size-btn" @onclick="SizeDown" @onclick:stopPropagation="true">−</button>
            <input type="range" min="1" max="40" step="1" value="@ActiveSize"
                   @oninput="OnSizeChange"
                   style="flex:1;min-width:130px;cursor:pointer;accent-color:#555;" />
            <button class="dp-size-btn" @onclick="SizeUp" @onclick:stopPropagation="true">+</button>
        </div>
        <div style="font-size:11px;font-weight:600;color:#555;text-align:center;margin-top:6px;">@ActiveSize</div>
    </div>
}
@if (_drawMode && _showOpacityPopup && _tool == "pen")
{
    <div style="position:fixed;top:@(_opacityPopoverTop)px;left:@(_popoverLeft)px;z-index:9000;
                background:rgba(255,255,255,0.97);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
                border:1.5px solid rgba(0,0,0,0.1);border-radius:14px;padding:12px 14px;
                box-shadow:0 4px 20px rgba(0,0,0,0.18);white-space:nowrap;"
         @onclick:stopPropagation="true" @onmousedown:stopPropagation="true" @ontouchstart:stopPropagation="true">
        <div style="font-size:13px;font-weight:700;color:#333;margin-bottom:10px;text-align:center;">투명도</div>
        <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:10px;color:#999;white-space:nowrap;">5%</span>
            <input type="range" min="5" max="100" step="5" value="@ActiveOpacity"
                   @oninput="OnOpacityChange"
                   style="flex:1;min-width:130px;cursor:pointer;accent-color:#555;" />
            <span style="font-size:10px;color:#999;white-space:nowrap;">100%</span>
        </div>
        <div style="font-size:11px;font-weight:600;color:#555;text-align:center;margin-top:6px;">@ActiveOpacity %</div>
    </div>
}

<style>
    /* ── 뷰어 루트: PC는 main-content 안, 모바일은 fixed fullscreen ── */
    .pv-root {
        /* PC: 사이드바 오른쪽 main-content 안에서 전체 높이 차지 */
        position: relative;
        width: 100%;
        height: 100vh;
        height: 100dvh; /* 모바일 주소창 대응 */
        overflow: hidden;
        background: #aaa;
    }
    /* 태블릿+모바일(1024px 이하): 사이드바 없으므로 fixed fullscreen */
    @@media (max-width: 1024px) {
        .pv-root {
            position: fixed;
            inset: 0;
            z-index: 50;
            height: 100dvh;
        }
    }

    .pv-scroll {
        position: absolute;
        inset: 0;
        overflow: auto;
        display: flex;
        justify-content: center;
    }

    /* ── 프로젝트명/파일명 표시줄 ── */
    .pv-title-bar {
        position: absolute;
        top: 0; left: 0; right: 0;
        background: rgba(255,255,255,0.72);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-bottom: 1px solid rgba(0,0,0,0.06);
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 6px;
        z-index: 210;
        height: 28px;
        box-sizing: border-box;
    }
    .pv-title-project {
        font-size: 11px;
        font-weight: 700;
        color: #333;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 200px;
    }
    .pv-title-sep { font-size: 11px; color: #aaa; flex-shrink: 0; }
    .pv-title-file {
        font-size: 10px;
        color: #888;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
