    async Task OnGlobalMouseMove(MouseEventArgs e)
    {
        // 카운터 위젯 드래그
        if(_cwDragging){_cwX=e.ClientX-_cwOffX;_cwY=e.ClientY-_cwOffY;StateHasChanged();return;}
        if(_isDrawingRuler||_draggingRuler!=null||_resizingRuler!=null)
        {
            var pg=_draggingRuler?.Page??_resizingRuler?.Page??_rulerPage;
            var rect=await JS.InvokeAsync<double[]>("patternViewer.getRect",pg);
            double curX=e.ClientX-rect[0];double curY=e.ClientY-rect[1];
            if(_isDrawingRuler){_previewW=curX-_rulerStartX;_previewH=curY-_rulerStartY;}
            else if(_draggingRuler!=null){_draggingRuler.X=(curX-_dragOffsetX)/_zoom;_draggingRuler.Y=(curY-_dragOffsetY)/_zoom;}
            else if(_resizingRuler!=null){_resizingRuler.Width=Math.Max(30/_zoom,curX/_zoom-_resizingRuler.X);_resizingRuler.Height=Math.Max(10/_zoom,curY/_zoom-_resizingRuler.Y);}
            StateHasChanged();
        }
    }
    async Task OnGlobalMouseUp(MouseEventArgs e)
    {
        _cwDragging=false;
        if(_isDrawingRuler&&Math.Abs(_previewW)>5){var r=new RulerOverlay{X=(_previewW>0?_rulerStartX:_rulerStartX+_previewW)/_zoom,Y=(_previewH>0?_rulerStartY:_rulerStartY+_previewH)/_zoom,Width=Math.Abs(_previewW)/_zoom,Height=Math.Abs(_previewH)/_zoom,Page=_rulerPage};_rulers.Add(r);_selectedRuler=r;_=SaveRulersAsync();}
        bool _hadRulerAction = _isDrawingRuler || _draggingRuler!=null || _resizingRuler!=null;
        _isDrawingRuler=false;_draggingRuler=null;_resizingRuler=null;
        if(_isDrawing&&_pdfLoaded&&(_tool=="pen"||_tool=="eraser"||_tool=="highlighter"))await JS.InvokeVoidAsync("patternViewer.endDraw");
        _isDrawing=false;
        if(_hadRulerAction)_=SaveRulersAsync();
        StateHasChanged();
    }
