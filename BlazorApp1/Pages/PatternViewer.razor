    async Task OnPdfSelected(InputFileChangeEventArgs e)
    {
        try
        {
            var contentType = e.File.ContentType;
            var isImage = contentType.StartsWith("image/");

            using var stream = e.File.OpenReadStream(100 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            // ── 이미지 파일 처리 ──
            if (isImage)
            {
                // 도안 초기화
                
                _rowMarkers.Clear();
                _detectedRowH = 0;
                _zoom = 1.0;
                _currentPage = 1;

                var b64 = Convert.ToBase64String(bytes);
                _imageDataUrl = $"data:{contentType};base64,{b64}";
                _isImageMode = true;
                _totalPages = 1;
                _pdfLoaded = true;
                StateHasChanged();
                await Task.Delay(100);

                // 이미지 크기 가져오기
                var size = await JS.InvokeAsync<double[]>("patternViewer.getImageSize", "pdf-canvas-1");
                if (size != null && size.Length == 2)
                {
                    _imageOrigW = size[0];
                    _imageOrigH = size[1];
                    _pageWidth  = _imageOrigW;
                }

                // anno-canvas 크기 맞추기
                await JS.InvokeVoidAsync("patternViewer.resizeAnnoCanvas", 1, _imageOrigW * _zoom, _imageOrigH * _zoom);

                if (_project != null)
                {
                    _project.HasSavedPattern = true;
                    _project.PatternFileName = e.File.Name;
                    await SaveProject();
                }
                return;
            }

            // ── PDF 파일 처리 ──
            _isImageMode = false;

            // JS에 byte[] 직접 전달 (Base64 변환 없이 → 메모리 절약)
            using var streamRef = new DotNetStreamReference(new System.IO.MemoryStream(bytes), leaveOpen: false);
            var pages = await JS.InvokeAsync<int>("patternViewer.loadPdfBytes", streamRef);
            if (pages <= 0) return;

            // Blazor DOM에 캔버스 생성
            _totalPages = pages;
            _pdfLoaded = true;
            _currentPage = 1;
            StateHasChanged();
            await Task.Delay(100);

            // JS 렌더링
            await JS.InvokeVoidAsync("patternViewer.renderPdf");

            // IndexedDB에 저장
            if (_project != null)
            {
                var saved = await JS.InvokeAsync<bool>("patternViewer.savePdfToProject",
                    ProjectId.ToString(), e.File.Name);
                if (saved)
                {
                    _project.HasSavedPattern = true;
                    _project.PatternFileName = e.File.Name;
                    await SaveProject();
                }
            }
        }
        catch (Exception ex)
        {
            _pdfLoaded = false;
            _totalPages = 0;
            StateHasChanged();
            await JS.InvokeVoidAsync("console.error", "PDF load error: " + ex.Message);
        }
    }
    async Task ZoomIn()
    {
        _zoom = Math.Round(_zoom + 0.1, 1);
        if (_isImageMode) { await JS.InvokeVoidAsync("patternViewer.resizeAnnoCanvas", 1, _imageOrigW * _zoom, _imageOrigH * _zoom); StateHasChanged(); }
        else await RenderAllPages();
    }
    async Task ZoomOut()
    {
        _zoom = Math.Max(0.1, Math.Round(_zoom - 0.1, 1));
        if (_isImageMode) { await JS.InvokeVoidAsync("patternViewer.resizeAnnoCanvas", 1, _imageOrigW * _zoom, _imageOrigH * _zoom); StateHasChanged(); }
        else await RenderAllPages();
    }
    async Task RenderAllPages(){await JS.InvokeVoidAsync("patternViewer.renderAllPages",_zoom);StateHasChanged();}
