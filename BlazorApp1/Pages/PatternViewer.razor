@if (_showLoadWarning)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;padding:20px;">
        <div class="modal" style="max-width:360px;text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem;margin-bottom:12px;">📄</div>
            <div style="font-size:1rem;font-weight:600;margin-bottom:8px;color:var(--text-dark);">도안을 교체할까요?</div>
            <div style="font-size:0.88rem;color:var(--text-mid);margin-bottom:20px;">이미 불러온 도안이 있어요.<br/>새 파일로 교체하면 기존 필기와 도형이 모두 사라져요.</div>
            <div style="display:flex;gap:10px;justify-content:center;">
                <button class="btn btn-ghost" @onclick="()=>_showLoadWarning=false">취소</button>
                <button class="btn btn-primary" @onclick="ConfirmLoadPattern">교체</button>
            </div>
        </div>
    </div>
}

@if (_showConfirm)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;padding:20px;">
        <div class="modal" style="max-width:360px;text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem;margin-bottom:12px;">🗑️</div>
            <div style="font-size:1rem;font-weight:600;margin-bottom:8px;color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem;color:var(--text-mid);margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex;gap:10px;justify-content:center;">
                <button class="btn btn-ghost" @onclick="()=>_showConfirm=false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _showLoadWarning=false;
    bool _showConfirm=false; string _confirmMsg=""; Func<Task>? _confirmAction;
    void Confirm(string msg,Func<Task> action){_confirmMsg=msg;_confirmAction=action;_showConfirm=true;}
    async Task ExecuteConfirm(){_showConfirm=false;if(_confirmAction!=null)await _confirmAction();_confirmAction=null;}

    [Parameter] public Guid ProjectId { get; set; }
    KnitProject? _project;
    string _tool="select", _penColor="#000000";
    int _penSize=4; // 모바일 기본값 얇게
    int _penOpacity=100; // 투명도 (100=불투명, 낮을수록 형광펜)
    int _currentPage=1, _totalPages=1;
    double _zoom=1.0;
    bool _pdfLoaded=false, _isDrawing=false, _isDrawingRuler=false;
    bool _drawMode=false, _showCounterWidget=true;
    bool _suppressRender = false;
    protected override bool ShouldRender() { if (_suppressRender) { _suppressRender = false; return false; } return true; }
    int _activeCounterIndex=0;
    double _rulerStartX,_rulerStartY,_previewW,_previewH,_dragOffsetX,_dragOffsetY;
    double _rulerPopupX=200, _rulerPopupY=200; // 도형 컨트롤 팝업 위치
    int _rulerPage=1;
    List<RulerOverlay> _rulers=new();
    RulerOverlay? _draggingRuler,_resizingRuler,_selectedRuler;
    DotNetObjectReference<PatternViewer>? _dotNetRef;

    // ── 카운터 위젯 드래그 ──
    double _cwX=-1, _cwY=-1; // -1 = JS 계산 전, CSS로 우하단 고정
    bool _cwDragging=false;
    double _cwOffX=0, _cwOffY=0;

    void CwDragStart(MouseEventArgs e)
    {
        _cwDragging=true;
        _cwOffX=e.ClientX-_cwX;
        _cwOffY=e.ClientY-_cwY;
    }
    void CwTouchStart(TouchEventArgs e)
    {
        if(e.Touches.Length==0)return;
        _cwDragging=true;
        _cwOffX=e.Touches[0].ClientX-_cwX;
        _cwOffY=e.Touches[0].ClientY-_cwY;
    }

    // ── 타이머 ──
    KnitSession? _activeSession => _project?.Sessions.FirstOrDefault(s=>s.IsActive);
    string _timerDisplay="00:00:00";
    PeriodicTimer? _refreshTimer;
    void StartRefreshTimer(){StopRefreshTimer();_refreshTimer=new PeriodicTimer(TimeSpan.FromSeconds(1));_=RefreshUIAsync();}
    void StopRefreshTimer(){_refreshTimer?.Dispose();_refreshTimer=null;}
    async Task RefreshUIAsync(){try{while(_refreshTimer is not null&&await _refreshTimer.WaitForNextTickAsync()){UpdateTimerDisplay();await InvokeAsync(StateHasChanged);}}catch(OperationCanceledException){}}
    void UpdateTimerDisplay(){if(_project==null){_timerDisplay="00:00:00";return;}var a=_project.Sessions.FirstOrDefault(s=>s.IsActive);if(a==null){_timerDisplay="00:00:00";return;}var t=(int)(DateTime.Now-a.StartTime).TotalSeconds;_timerDisplay=$"{t/3600:D2}:{(t%3600)/60:D2}:{t%60:D2}";}
    async Task StartSession(){if(_project==null)return;var ex=_project.Sessions.FirstOrDefault(s=>s.IsActive);if(ex!=null)ex.EndTime=DateTime.Now;_project.Sessions.Add(new KnitSession{StartTime=DateTime.Now});await Storage.SaveProjectAsync(_project);StartRefreshTimer();StateHasChanged();}
    async Task EndSession(){if(_project==null)return;var a=_project.Sessions.FirstOrDefault(s=>s.IsActive);if(a==null)return;a.EndTime=DateTime.Now;await Storage.SaveProjectAsync(_project);StopRefreshTimer();_timerDisplay="00:00:00";StateHasChanged();}

    // ── 카운터 ──
    void PrevCounter(){if(_project==null||_project.Counters.Count==0)return;_activeCounterIndex=(_activeCounterIndex-1+_project.Counters.Count)%_project.Counters.Count;}
    void NextCounter(){if(_project==null||_project.Counters.Count==0)return;_activeCounterIndex=(_activeCounterIndex+1)%_project.Counters.Count;}
    async Task IncrementCounter(ProjectCounter c){c.Value+=c.Step;c.LastUpdatedAt=DateTime.Now;await SaveProject();StateHasChanged();}
    async Task DecrementCounter(ProjectCounter c){c.Value=Math.Max(0,c.Value-c.Step);c.LastUpdatedAt=DateTime.Now;await SaveProject();StateHasChanged();}
    async Task SaveProject(){if(_project is KnitProject p)await Storage.SaveProjectAsync(p);}

    // 도형만 즉시 저장 (디바운스 없이)
    async Task SaveRulersAsync()
    {
        if (_project == null) return;
        try
        {
            _project.ViewerRulers = System.Text.Json.JsonSerializer.Serialize(_rulers);
            _project.ViewerAnnotations = await JS.InvokeAsync<string>("patternViewer.getPaths");
            await SaveProject();
        }
        catch { }
    }

    // 필기+도형+줌+페이지 자동 저장 (디바운스)
    System.Threading.CancellationTokenSource? _saveCts;
    async Task SaveViewerStateAsync()
    {
        if (_project == null || !_pdfLoaded || _isRestoring) return;
        // 디바운스: 2초 내 연속 호출은 마지막 것만 실행
        _saveCts?.Cancel();
        _saveCts = new System.Threading.CancellationTokenSource();
        var token = _saveCts.Token;
        try
        {
            await Task.Delay(2000, token);
            if (token.IsCancellationRequested) return;

            // 필기 paths를 JS에서 가져와서 저장
            var pathsJson = await JS.InvokeAsync<string>("patternViewer.getPaths");
            _project.ViewerAnnotations = pathsJson;

            // 도형 저장
            _project.ViewerRulers = System.Text.Json.JsonSerializer.Serialize(_rulers);

            // 행 마커 저장
            _project.ViewerRowMarkers = System.Text.Json.JsonSerializer.Serialize(_rowMarkers);

            // 줌/페이지 저장
            _project.ViewerLastZoom = _zoom;
            _project.ViewerLastPage = _currentPage;

            await SaveProject();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", "SaveViewerState error: " + ex.Message);
        }
    }

    // ── 초기화 ──
    protected override async Task OnInitializedAsync()
    {
        _project=(await Storage.GetProjectsAsync()).FirstOrDefault(p=>p.Id==ProjectId);
        if(_project?.Sessions.Any(s=>s.IsActive)==true)StartRefreshTimer();
    }

    // OnAfterRenderAsync 첫 렌더 후 저장된 데이터 복원
    bool _restoredOnce = false;
    bool _isRestoring = false;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if(firstRender)
        {
            var vw = await JS.InvokeAsync<double>("eval", "window.innerWidth");
            var vh = await JS.InvokeAsync<double>("eval", "window.innerHeight");
            _cwX = Math.Max(16, vw - 196);
            _cwY = Math.Max(80, vh - 230);
            _dotNetRef=DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("patternViewer.init",_dotNetRef);
            await JS.InvokeVoidAsync("patternViewer.setTool",_penColor,_penSize,false,_tool,_penOpacity);
            StateHasChanged();
        }

        // 첫 렌더 후 저장 데이터 복원 (한 번만)
        if (!_restoredOnce && _project != null)
        {
            _restoredOnce = true;
            await RestoreSavedPatternAsync();
        }
    }

    async Task RestoreSavedPatternAsync()
    {
        if (_project == null || !_project.HasSavedPattern) return;
        _isRestoring = true;
        try
        {
            var savedFileName = await JS.InvokeAsync<string?>("patternViewer.loadPdfFromProject", ProjectId.ToString());
            if (string.IsNullOrEmpty(savedFileName)) return;

            var pages = await JS.InvokeAsync<int>("patternViewer.renderSavedPdf", ProjectId.ToString());
            if (pages <= 0) return;

            _totalPages = pages;
            _pdfLoaded = true;
            _currentPage = _project.ViewerLastPage > 0 ? _project.ViewerLastPage : 1;
            StateHasChanged();
            await Task.Delay(100);

            await JS.InvokeVoidAsync("patternViewer.renderPdf");
            await Task.Delay(500); // renderPdf 내부 ZoomToFromJS 콜백 완료 대기


            // 필기 복원은 렌더 완전히 끝난 후
            if (!string.IsNullOrEmpty(_project.ViewerAnnotations))
                await JS.InvokeVoidAsync("patternViewer.setPaths", _project.ViewerAnnotations);

            if (!string.IsNullOrEmpty(_project.ViewerRulers))
            {
                try
                {
                    var rulers = System.Text.Json.JsonSerializer.Deserialize<List<RulerOverlay>>(
                        _project.ViewerRulers,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (rulers != null) _rulers = rulers;
                }
                catch { }
            }

            if (!string.IsNullOrEmpty(_project.ViewerRowMarkers))
            {
                try
                {
                    var markers = System.Text.Json.JsonSerializer.Deserialize<List<RowMarker>>(
                        _project.ViewerRowMarkers,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (markers != null)
                    {
                        _rowMarkers = markers;
                        var first = _rowMarkers.FirstOrDefault();
                        if (first != null)
                        {
                            _detectedRowH = first.RowHeight;
                            _pageWidth    = first.PageWidth;
                            _rowMarkerColor = first.Color;
                        }
                    }
                }
                catch { }
            }

            StateHasChanged();

            // 마지막으로 보던 페이지로 스크롤
            if (_currentPage > 1)
            {
                await Task.Delay(150); // 렌더 완료 대기
                await JS.InvokeVoidAsync("patternViewer.scrollToPage", _currentPage);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", "RestoreSavedPattern error: " + ex.Message);
        }
        finally
        {
            _saveCts?.Cancel();
            _saveCts = null;
            _isRestoring = false;
        }
    }


