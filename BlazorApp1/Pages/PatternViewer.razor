    async Task ForceSaveViewerStateAsync()
    {
        if (_project == null || !_pdfLoaded) return;
        try
        {
            _saveCts?.Cancel();
            var pathsJson = await JS.InvokeAsync<string>("patternViewer.getPaths");
            _project.ViewerAnnotations = pathsJson;
            _project.ViewerRulers      = System.Text.Json.JsonSerializer.Serialize(_rulers);
            _project.ViewerRowMarkers  = System.Text.Json.JsonSerializer.Serialize(_rowMarkers);
            _project.ViewerLastZoom    = _zoom;
            _project.ViewerLastPage    = _currentPage;
            await SaveProject();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", "ForceSave error: " + ex.Message);
        }
    }

