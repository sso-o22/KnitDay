    // ── 필기 ──
    async Task ToggleDrawMode()
    {
        _drawMode = !_drawMode;
        _suppressRender = true;
        await JS.InvokeVoidAsync("patternViewer.setDrawPanelOpen", _drawMode);
        if (_drawMode)
            SetTool(_tool is "pen" or "highlighter" or "eraser" or "rowmarker" ? _tool : "pen");
        else
        {
            // 닫을 때는 _tool은 기억해두고 JS만 select로, 팝오버도 닫기
            _showSizePopup = false;
            _showOpacityPopup = false;
            _ = JS.InvokeVoidAsync("patternViewer.setTool", _penColor, _penSize, false, "select", _penOpacity);
        }
        _suppressRender = false;
    }
    void SetTool(string t)
    {
        _tool = t;
        _showSizePopup = false;
        _showOpacityPopup = false;
        var (color, size, isEraser, opacity) = t switch {
            "highlighter" => (_hlColor,    _hlSize,    false, _penOpacity),
            "eraser"      => (_penColor,   _eraserSize,true,  _penOpacity),
            _             => (_penColor,   _penSize,   false, _penOpacity)
        };
        _ = JS.InvokeVoidAsync("patternViewer.setTool", color, size, isEraser, t, opacity);
        _ = SaveViewerStateAsync();
        StateHasChanged();
    }

    void ApplyCurrentTool() => SetTool(_tool);

    // ── 팝오버 열기: 버튼 위치 읽어서 fixed 좌표 계산 ─────────────────
    async Task OpenSizePopup()
    {
        if (_showSizePopup) { _showSizePopup = false; StateHasChanged(); return; }
        _showOpacityPopup = false;
        try
        {
            var rect = await JS.InvokeAsync<double[]>("patternViewer.getBtnRect", "dp-size-btn");
            // rect: [top, right, bottom, left, width, height]
            _sizePopoverTop = rect[0];      // 버튼 top → 팝오버 top
            _popoverLeft    = rect[1] + 8;  // 버튼 right + 8px
        }
        catch { /* JS 실패 시 기본값 사용 */ }
        _showSizePopup = true;
        StateHasChanged();
    }

    async Task OpenOpacityPopup()
    {
        if (_showOpacityPopup) { _showOpacityPopup = false; StateHasChanged(); return; }
        _showSizePopup = false;
        try
        {
            var rect = await JS.InvokeAsync<double[]>("patternViewer.getBtnRect", "dp-opacity-btn");
            _opacityPopoverTop = rect[0];
            _popoverLeft       = rect[1] + 8;
        }
        catch { /* JS 실패 시 기본값 사용 */ }
        _showOpacityPopup = true;
        StateHasChanged();
    }

    async Task OnColorChange(ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? "";
        if (_tool == "highlighter") _hlColor  = v;
        else                        _penColor = v;
        ApplyCurrentTool();
    }
    async Task OnSizeChange(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var v)) return;
        if (_tool == "highlighter") _hlSize     = v;
        else if (_tool == "eraser") _eraserSize = v;
        else                        _penSize    = v;
        ApplyCurrentTool();
    }
    async Task SizeDown()
    {
        if (_tool == "highlighter") _hlSize     = Math.Max(1, _hlSize     - 1);
        else if (_tool == "eraser") _eraserSize = Math.Max(1, _eraserSize - 1);
        else                        _penSize    = Math.Max(1, _penSize    - 1);
        ApplyCurrentTool();
        StateHasChanged();
    }
    async Task SizeUp()
    {
        if (_tool == "highlighter") _hlSize     = Math.Min(40, _hlSize     + 1);
        else if (_tool == "eraser") _eraserSize = Math.Min(40, _eraserSize + 1);
        else                        _penSize    = Math.Min(40, _penSize    + 1);
        ApplyCurrentTool();
        StateHasChanged();
    }
    async Task OnOpacityChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v)) _penOpacity = v;
        ApplyCurrentTool();
    }

