            if(_draggingRuler!=null){_draggingRuler.X=curX-_dragOffsetX;_draggingRuler.Y=curY-_dragOffsetY;}
            else if(_resizingRuler!=null){_resizingRuler.Width=Math.Max(30,curX-_resizingRuler.X);_resizingRuler.Height=Math.Max(10,curY-_resizingRuler.Y);}
            StateHasChanged();
        }
    }
