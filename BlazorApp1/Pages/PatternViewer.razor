    async Task OnRulerMouseDown(MouseEventArgs e, RulerOverlay ruler)
    {
        if (_tool != "ruler") return;
        // 선택 + 팝업 위치 갱신
        _selectedRuler = ruler;
        _rulerPopupX = Math.Min(e.ClientX + 8, e.ClientX - 20);
        _rulerPopupY = Math.Max(e.ClientY - 60, 60);
        // 드래그 시작
        var rect = await JS.InvokeAsync<double[]>("patternViewer.getRect", ruler.Page);
        _draggingRuler = ruler;
        _dragOffsetX = (e.ClientX - rect[0]) - ruler.X * _zoom;
        _dragOffsetY = (e.ClientY - rect[1]) - ruler.Y * _zoom;
    }
    async Task OnRulerTouchStart(TouchEventArgs e, RulerOverlay ruler)
    {
        if (_tool != "ruler") return;
        var t = e.Touches[0];
        if (_selectedRuler != ruler)
        {
            _selectedRuler = ruler;
            // 팝업을 도형 위에 표시
            _rulerPopupX = Math.Max(10, Math.Min(t.ClientX - 80, t.ClientX + 8));
            _rulerPopupY = Math.Max(60, t.ClientY - 70);
            StateHasChanged();
            return;
        }
        // 이미 선택된 도형 → 드래그 시작
        var rect = await JS.InvokeAsync<double[]>("patternViewer.getRect", ruler.Page);
        _draggingRuler = ruler;
        _dragOffsetX = (t.ClientX - rect[0]) - ruler.X * _zoom;
        _dragOffsetY = (t.ClientY - rect[1]) - ruler.Y * _zoom;
    }
