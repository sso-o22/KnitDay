    string HexToRgb(string hex){hex=hex.TrimStart('#');return $"{Convert.ToInt32(hex[..2],16)},{Convert.ToInt32(hex[2..4],16)},{Convert.ToInt32(hex[4..6],16)}";}
    string RgbToHex(string rgb){var p=rgb.Split(',');return $"#{int.Parse(p[0]):X2}{int.Parse(p[1]):X2}{int.Parse(p[2]):X2}";}
    string DarkenRgb(string hex)
    {
        hex = hex.TrimStart('#');
        int r = Math.Max(0, Convert.ToInt32(hex[..2], 16) - 60);
        int g = Math.Max(0, Convert.ToInt32(hex[2..4], 16) - 60);
        int b = Math.Max(0, Convert.ToInt32(hex[4..6], 16) - 60);
        return $"{r},{g},{b}";
    }
    string GetCursor()=>_tool switch{"select"=>"default","pen"=>"crosshair","eraser"=>"cell","highlighter"=>"crosshair","rowmarker"=>"pointer","rowheightdraw"=>"ns-resize",_=>"crosshair"};

    // ── 이미지 모드 ──────────────────────────────────────────────────
    bool _isImageMode = false;
    string _imageDataUrl = "";
    double _imageOrigW = 0;
    double _imageOrigH = 0;
    List<RowMarker> _rowMarkers = new();
    string _rowMarkerColor = "#ffeb3b";
    string _gridLineColor  = "rgba(220,50,50,0.55)"; // 감지선 기본색 (연한 빨강)
    double _detectedRowH = 0;
    int _detectedLineCount = 0;
    List<double> _previewLineYs = new();   // 감지 미리보기 선 (확인 전)
    bool _showPreviewLines = false;
    int _detectPage = 0;

    // ── 수동 행 높이: 두 선 드래그 ───────────────────────────────────
    int    _rowDrawPage  = 0;
    double _rowLineAY    = 100; // CSS px, canvas 기준 (zoom 반영)
    double _rowLineBY    = 160; // CSS px, canvas 기준 (zoom 반영)

    void StartRowHeightDraw()
    {
        _tool        = "rowheightdraw";
        _rowDrawPage = _currentPage;
        // 현재 보이는 스크롤 중앙 근처에 두 선 배치
        var center = 200 * _zoom; // 임시 기본값; JS에서 스크롤 중앙으로 이동
        _rowLineAY   = center;
        _rowLineBY   = center + 40 * _zoom;
        _ = JS.InvokeVoidAsync("patternViewer.initRowLines", _currentPage,
                               DotNetObjectReference.Create(this));
        StateHasChanged();
    }

    [JSInvokable]
    public void SetRowLineAY(double y) { _rowLineAY = y; StateHasChanged(); }
    [JSInvokable]
    public void SetRowLineBY(double y) { _rowLineBY = y; StateHasChanged(); }

    async Task ConfirmRowHeightLines()
    {
        var rowHCss   = Math.Abs(_rowLineAY - _rowLineBY); // 현재 zoom 기준
        if (rowHCss < 4) return;

        _detectedRowH = rowHCss / _zoom; // zoom=1 기준 저장
        var topCssY   = Math.Min(_rowLineAY, _rowLineBY);
        var startY1   = topCssY / _zoom;

        _pageWidth  = await JS.InvokeAsync<double>("patternViewer.getPageWidth",  _rowDrawPage);
        var pageHCss = await JS.InvokeAsync<double>("patternViewer.getPageHeight", _rowDrawPage);

        _previewLineYs.Clear();
        for (var y = startY1; y >= 0; y -= _detectedRowH)
            _previewLineYs.Add(y);
        for (var y = startY1 + _detectedRowH; y < pageHCss / _zoom; y += _detectedRowH)
            _previewLineYs.Add(y);
        _previewLineYs.Sort();

        _detectedLineCount = _previewLineYs.Count;
        _detectPage        = _rowDrawPage;
        _showPreviewLines  = true;
        _tool              = "rowmarker";
        StateHasChanged();
    }

    async Task OnAnnoCanvasClick(MouseEventArgs e, int pageNum)
    {
        if (!_drawMode) return;
        if (_tool != "rowmarker") return;
        if (_detectedRowH <= 0) return;

        // JS로 스크롤 보정된 정확한 CSS Y 좌표
        var cssPxY = await JS.InvokeAsync<double>("patternViewer.getCanvasCssY", pageNum, e.ClientY);
        var clickY = cssPxY / _zoom;

        _ = JS.InvokeVoidAsync("console.log",
            $"[클릭] cssPxY={cssPxY:F1} zoom={_zoom:F2} clickY={clickY:F1} rowH={_detectedRowH:F2} lineYs={_previewLineYs.Count}개" +
            (_previewLineYs.Count > 0 ? $" 근접lineY={_previewLineYs.MinBy(ly => Math.Abs(ly - clickY)):F1}" : ""));

        // 감지된 lineYs가 있으면 가장 가까운 행 시작점으로 스냅
        double markerY;
        if (_previewLineYs.Count > 0)
        {
            markerY = _previewLineYs.MinBy(ly => Math.Abs(ly - clickY));
        }
        else
        {
            // lineYs 없으면 행 높이로 계산
            var rowIndex = (int)(clickY / _detectedRowH);
            markerY = rowIndex * _detectedRowH;
        }

        // 같은 페이지·같은 행이면 무시
        if (_rowMarkers.Any(m => m.Page == pageNum && Math.Abs(m.Y - markerY) < _detectedRowH * 0.5 && m.IsCurrent))
            return;

        // 기존 current → 완료(흔적)로 변경
        foreach (var m in _rowMarkers.Where(m => m.IsCurrent)) m.IsCurrent = false;

        // 새 현재 행 마커 추가
        _rowMarkers.Add(new RowMarker
        {
            Page = pageNum,
            Y = markerY,
            RowHeight = _detectedRowH,
            PageWidth = _pageWidth,
            Color = _rowMarkerColor,
            IsCurrent = true
        });
        _ = SaveRowMarkersAsync();
        StateHasChanged();
    }

    async Task DetectRowHeight()
    {
        if (!_pdfLoaded) return;
        _showPreviewLines = false;
        _previewLineYs.Clear();
        StateHasChanged();

        var result = await JS.InvokeAsync<DetectResult>("patternViewer.detectRowHeight", _currentPage);
        _detectedLineCount = result.LineCount;
        _detectPage = _currentPage;

        if (result.RowHeight > 0)
        {
            // JS는 현재 zoom 기준 CSS px 반환 → zoom=1 기준으로 나눠서 저장
            _detectedRowH = result.RowHeight / _zoom;
            _pageWidth = await JS.InvokeAsync<double>("patternViewer.getPageWidth", _currentPage);
            // lineYs도 동일하게 zoom=1 기준으로 변환해서 저장
            // 렌더링 시 * _zoom 곱하므로 일관성 유지
            _previewLineYs = result.LineYs?.Select(y => y / _zoom).ToList() ?? new();
            _showPreviewLines = true;
        }
        StateHasChanged();
    }

    void ConfirmDetect()
    {
        _showPreviewLines = false;
        _previewLineYs.Clear();
        StateHasChanged();
    }

    record DetectResult(
        [property: System.Text.Json.Serialization.JsonPropertyName("rowHeight")] double RowHeight,
        [property: System.Text.Json.Serialization.JsonPropertyName("lineCount")] int LineCount,
        [property: System.Text.Json.Serialization.JsonPropertyName("lineYs")] List<double>? LineYs
    );

    void OnRowMarkerColorChange(ChangeEventArgs e)
    {
        _rowMarkerColor = e.Value?.ToString() ?? "#ffeb3b";
        foreach (var m in _rowMarkers.Where(m => m.IsCurrent))
            m.Color = _rowMarkerColor;
        StateHasChanged();
    }

    void OnGridLineColorChange(ChangeEventArgs e)
    {
        var hex = e.Value?.ToString() ?? "#dc3232";
        // hex → rgba (투명도 0.55 고정)
        _gridLineColor = $"rgba({Convert.ToInt32(hex[1..3],16)},{Convert.ToInt32(hex[3..5],16)},{Convert.ToInt32(hex[5..7],16)},0.55)";
        StateHasChanged();
    }

    void OnRowHeightManualChange(ChangeEventArgs e)
    {
        // 사용자는 현재 화면 기준 px 입력 → zoom=1 기준으로 변환해서 저장
        if (double.TryParse(e.Value?.ToString(), out var v) && v > 0)
            _detectedRowH = v / _zoom;
    }

    void MoveRowMarkerUp()
    {
        var current = _rowMarkers.FirstOrDefault(m => m.IsCurrent);
        if (current == null || _detectedRowH <= 0) return;

        // 다음 행 Y 계산: lineYs에서 현재보다 작은 값 중 가장 가까운 것
        double nextY;
        if (_previewLineYs.Count > 0)
        {
            var candidates = _previewLineYs.Where(ly => ly < current.Y - _detectedRowH * 0.3).ToList();
            nextY = candidates.Count > 0
                ? candidates.MaxBy(ly => ly)
                : Math.Max(0, current.Y - _detectedRowH);
        }
        else
        {
            nextY = Math.Max(0, current.Y - _detectedRowH);
        }

        current.IsCurrent = false;
        _rowMarkers.Add(new RowMarker
        {
            Page = current.Page,
            Y = nextY,
            RowHeight = _detectedRowH,
            PageWidth = _pageWidth,
            Color = _rowMarkerColor,
            IsCurrent = true
        });
        _ = SaveRowMarkersAsync();
        StateHasChanged();
    }

    void UndoRowMarker()
    {
        if (!_rowMarkers.Any()) return;

        // 현재 행 마커 제거
        var current = _rowMarkers.LastOrDefault(m => m.IsCurrent);
        if (current != null)
        {
            _rowMarkers.Remove(current);
            // 직전 완료 마커를 다시 현재로 복원
            var prev = _rowMarkers.LastOrDefault();
            if (prev != null) prev.IsCurrent = true;
        }
        else
        {
            // 현재 마커가 없으면 마지막 완료 마커 제거
            var last = _rowMarkers.LastOrDefault();
            if (last != null) _rowMarkers.Remove(last);
        }
        _ = SaveRowMarkersAsync();
        StateHasChanged();
    }

    async Task ClearRowMarkers()
    {
        _rowMarkers.Clear();
        await SaveRowMarkersAsync();
        StateHasChanged();
    }

    double _pageWidth = 0;

    async Task SaveRowMarkersAsync()
    {
        if (_project == null) return;
        _project.ViewerRowMarkers = System.Text.Json.JsonSerializer.Serialize(_rowMarkers);
        await SaveProject();
    }
    async Task GoBack()
    {
        // 뒤로가기 전 즉시 저장 (디바운스 기다리지 않고)
        await ForceSaveViewerStateAsync();
        Nav.NavigateTo("projects/" + ProjectId);
    }

    async Task ForceSaveViewerStateAsync()
    {
        if (_project == null || !_pdfLoaded) return;
        try
        {
            _saveCts?.Cancel();
            var pathsJson = await JS.InvokeAsync<string>("patternViewer.getPaths");
            _project.ViewerAnnotations = pathsJson;

            _project.ViewerRowMarkers      = System.Text.Json.JsonSerializer.Serialize(_rowMarkers);
            _project.ViewerLastZoom        = _zoom;
            _project.ViewerLastPage        = _currentPage;
            _project.ViewerLastTool        = _tool;
            _project.ViewerPenColor        = _penColor;
            _project.ViewerPenSize         = _penSize;
            _project.ViewerPenOpacity      = _penOpacity;
            _project.ViewerHlColor         = _hlColor;
            _project.ViewerHlSize          = _hlSize;
            _project.ViewerEraserSize      = _eraserSize;
            _project.ViewerRowMarkerColor  = _rowMarkerColor;
            _project.ViewerGridLineColor   = _gridLineColor;
            await SaveProject();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", "ForceSave error: " + ex.Message);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _saveCts?.Cancel();
        _saveCts?.Dispose();
        StopRefreshTimer();
        _dotNetRef?.Dispose();
        try { await JS.InvokeVoidAsync("patternViewer.dispose"); } catch { }
    }
}
