@page "/pattern-viewer/{ProjectId:guid}"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<!--
  PC:  사이드바(220px) 오른쪽 main-content 안에서 전체 차지
  모바일: 사이드바 없으므로 position:fixed로 전체화면
-->
<div class="pv-root"
     @onmousemove="OnGlobalMouseMove"
     @onmouseup="OnGlobalMouseUp"
     @ontouchmove="OnGlobalTouchMove"
     @ontouchend="OnGlobalTouchEnd">

    <!-- PDF 스크롤 영역 (꽉 차게) -->
    <div id="scroll-container" class="pv-scroll">
        <div id="pdf-wrapper" style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:8px 0;">
            @if (_pdfLoaded)
            {
                @for (int pg = 1; pg <= _totalPages; pg++)
                {
                    var pageNum = pg;
                    <div class="page-container" id="page-container-@pageNum" style="position:relative;display:inline-block;">
                        @if (_isImageMode)
                        {
                            <img id="pdf-canvas-@pageNum" src="@_imageDataUrl"
                                 style="display:block;width:@(_imageOrigW * _zoom)px;height:@(_imageOrigH * _zoom)px;" />
                        }
                        else
                        {
                            <canvas id="pdf-canvas-@pageNum" style="display:block;"></canvas>
                        }
                        <canvas id="anno-canvas-@pageNum" style="position:absolute;top:0;left:0;z-index:10;cursor:@GetCursor();"
                                @onclick="e => OnAnnoCanvasClick(e, pageNum)"></canvas>

                        @foreach (var ruler in _rulers.Where(r => r.Page == pageNum))
                        {
                            var isSelected = _selectedRuler == ruler && _tool == "ruler";
                            <div class="ruler-item @(isSelected ? "ruler-selected" : "")"
                                 style="position:absolute;left:@(ruler.X * _zoom)px;top:@(ruler.Y * _zoom)px;width:@(ruler.Width * _zoom)px;height:@(ruler.Height * _zoom)px;
                                        background:rgba(@(ruler.ColorRgb),@(ruler.Opacity.ToString("F2",System.Globalization.CultureInfo.InvariantCulture)));
                                        border:2px solid rgba(@(ruler.ColorRgb),@(isSelected?"1.0":"0.8"));
                                        cursor:@(_tool=="ruler"?(isSelected?"move":"pointer"):"default");
                                        pointer-events:@(_tool=="ruler"?"auto":"none");"
                                 @onclick:stopPropagation="true" @onclick="() => OnRulerClick(ruler)"
                                 @onmousedown="e => OnRulerMouseDown(e, ruler)" @onmousedown:stopPropagation="true"
                                 @ontouchstart="e => OnRulerTouchStart(e, ruler)" @ontouchstart:stopPropagation="true">
                                @if (isSelected)
                                {
                                    <div class="resize-handle"
                                         @onmousedown="e => OnResizeMouseDown(e,ruler)" @onmousedown:stopPropagation="true"
                                         @ontouchstart="e => OnResizeTouchStart(e,ruler)" @ontouchstart:stopPropagation="true"></div>
                                }
                            </div>
                        }
                        @if (_isDrawingRuler && _rulerPage == pageNum)
                        {
                            <div style="position:absolute;left:@(Math.Min(_rulerStartX,_rulerStartX+_previewW))px;top:@(Math.Min(_rulerStartY,_rulerStartY+_previewH))px;width:@(Math.Abs(_previewW))px;height:@(Math.Abs(_previewH))px;border:2px dashed rgba(0,0,0,0.5);pointer-events:none;z-index:20;"></div>
                        }

                        @* ── 행 감지 미리보기 선 ── *@
                        @if (_showPreviewLines && _detectPage == pageNum)
                        {
                            foreach (var lineY in _previewLineYs)
                            {
                                <div style="position:absolute;left:0;top:@(lineY * _zoom)px;
                                            width:@(_pageWidth * _zoom)px;height:1px;
                                            background:rgba(255,80,80,0.6);
                                            pointer-events:none;z-index:25;"></div>
                            }
                        }

                        @* ── 행 마커 ── *@
                        @foreach (var marker in _rowMarkers.Where(m => m.Page == pageNum))
                        {
                            var markerY   = marker.Y * _zoom;
                            var markerH   = Math.Max(marker.RowHeight * _zoom, 4);
                            var markerW   = marker.PageWidth * _zoom;
                            var alpha     = marker.IsCurrent ? "0.45" : "0.30";
                            var rgb       = HexToRgb(marker.Color);
                            var darkRgb   = DarkenRgb(marker.Color);
                            var borderH   = Math.Max(2, markerH * 0.12);
                            <div style="position:absolute;left:0;top:@(markerY)px;
                                        width:@(markerW)px;height:@(markerH)px;
                                        background:rgba(@rgb,@alpha);
                                        @(marker.IsCurrent
                                            ? $"box-shadow:0 -{borderH}px 0 0 rgba({darkRgb},0.8),0 {borderH}px 0 0 rgba({darkRgb},0.8);"
                                            : "")
                                        pointer-events:none;z-index:15;
                                        transition:top 0.15s ease,height 0.15s ease;">
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- ── 프로젝트명 / 파일명 표시줄 ── -->
    @if (_project != null)
    {
        <div class="pv-title-bar">
            <span class="pv-title-project">@_project.Title</span>
            @if (!string.IsNullOrEmpty(_project.PatternFileName))
            {
                <span class="pv-title-sep">·</span>
                <span class="pv-title-file">@_project.PatternFileName</span>
            }
        </div>
    }

    <!-- ── 상단 오버레이 툴바 ── -->
    <!-- 구조: [나가기 + 타이머] [가운데: 페이지/줌] [도안 불러오기] -->
    <div class="top-bar">
        <!-- 왼쪽: 나가기 + 타이머 -->
        <div class="tb-left">
            <button class="tb-btn" @onclick="GoBack">←</button>
            @if (_project is not null)
            {
                <div class="tb-div"></div>
                <span style="font-size:11px;opacity:0.4;">⏱</span>
                <span class="tb-txt" style="font-variant-numeric:tabular-nums;letter-spacing:0.3px;">@_timerDisplay</span>
                @if (_activeSession == null)
                {
                    <button class="tb-icon-btn" @onclick="StartSession">▶</button>
                }
                else
                {
                    <button class="tb-icon-btn" @onclick="EndSession">⏸</button>
                }
            }
        </div>

        <!-- 가운데: 페이지수만 -->
        <div class="tb-center">
            @if (_totalPages > 0)
            {
                <span class="tb-txt">@_currentPage / @_totalPages</span>
            }
        </div>

        <!-- 오른쪽: 줌 + 도안 불러오기 -->
        <div class="tb-right">
            @if (_totalPages > 0)
            {
                <div class="tb-zoom">
                    <button class="tb-zoom-btn" @onclick="ZoomOut">−</button>
                    <span class="tb-txt" style="min-width:36px;text-align:center;">@((int)(_zoom*100))%</span>
                    <button class="tb-zoom-btn" @onclick="ZoomIn">+</button>
                </div>
                <div class="tb-div"></div>
            }
            <span class="tb-label" style="cursor:pointer;" @onclick="OnLoadPatternClick">
                📄
            </span>
            <InputFile id="pdf-file-input" OnChange="OnPdfSelected" accept="application/pdf,image/png,image/jpeg,image/webp" style="display:none;" />
        </div>
    </div>

    <!-- ── 필기 도구 플로팅 위젯 (좌측 상단, 툴바 아래) ── -->
    <div class="draw-wrap">
        <button class="draw-fab" id="draw-fab-btn" @onclick="ToggleDrawMode">✏️</button>
        <div class="draw-panel" id="draw-panel-div">
            <div class="draw-panel-inner">
                <!-- 행1: 도구 선택 (도형 → 펜 → 지우개) -->
                <div class="dp-row">
                    <button class="dp-btn @(_tool=="ruler"?"dp-on":"")"       @onclick='()=>SetTool("ruler")'>📏</button>
                    <button class="dp-btn @(_tool=="pen"?"dp-on":"")"         @onclick='()=>SetTool("pen")'>🖋️</button>
                    <button class="dp-btn @(_tool=="highlighter"?"dp-on":"")" @onclick='()=>SetTool("highlighter")'>🖊️</button>
                    <button class="dp-btn @(_tool=="eraser"?"dp-on":"")"       @onclick='()=>SetTool("eraser")'>🧽</button>
                    <button class="dp-btn @(_tool=="rowmarker"?"dp-on":"")"   @onclick='()=>SetTool("rowmarker")' title="행 마커">☰</button>
                </div>

                @if (_tool == "rowmarker")
                {
                    <div class="dp-sep"></div>
                    @* 색상 *@
                    <div class="dp-row" style="justify-content:center;">
                        <input type="color" value="@_rowMarkerColor" @oninput="OnRowMarkerColorChange"
                               style="width:28px;height:28px;border:none;border-radius:50%;padding:2px;cursor:pointer;background:transparent;" />
                    </div>
                    <div class="dp-sep"></div>
                    @* 행 높이 감지 버튼 *@
                    <div class="dp-row" style="justify-content:center;">
                        <button class="dp-btn" title="행 감지" @onclick="DetectRowHeight" style="font-size:11px;width:36px;height:28px;">🔍</button>
                    </div>
                    @* 감지 결과 피드백 *@
                    @if (_detectPage > 0)
                    {
                        @if (_detectedRowH > 0)
                        {
                            <div class="dp-val" style="font-size:9px;text-align:center;color:#2a7a2a;margin-top:2px;">
                                @($"{_detectedRowH * _zoom:F0}px")
                            </div>
                            <div class="dp-val" style="font-size:8px;text-align:center;color:#888;">
                                @($"{_detectedLineCount}줄")
                            </div>
                            @if (_showPreviewLines)
                            {
                                <div class="dp-row" style="justify-content:center;margin-top:2px;">
                                    <button class="dp-btn" style="font-size:10px;width:36px;height:22px;background:#e8f5e8;"
                                            @onclick="ConfirmDetect" title="확인">✓</button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="dp-val" style="font-size:8px;text-align:center;color:#c05050;margin-top:2px;">감지 실패</div>
                        }
                    }
                    @* 수동 행 높이 입력 *@
                    <div class="dp-row" style="justify-content:center;margin-top:2px;">
                        <input type="number" min="2" max="500" value="@((int)(_detectedRowH * _zoom > 0 ? _detectedRowH * _zoom : 20))"
                               @onchange="OnRowHeightManualChange"
                               style="width:36px;font-size:10px;text-align:center;padding:2px;border:1px solid #ccc;border-radius:4px;" />
                    </div>
                    <div class="dp-sep"></div>
                    @* + 버튼 (위로 이동) *@
                    @if (_rowMarkers.Any(m => m.IsCurrent))
                    {
                        <div class="dp-row" style="justify-content:center;gap:4px;">
                            <button class="dp-btn" title="다음 행으로" @onclick="MoveRowMarkerUp" style="font-size:16px;">+</button>
                            <button class="dp-btn" title="되돌리기" @onclick="UndoRowMarker" style="font-size:13px;">↩</button>
                        </div>
                    }
                    else if (_rowMarkers.Any())
                    {
                        <div class="dp-row" style="justify-content:center;">
                            <button class="dp-btn" title="되돌리기" @onclick="UndoRowMarker" style="font-size:13px;">↩</button>
                        </div>
                    }
                    @* 전체 삭제 *@
                    @if (_rowMarkers.Any())
                    {
                        <div class="dp-sep"></div>
                        <div class="dp-row" style="justify-content:center;">
                            <button class="dp-btn" title="행 마커 전체 삭제" @onclick="ClearRowMarkers" style="font-size:11px;">🗑</button>
                        </div>
                    }
                }

                @if (_tool == "pen" || _tool == "eraser" || _tool == "highlighter")
                {
                    <div class="dp-sep"></div>

                    @if (_tool == "pen" || _tool == "highlighter")
                    {
                        <!-- 행2: 색상 -->
                        <div class="dp-row" style="justify-content:center;">
                            <input type="color" value="@_penColor" @oninput="OnColorChange"
                                   style="width:28px;height:28px;border:none;border-radius:50%;padding:2px;cursor:pointer;background:transparent;" />
                        </div>
                    }

                    <!-- 굵기: 세로 슬라이더 + ± -->
                    <div class="dp-slider-col">
                        <button class="dp-size-btn" @onclick="SizeUp">+</button>
                        <input type="range" min="1" max="40" step="1" value="@_penSize"
                               @oninput="OnSizeChange"
                               class="dp-range-v" />
                        <button class="dp-size-btn" @onclick="SizeDown">−</button>
                        <span class="dp-val">@_penSize</span>
                    </div>

                    @if (_tool == "pen")
                    {
                        <div class="dp-sep"></div>
                        <!-- 투명도 세로 슬라이더 -->
                        <div class="dp-slider-col">
                            <span class="dp-label">100</span>
                            <input type="range" min="5" max="100" step="5" value="@_penOpacity"
                                   @oninput="OnOpacityChange"
                                   class="dp-range-v" />
                            <span class="dp-label">5</span>
                            <span class="dp-val" style="font-size:8px;">투명</span>
                        </div>
                    }

                    <div class="dp-sep"></div>
                    <!-- 되돌리기 -->
                    <div class="dp-row" style="justify-content:center;">
                        <button class="dp-btn" @onclick="UndoLastPath">↩️</button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── 카운터 플로팅 위젯 (드래그 가능) ── -->
    @if (_project is not null && _project.Counters.Any())
    {
        @if (_showCounterWidget)
        {
            <div class="cw-wrap @(_cwX < 0 ? "cw-default-pos" : "")"
                 style="@(_cwX >= 0 ? $"position:fixed;left:{_cwX}px;top:{_cwY}px;" : "")z-index:600;touch-action:none;cursor:grab;"
                 @onmousedown="CwDragStart">
                <div class="cw-inner" @onmousedown:stopPropagation="true" @ontouchstart:stopPropagation="true">
                    <!-- 드래그 핸들 -->
                    <div class="cw-header"
                         style="cursor:grab;"
                         @onmousedown="CwDragStart"
                         @ontouchstart="CwTouchStart">
                        <span style="font-size:11px;font-weight:700;color:#444;">🧶 카운터</span>
                        <button class="cw-close" @onclick="()=>_showCounterWidget=false" @onmousedown:stopPropagation="true">✕</button>
                    </div>
                    @{var c = _project.Counters[_activeCounterIndex];}
                    <div class="cw-nav">
                        <button class="cw-nav-btn" @onclick="PrevCounter" disabled="@(_project.Counters.Count<=1)">‹</button>
                        <div style="text-align:center;flex:1;">
                            <div style="font-size:12px;color:#333;font-weight:600;">@c.Label</div>
                            <div style="font-size:10px;color:#aaa;">@(_activeCounterIndex+1)/@_project.Counters.Count</div>
                        </div>
                        <button class="cw-nav-btn" @onclick="NextCounter" disabled="@(_project.Counters.Count<=1)">›</button>
                    </div>
                    <div class="cw-controls">
                        <button class="cw-btn minus" @onclick="()=>DecrementCounter(c)">−</button>
                        <span class="cw-val">@c.Value</span>
                        <button class="cw-btn plus"  @onclick="()=>IncrementCounter(c)">+</button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <button class="cw-fab" @onclick="()=>_showCounterWidget=true">🧶</button>
        }
    }
    <!-- ── 도형 컨트롤 팝업 (마우스 위치 기준 fixed) ── -->
    @if (_selectedRuler != null && _tool == "ruler")
    {
        var _sr = _selectedRuler;
        <div class="ruler-popup"
             style="position:fixed; left:@(_rulerPopupX)px; top:@(_rulerPopupY)px; z-index:800;"
             @onmousedown:stopPropagation="true"
             @onclick:stopPropagation="true"
             @ontouchstart:stopPropagation="true">
            <input type="color" value="@RgbToHex(_sr.ColorRgb)" @oninput="e => UpdateRulerColor(_sr, e)" title="색상" />
            <input type="range" min="10" max="90" step="5" value="@((int)(_sr.Opacity*100))"
                   @oninput="e => ChangeRulerOpacity(_sr, e)" style="width:48px;" title="투명도" />
            <button class="ctrl-btn" @onclick="() => { _sr.Y -= _sr.Height; StateHasChanged(); }">▲</button>
            <button class="ctrl-btn" @onclick="() => { _sr.Y += _sr.Height; StateHasChanged(); }">▼</button>
            <button class="ctrl-btn del" @onclick="() => { _rulers.Remove(_sr); _selectedRuler = null; _ = SaveRulersAsync(); StateHasChanged(); }">✕</button>
        </div>
    }
</div>

<style>
    /* ── 뷰어 루트: PC는 main-content 안, 모바일은 fixed fullscreen ── */
    .pv-root {
        /* PC: 사이드바 오른쪽 main-content 안에서 전체 높이 차지 */
        position: relative;
        width: 100%;
        height: 100vh;
        height: 100dvh; /* 모바일 주소창 대응 */
        overflow: hidden;
        background: #aaa;
    }
    /* 태블릿+모바일(1024px 이하): 사이드바 없으므로 fixed fullscreen */
    @@media (max-width: 1024px) {
        .pv-root {
            position: fixed;
            inset: 0;
            z-index: 50;
            height: 100dvh;
        }
    }

    .pv-scroll {
        position: absolute;
        inset: 0;
        overflow: auto;
        display: flex;
        justify-content: center;
    }

    /* ── 프로젝트명/파일명 표시줄 ── */
    .pv-title-bar {
        position: absolute;
        top: 0; left: 0; right: 0;
        background: rgba(255,255,255,0.72);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-bottom: 1px solid rgba(0,0,0,0.06);
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 6px;
        z-index: 210;
        height: 28px;
        box-sizing: border-box;
    }
    .pv-title-project {
        font-size: 11px;
        font-weight: 700;
        color: #333;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 200px;
    }
    .pv-title-sep { font-size: 11px; color: #aaa; flex-shrink: 0; }
    .pv-title-file {
        font-size: 10px;
        color: #888;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
    }
    [data-dark="true"] .pv-title-bar {
        background: rgba(28,28,28,0.80);
        border-bottom-color: rgba(255,255,255,0.06);
    }
    [data-dark="true"] .pv-title-project { color: #eee; }
    [data-dark="true"] .pv-title-sep { color: #555; }
    [data-dark="true"] .pv-title-file { color: #888; }

    /* ── 상단 툴바: 타이틀바(28px) 아래 배치 ── */
    .top-bar {
        position: absolute;
        top: 28px; left: 0; right: 0;
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        color: #222;
        padding: 5px 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 4px;
        z-index: 200;
        border-bottom: 1px solid rgba(0,0,0,0.08);
        flex-wrap: nowrap;
        box-shadow: 0 1px 8px rgba(0,0,0,0.1);
    }
    .tb-left  { display:flex; align-items:center; gap:5px; flex-shrink:0; }
    .tb-center { display:flex; align-items:center; gap:5px; flex:1; justify-content:center; }
    .tb-right { display:flex; align-items:center; gap:5px; flex-shrink:0; }
    .tb-btn {
        background: rgba(0,0,0,0.07); border: 1px solid rgba(0,0,0,0.12);
        color: #222; width: 32px; height: 28px; border-radius: 6px; cursor: pointer; flex-shrink: 0;
        font-size: 14px;
    }
    .tb-btn:hover { background: rgba(0,0,0,0.13); }
    .tb-label {
        background: rgba(0,0,0,0.06); border: 1px solid rgba(0,0,0,0.1);
        color: #333; padding: 0 10px; height: 28px;
        display: flex; align-items: center;
        border-radius: 14px; font-size: 12px; cursor: pointer; flex-shrink: 0;
    }
    .tb-txt { font-size: 11px; font-weight: 600; flex-shrink: 0; color: #222; }
    .tb-div { width: 1px; height: 14px; background: rgba(0,0,0,0.12); flex-shrink: 0; }
    .tb-zoom {
        display: flex; align-items: center;
        background: rgba(0,0,0,0.06); border-radius: 12px;
        padding: 0 6px; height: 28px; gap: 4px; flex-shrink: 0;
    }
    .tb-zoom-btn { background: transparent; border: none; color: #333; cursor: pointer; font-size: 18px; padding: 0 2px; }
    .tb-icon-btn {
        background: rgba(0,0,0,0.07); border: none; color: #333;
        width: 24px; height: 24px; border-radius: 4px; cursor: pointer;
        font-size: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .tb-icon-btn:hover { background: rgba(0,0,0,0.14); }

    /* ── 필기 위젯: 위젯(동그라미) 아래로 패널 펼치기 ── */
    .draw-wrap {
        position: fixed;
        top: 80px; /* 타이틀바(28px) + 툴바(~38px) + 여백 */
        left: 230px; /* PC: sidebar(220px) + 10px */
        z-index: 300;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 6px;
    }
    /* 태블릿: sidebar 72px */
    @@media (max-width: 1024px) and (min-width: 641px) {
        .draw-wrap { left: 82px; }
    }
    /* 모바일: sidebar 없음, fixed fullscreen 진장 */
    @@media (max-width: 640px) {
        .draw-wrap { left: 10px; }
    }
    .draw-fab {
        width: 40px; height: 40px; border-radius: 50%;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        border: 1.5px solid rgba(0,0,0,0.12);
