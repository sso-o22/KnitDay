@if (_showLoadWarning)
{
    <div class="modal-backdrop modal-confirm" style="z-index:9999;">
        <div class="modal" style="max-width:360px;text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem;margin-bottom:12px;">📄</div>
            <div style="font-size:1rem;font-weight:600;margin-bottom:8px;color:var(--text-dark);">도안을 교체할까요?</div>
            <div style="font-size:0.88rem;color:var(--text-mid);margin-bottom:20px;">이미 불러온 도안이 있어요.<br/>새 파일로 교체하면 기존 필기와 도형이 모두 사라져요.</div>
            <div style="display:flex;gap:10px;justify-content:center;">
                <button class="btn btn-ghost" @onclick="()=>_showLoadWarning=false">취소</button>
                <button class="btn btn-primary" @onclick="ConfirmLoadPattern">교체</button>
            </div>
        </div>
    </div>
}

@if (_showConfirm)
{
    <div class="modal-backdrop" style="z-index:9999;">
        <div class="modal" style="max-width:360px;text-align:center;" @onclick:stopPropagation="true">
            <div style="font-size:2rem;margin-bottom:12px;">🗑️</div>
            <div style="font-size:1rem;font-weight:600;margin-bottom:8px;color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem;color:var(--text-mid);margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex;gap:10px;justify-content:center;">
                <button class="btn btn-ghost" @onclick="()=>_showConfirm=false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _showLoadWarning=false;
    bool _showConfirm=false; string _confirmMsg=""; Func<Task>? _confirmAction;
    void Confirm(string msg,Func<Task> action){_confirmMsg=msg;_confirmAction=action;_showConfirm=true;}
    async Task ExecuteConfirm(){_showConfirm=false;if(_confirmAction!=null)await _confirmAction();_confirmAction=null;}

    [Parameter] public Guid ProjectId { get; set; }
    KnitProject? _project;
    string _tool="select", _penColor="#000000";
    int _penSize=4; // 모바일 기본값 얇게
    int _penOpacity=100; // 투명도 (100=불투명, 낮을수록 형광펜)
    int _currentPage=1, _totalPages=1;
    double _zoom=1.0;
    bool _pdfLoaded=false, _isDrawing=false, _isDrawingRuler=false;
    bool _drawMode=false, _showCounterWidget=true;
    int _activeCounterIndex=0;
    double _rulerStartX,_rulerStartY,_previewW,_previewH,_dragOffsetX,_dragOffsetY;
    double _rulerPopupX=200, _rulerPopupY=200; // 도형 컨트롤 팝업 위치
    int _rulerPage=1;
    List<RulerOverlay> _rulers=new();
    RulerOverlay? _draggingRuler,_resizingRuler,_selectedRuler;
    DotNetObjectReference<PatternViewer>? _dotNetRef;

    // ── 카운터 위젯 드래그 ──
    double _cwX=-1, _cwY=-1; // -1 = JS 계산 전, CSS로 우하단 고정
    bool _cwDragging=false;
    double _cwOffX=0, _cwOffY=0;

    void CwDragStart(MouseEventArgs e)
    {
        _cwDragging=true;
        _cwOffX=e.ClientX-_cwX;
        _cwOffY=e.ClientY-_cwY;
    }
    void CwTouchStart(TouchEventArgs e)
    {
        if(e.Touches.Length==0)return;
        _cwDragging=true;
        _cwOffX=e.Touches[0].ClientX-_cwX;
        _cwOffY=e.Touches[0].ClientY-_cwY;
    }

    // ── 타이머 ──
    KnitSession? _activeSession => _project?.Sessions.FirstOrDefault(s=>s.IsActive);
    string _timerDisplay="00:00:00";
    PeriodicTimer? _refreshTimer;
    void StartRefreshTimer(){StopRefreshTimer();_refreshTimer=new PeriodicTimer(TimeSpan.FromSeconds(1));_=RefreshUIAsync();}
    void StopRefreshTimer(){_refreshTimer?.Dispose();_refreshTimer=null;}
    async Task RefreshUIAsync(){try{while(_refreshTimer is not null&&await _refreshTimer.WaitForNextTickAsync()){UpdateTimerDisplay();await InvokeAsync(StateHasChanged);}}catch(OperationCanceledException){}}
    void UpdateTimerDisplay(){if(_project==null){_timerDisplay="00:00:00";return;}var a=_project.Sessions.FirstOrDefault(s=>s.IsActive);if(a==null){_timerDisplay="00:00:00";return;}var t=(int)(DateTime.Now-a.StartTime).TotalSeconds;_timerDisplay=$"{t/3600:D2}:{(t%3600)/60:D2}:{t%60:D2}";}
    async Task StartSession(){if(_project==null)return;var ex=_project.Sessions.FirstOrDefault(s=>s.IsActive);if(ex!=null)ex.EndTime=DateTime.Now;_project.Sessions.Add(new KnitSession{StartTime=DateTime.Now});await Storage.SaveProjectAsync(_project);StartRefreshTimer();StateHasChanged();}
    async Task EndSession(){if(_project==null)return;var a=_project.Sessions.FirstOrDefault(s=>s.IsActive);if(a==null)return;a.EndTime=DateTime.Now;await Storage.SaveProjectAsync(_project);StopRefreshTimer();_timerDisplay="00:00:00";StateHasChanged();}

    // ── 카운터 ──
    void PrevCounter(){if(_project==null||_project.Counters.Count==0)return;_activeCounterIndex=(_activeCounterIndex-1+_project.Counters.Count)%_project.Counters.Count;}
    void NextCounter(){if(_project==null||_project.Counters.Count==0)return;_activeCounterIndex=(_activeCounterIndex+1)%_project.Counters.Count;}
    async Task IncrementCounter(ProjectCounter c){c.Value+=c.Step;c.LastUpdatedAt=DateTime.Now;await SaveProject();StateHasChanged();}
    async Task DecrementCounter(ProjectCounter c){c.Value=Math.Max(0,c.Value-c.Step);c.LastUpdatedAt=DateTime.Now;await SaveProject();StateHasChanged();}
    async Task SaveProject(){if(_project is KnitProject p)await Storage.SaveProjectAsync(p);}

    // 도형만 즉시 저장 (디바운스 없이)
    async Task SaveRulersAsync()
    {
        if (_project == null) return;
        try
        {
            _project.ViewerRulers = System.Text.Json.JsonSerializer.Serialize(_rulers);
            await SaveProject();
        }
        catch { }
    }

    // 필기+도형+줌+페이지 자동 저장 (디바운스)
    System.Threading.CancellationTokenSource? _saveCts;
    async Task SaveViewerStateAsync()
    {
        if (_project == null || !_pdfLoaded || _isRestoring) return;
        // 디바운스: 2초 내 연속 호출은 마지막 것만 실행
        _saveCts?.Cancel();
        _saveCts = new System.Threading.CancellationTokenSource();
        var token = _saveCts.Token;
        try
        {
            await Task.Delay(2000, token);
            if (token.IsCancellationRequested) return;

            // 필기 paths를 JS에서 가져와서 저장
            var pathsJson = await JS.InvokeAsync<string>("patternViewer.getPaths");
            _project.ViewerAnnotations = pathsJson;

            // 도형 저장
            _project.ViewerRulers = System.Text.Json.JsonSerializer.Serialize(_rulers);

            // 줌/페이지 저장
            _project.ViewerLastZoom = _zoom;
            _project.ViewerLastPage = _currentPage;

            await SaveProject();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", "SaveViewerState error: " + ex.Message);
        }
    }

    // ── 초기화 ──
    protected override async Task OnInitializedAsync()
    {
        _project=(await Storage.GetProjectsAsync()).FirstOrDefault(p=>p.Id==ProjectId);
        if(_project?.Sessions.Any(s=>s.IsActive)==true)StartRefreshTimer();
    }

    // OnAfterRenderAsync 첫 렌더 후 저장된 데이터 복원
    bool _restoredOnce = false;
    bool _isRestoring = false;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if(firstRender)
        {
            var vw = await JS.InvokeAsync<double>("eval", "window.innerWidth");
            var vh = await JS.InvokeAsync<double>("eval", "window.innerHeight");
            _cwX = Math.Max(16, vw - 196);
            _cwY = Math.Max(80, vh - 230);
            _dotNetRef=DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("patternViewer.init",_dotNetRef);
            await JS.InvokeVoidAsync("patternViewer.setTool",_penColor,_penSize,false,_tool,_penOpacity);
            StateHasChanged();
        }

        // 첫 렌더 후 저장 데이터 복원 (한 번만)
        if (!_restoredOnce && _project != null)
        {
            _restoredOnce = true;
            await RestoreSavedPatternAsync();
        }
    }

    async Task RestoreSavedPatternAsync()
    {
        if (_project == null || !_project.HasSavedPattern) return;
        _isRestoring = true;
        try
        {
            var savedFileName = await JS.InvokeAsync<string?>("patternViewer.loadPdfFromProject", ProjectId.ToString());
            if (string.IsNullOrEmpty(savedFileName)) return;

            var pages = await JS.InvokeAsync<int>("patternViewer.renderSavedPdf", ProjectId.ToString());
            if (pages <= 0) return;

            _totalPages = pages;
            _pdfLoaded = true;
            _currentPage = _project.ViewerLastPage > 0 ? _project.ViewerLastPage : 1;
            StateHasChanged();
            await Task.Delay(100);

            await JS.InvokeVoidAsync("patternViewer.renderPdf");
            await Task.Delay(200); // renderPdf 내부 ZoomToFromJS 콜백 완료 대기


            // 필기 복원은 렌더 완전히 끝난 후
            if (!string.IsNullOrEmpty(_project.ViewerAnnotations))
                await JS.InvokeVoidAsync("patternViewer.setPaths", _project.ViewerAnnotations);

            if (!string.IsNullOrEmpty(_project.ViewerRulers))
            {
                try
                {
                    var rulers = System.Text.Json.JsonSerializer.Deserialize<List<RulerOverlay>>(
                        _project.ViewerRulers,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (rulers != null) _rulers = rulers;
                }
                catch { }
            }

            StateHasChanged();

            // 마지막으로 보던 페이지로 스크롤
            if (_currentPage > 1)
            {
                await Task.Delay(150); // 렌더 완료 대기
                await JS.InvokeVoidAsync("patternViewer.scrollToPage", _currentPage);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", "RestoreSavedPattern error: " + ex.Message);
        }
        finally
        {
            _saveCts?.Cancel(); // 복원 중 쌓인 디바운스 타이머 취소
            _saveCts = null;
            _isRestoring = false;
        }
    }


    // ── PDF ──
    async Task UndoLastPath()=>await JS.InvokeVoidAsync("patternViewer.undo");
    // 도안 불러오기 버튼 클릭 → 이미 있으면 경고, 없으면 바로 파일 선택
    async Task OnLoadPatternClick()
    {
        if (_pdfLoaded)
        {
            _showLoadWarning = true;
            StateHasChanged();
        }
        else
        {
            await JS.InvokeVoidAsync("patternViewer.triggerFileInput");
        }
    }

    async Task ConfirmLoadPattern()
    {
        _showLoadWarning = false;
        // 기존 필기/도형/줌/페이지 초기화
        _rulers.Clear();
        _zoom = 1.0;
        _currentPage = 1;
        _pdfLoaded = false;
        _totalPages = 0;
        if (_project != null)
        {
            _project.ViewerAnnotations = "";
            _project.ViewerRulers = "";
            _project.ViewerLastZoom = 0;
            _project.ViewerLastPage = 1;
        }
        await JS.InvokeVoidAsync("patternViewer.clearAnnotations");
        await JS.InvokeVoidAsync("patternViewer.triggerFileInput");
    }

    async Task OnPdfSelected(InputFileChangeEventArgs e)
    {
        try
        {
            // 파일을 byte[]로 읽어서 Base64로 JS에 전달
            // (DotNetStreamReference.arrayBuffer()가 iOS Safari에서 404 오류 발생)
            // MemoryStream 경유 (iOS Safari의 DotNetStreamReference 불안정 우회)
            using var stream = e.File.OpenReadStream(100 * 1024 * 1024); // 100MB
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            // JS에 byte[] 직접 전달 (Base64 변환 없이 → 메모리 절약)
            using var streamRef = new DotNetStreamReference(new System.IO.MemoryStream(bytes), leaveOpen: false);
            var pages = await JS.InvokeAsync<int>("patternViewer.loadPdfBytes", streamRef);
            if (pages <= 0) return;

            // Blazor DOM에 캔버스 생성
            _totalPages = pages;
            _pdfLoaded = true;
            _currentPage = 1;
            StateHasChanged();
            await Task.Delay(100);

            // JS 렌더링
            await JS.InvokeVoidAsync("patternViewer.renderPdf");

            // IndexedDB에 저장
            if (_project != null)
            {
                var saved = await JS.InvokeAsync<bool>("patternViewer.savePdfToProject",
                    ProjectId.ToString(), e.File.Name);
                if (saved)
                {
                    _project.HasSavedPattern = true;
                    _project.PatternFileName = e.File.Name;
                    await SaveProject();
                }
            }
        }
        catch (Exception ex)
        {
            _pdfLoaded = false;
            _totalPages = 0;
            StateHasChanged();
            await JS.InvokeVoidAsync("console.error", "PDF load error: " + ex.Message);
        }
    }
    async Task ZoomIn(){_zoom=Math.Round(_zoom+0.1,1);await RenderAllPages();}
    async Task ZoomOut(){_zoom=Math.Round(_zoom-0.1,1);await RenderAllPages();}
    async Task RenderAllPages(){await JS.InvokeVoidAsync("patternViewer.renderAllPages",_zoom);StateHasChanged();}
    [JSInvokable] public void UpdatePageFromJS(int page)
    {
        _currentPage = page;
        StateHasChanged();
        _ = SaveViewerStateAsync();
    }
    [JSInvokable] public void NotifyAnnotationChanged()
    {
        _ = SaveViewerStateAsync();
    }

    [JSInvokable] public void ZoomToFromJS(double zoom)
    {
        _zoom = zoom;
        StateHasChanged();
        _ = SaveViewerStateAsync(); // 줌 변경 시 자동 저장 (fire-and-forget)
    }

    // ── 필기 ──
    void ToggleDrawMode()
    {
        _drawMode = !_drawMode;
        if (_drawMode)
            SetTool("pen"); // 필기모드 ON → 펜으로 시작
        else
            SetTool("select"); // 필기모드 OFF → select(이동) 모드
    }
    void SetTool(string t){_tool=t;_=JS.InvokeVoidAsync("patternViewer.setTool",_penColor,_penSize,t=="eraser",t,_penOpacity);}
    async Task OnColorChange(ChangeEventArgs e){_penColor=e.Value?.ToString()??_penColor;await JS.InvokeVoidAsync("patternViewer.setTool",_penColor,_penSize,_tool=="eraser",_tool,_penOpacity);}
    async Task OnSizeChange(ChangeEventArgs e){if(int.TryParse(e.Value?.ToString(),out var v))_penSize=v;await JS.InvokeVoidAsync("patternViewer.setTool",_penColor,_penSize,_tool=="eraser",_tool,_penOpacity);}
    async Task SizeDown(){_penSize=Math.Max(1,_penSize-1);await JS.InvokeVoidAsync("patternViewer.setTool",_penColor,_penSize,_tool=="eraser",_tool,_penOpacity);}
    async Task SizeUp(){_penSize=Math.Min(40,_penSize+1);await JS.InvokeVoidAsync("patternViewer.setTool",_penColor,_penSize,_tool=="eraser",_tool,_penOpacity);}
    async Task OnOpacityChange(ChangeEventArgs e){if(int.TryParse(e.Value?.ToString(),out var v))_penOpacity=v;await JS.InvokeVoidAsync("patternViewer.setTool",_penColor,_penSize,_tool=="eraser",_tool,_penOpacity);}

    // ── 자 ──
    [JSInvokable] public void OnCanvasPointerDown(double x,double y,int pageNum){if(_tool=="ruler"){_isDrawingRuler=true;_rulerStartX=x;_rulerStartY=y;_rulerPage=pageNum;_previewW=0;_previewH=0;StateHasChanged();}}
    [JSInvokable] public void OnRulerTouchMove(double x,double y){if(_isDrawingRuler){_previewW=x-_rulerStartX;_previewH=y-_rulerStartY;StateHasChanged();}}
    [JSInvokable] public void OnRulerTouchEnd(){if(_isDrawingRuler&&Math.Abs(_previewW)>5)_rulers.Add(new RulerOverlay{X=(_previewW>0?_rulerStartX:_rulerStartX+_previewW)/_zoom,Y=(_previewH>0?_rulerStartY:_rulerStartY+_previewH)/_zoom,Width=Math.Abs(_previewW)/_zoom,Height=Math.Abs(_previewH)/_zoom,Page=_rulerPage});_isDrawingRuler=false;_=SaveRulersAsync();StateHasChanged();}

    async Task OnGlobalMouseMove(MouseEventArgs e)
    {
        // 카운터 위젯 드래그
        if(_cwDragging){_cwX=e.ClientX-_cwOffX;_cwY=e.ClientY-_cwOffY;StateHasChanged();return;}
        if(_isDrawingRuler||_draggingRuler!=null||_resizingRuler!=null)
        {
            var pg=_draggingRuler?.Page??_resizingRuler?.Page??_rulerPage;
            var rect=await JS.InvokeAsync<double[]>("patternViewer.getRect",pg);
            double curX=e.ClientX-rect[0];double curY=e.ClientY-rect[1];
            if(_isDrawingRuler){_previewW=curX-_rulerStartX;_previewH=curY-_rulerStartY;}
            else if(_draggingRuler!=null){_draggingRuler.X=(curX-_dragOffsetX)/_zoom;_draggingRuler.Y=(curY-_dragOffsetY)/_zoom;}
            else if(_resizingRuler!=null){_resizingRuler.Width=Math.Max(30/_zoom,curX/_zoom-_resizingRuler.X);_resizingRuler.Height=Math.Max(10/_zoom,curY/_zoom-_resizingRuler.Y);}
            StateHasChanged();
        }
    }
    async Task OnGlobalMouseUp(MouseEventArgs e)
    {
        _cwDragging=false;
        if(_isDrawingRuler&&Math.Abs(_previewW)>5){var r=new RulerOverlay{X=(_previewW>0?_rulerStartX:_rulerStartX+_previewW)/_zoom,Y=(_previewH>0?_rulerStartY:_rulerStartY+_previewH)/_zoom,Width=Math.Abs(_previewW)/_zoom,Height=Math.Abs(_previewH)/_zoom,Page=_rulerPage};_rulers.Add(r);_selectedRuler=r;_=SaveRulersAsync();}
        bool _hadRulerAction = _isDrawingRuler || _draggingRuler!=null || _resizingRuler!=null;
        _isDrawingRuler=false;_draggingRuler=null;_resizingRuler=null;
        if(_isDrawing&&_pdfLoaded&&(_tool=="pen"||_tool=="eraser"))await JS.InvokeVoidAsync("patternViewer.endDraw");
        _isDrawing=false;
        if(_hadRulerAction)_=SaveRulersAsync();
        StateHasChanged();
    }
    void DeselectRuler(){if(_tool=="ruler")_selectedRuler=null;}
    void OnRulerClick(RulerOverlay ruler)
    {
        if (_tool != "ruler") return;
        _selectedRuler = ruler; // 클릭 시 항상 선택 (토글 제거 → 이동하려다 해제되는 문제 방지)
    }
    async Task OnRulerMouseDown(MouseEventArgs e, RulerOverlay ruler)
    {
        if (_tool != "ruler") return;
        // 선택 + 팝업 위치 갱신
        _selectedRuler = ruler;
        _rulerPopupX = Math.Min(e.ClientX + 8, e.ClientX - 20);
        _rulerPopupY = Math.Max(e.ClientY - 60, 60);
        // 드래그 시작
        var rect = await JS.InvokeAsync<double[]>("patternViewer.getRect", ruler.Page);
        _draggingRuler = ruler;
        _dragOffsetX = (e.ClientX - rect[0]) - ruler.X * _zoom;
        _dragOffsetY = (e.ClientY - rect[1]) - ruler.Y * _zoom;
    }
    async Task OnRulerTouchStart(TouchEventArgs e,RulerOverlay ruler){if(_tool!="ruler")return;if(_selectedRuler!=ruler){_selectedRuler=ruler;StateHasChanged();return;}var rect=await JS.InvokeAsync<double[]>("patternViewer.getRect",ruler.Page);var t=e.Touches[0];_draggingRuler=ruler;_dragOffsetX=(t.ClientX-rect[0])-ruler.X*_zoom;_dragOffsetY=(t.ClientY-rect[1])-ruler.Y*_zoom;}
    void OnResizeMouseDown(MouseEventArgs e,RulerOverlay ruler)=>_resizingRuler=ruler;
    void OnResizeTouchStart(TouchEventArgs e,RulerOverlay ruler)=>_resizingRuler=ruler;

    async Task OnGlobalTouchMove(TouchEventArgs e)
    {
        if(_cwDragging&&e.Touches.Length>0){_cwX=e.Touches[0].ClientX-_cwOffX;_cwY=e.Touches[0].ClientY-_cwOffY;StateHasChanged();return;}
        if(_draggingRuler!=null||_resizingRuler!=null)
        {
            var pg=_draggingRuler?.Page??_resizingRuler?.Page??_currentPage;
            await JS.InvokeVoidAsync("patternViewer.preventScroll");
            var rect=await JS.InvokeAsync<double[]>("patternViewer.getRect",pg);
            var t=e.Touches[0];double curX=t.ClientX-rect[0];double curY=t.ClientY-rect[1];
            if(_draggingRuler!=null){_draggingRuler.X=curX-_dragOffsetX;_draggingRuler.Y=curY-_dragOffsetY;}
            else if(_resizingRuler!=null){_resizingRuler.Width=Math.Max(30,curX-_resizingRuler.X);_resizingRuler.Height=Math.Max(10,curY-_resizingRuler.Y);}
            StateHasChanged();
        }
    }
    Task OnGlobalTouchEnd(TouchEventArgs e){_cwDragging=false;bool _hadRuler=_draggingRuler!=null||_resizingRuler!=null;_draggingRuler=null;_resizingRuler=null;if(_hadRuler)_=SaveRulersAsync();StateHasChanged();return Task.CompletedTask;}

    void UpdateRulerColor(RulerOverlay r,ChangeEventArgs e)=>r.ColorRgb=HexToRgb(e.Value?.ToString()??"#ffffff");
    void ChangeRulerOpacity(RulerOverlay r,ChangeEventArgs e)=>r.Opacity=(double.TryParse(e.Value?.ToString(),out var v)?v:35)/100.0;
    string HexToRgb(string hex){hex=hex.TrimStart('#');return $"{Convert.ToInt32(hex[..2],16)},{Convert.ToInt32(hex[2..4],16)},{Convert.ToInt32(hex[4..6],16)}";}
    string RgbToHex(string rgb){var p=rgb.Split(',');return $"#{int.Parse(p[0]):X2}{int.Parse(p[1]):X2}{int.Parse(p[2]):X2}";}
    string GetCursor()=>_tool switch{"select"=>"default","pen"=>"crosshair","eraser"=>"cell",_=>"crosshair"};
    async Task GoBack()
    {
        // 뒤로가기 전 즉시 저장 (디바운스 기다리지 않고)
        await ForceSaveViewerStateAsync();
        Nav.NavigateTo("projects/" + ProjectId);
    }

    async Task ForceSaveViewerStateAsync()
    {
        if (_project == null || !_pdfLoaded) return;
        try
        {
            _saveCts?.Cancel(); // 진행 중인 디바운스 취소
            var pathsJson = await JS.InvokeAsync<string>("patternViewer.getPaths");
            _project.ViewerAnnotations = pathsJson;
            _project.ViewerRulers      = System.Text.Json.JsonSerializer.Serialize(_rulers);
            _project.ViewerLastZoom    = _zoom;
            _project.ViewerLastPage    = _currentPage;
            await SaveProject();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", "ForceSave error: " + ex.Message);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _saveCts?.Cancel();
        _saveCts?.Dispose();
        StopRefreshTimer();
        _dotNetRef?.Dispose();
        try { await JS.InvokeVoidAsync("patternViewer.dispose"); } catch { }
    }
    class RulerOverlay{public double X,Y,Width,Height,Opacity=0.35;public string ColorRgb="180,220,190";public int Page;public double SavedAtZoom=0;}
}
