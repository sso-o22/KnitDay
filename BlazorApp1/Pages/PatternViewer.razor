    {
        _saveCts?.Cancel();
        _saveCts?.Dispose();
        StopRefreshTimer();
        _dotNetRef?.Dispose();
        try { await JS.InvokeVoidAsync("patternViewer.dispose"); } catch { }
    }
    class RulerOverlay
    {
        public double X { get; set; }
