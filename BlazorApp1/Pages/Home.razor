@* =====================================================================
   Pages/Home.razor  —  홈 대시보드
   ===================================================================== *@
@page "/"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject AuthService Auth
@inject IJSRuntime JS
@implements IDisposable

<div class="page-header">
    <div>
        <h1 class="page-title">나의 뜨개 공간</h1>
        <p class="page-subtitle">오늘도 즐거운 뜨개질 하세요!</p>
    </div>
</div>

@* ── 로그인 배너 ── *@
@if (_authLoading)
{
    <div class="home-banner">
        <div style="font-size:0.85rem;color:var(--text-mid);">로그인 상태 확인 중...</div>
    </div>
}
else if (!Auth.IsLoggedIn)
{
    <div class="home-banner">
        <div>
            <div style="font-size:0.88rem;font-weight:600;color:var(--text-dark);">여러 기기에서 동기화하세요</div>
            <div style="font-size:0.78rem;color:var(--text-mid);margin-top:2px;">구글 로그인하면 데이터가 자동으로 백업돼요</div>
        </div>
        <button class="btn btn-primary" style="white-space:nowrap;font-size:0.82rem;padding:6px 14px;flex-shrink:0;" @onclick="SignIn">
            로그인
        </button>
    </div>
}

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else
{
    @* ── 요약 통계 카드 ── *@
    <div class="stats-grid">
        <a href="projects" class="home-stat-card" style="text-decoration:none;">
            <div class="home-stat-icon" style="background:var(--theme-pale);">
                <img src="icons/stack.svg" class="icon-line-card" style="width:22px;height:22px;" />
            </div>
            <div>
                <div class="home-stat-num" style="color:var(--theme-active);">@_inProgress</div>
                <div class="home-stat-label">문어발</div>
            </div>
        </a>
        <a href="finished" class="home-stat-card" style="text-decoration:none;">
            <div class="home-stat-icon" style="background:var(--theme-pale);">
                <img src="icons/t-shirt.svg" class="icon-line-card" style="width:22px;height:22px;" />
            </div>
            <div>
                <div class="home-stat-num" style="color:var(--theme-active);">@_finished</div>
                <div class="home-stat-label">완성작</div>
            </div>
        </a>
        <a href="wishlist" class="home-stat-card" style="text-decoration:none;">
            <div class="home-stat-icon" style="background:var(--theme-pale);">
                <img src="icons/shooting-star.svg" class="icon-line-card" style="width:22px;height:22px;" />
            </div>
            <div>
                <div class="home-stat-num" style="color:var(--theme-active);">@_wishlist</div>
                <div class="home-stat-label">위시리스트</div>
            </div>
        </a>
        <a href="yarns" class="home-stat-card" style="text-decoration:none;">
            <div class="home-stat-icon" style="background:var(--theme-pale);">
                <img src="icons/yarn.svg" class="icon-line-card" style="width:22px;height:22px;" />
            </div>
            <div>
                <div class="home-stat-num" style="color:var(--theme-active);">@_yarns</div>
                <div class="home-stat-label">실 창고</div>
            </div>
        </a>
        <a href="swatches" class="home-stat-card" style="text-decoration:none;">
            <div class="home-stat-icon" style="background:var(--theme-pale);">
                <img src="icons/swatches.svg" class="icon-line-card" style="width:22px;height:22px;" />
            </div>
            <div>
                <div class="home-stat-num" style="color:var(--theme-active);">@_swatches</div>
                <div class="home-stat-label">스와치</div>
            </div>
        </a>
        <a href="tools" class="home-stat-card" style="text-decoration:none;">
            <div class="home-stat-icon" style="background:var(--theme-pale);">
                <img src="icons/toolbox.svg" class="icon-line-card" style="width:22px;height:22px;" />
            </div>
            <div>
                <div class="home-stat-num" style="color:var(--theme-active);">@_tools</div>
                <div class="home-stat-label">도구</div>
            </div>
        </a>
    </div>


    @* ── 할 일 체크리스트 ── *@
    <h2 class="home-section-title">할 일</h2>
    <div class="card" style="padding:14px 16px; margin-bottom:20px;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
            <div style="display:flex; align-items:center; gap:6px;">
                <img src="icons/push-pin.svg" class="icon-line" style="width:14px;height:14px;" />
                <span style="font-size:0.82rem; font-weight:500; color:var(--text-dark);">할 일</span>
                @if (_todoItems.Count > 0)
                {
                    var done = _todoItems.Count(t => t.Done);
                    <span style="font-size:0.72rem; color:var(--text-light);">@done/@_todoItems.Count</span>
                }
            </div>
            <div style="display:flex; align-items:center; gap:4px;">
                @if (_todoEditMode)
                {
                    <button class="btn btn-primary btn-sm" style="font-size:0.72rem; padding:2px 8px;" @onclick="ExitTodoEditMode">완료</button>
                }
                else
                {
                    <button class="btn btn-ghost btn-sm" style="font-size:0.72rem; padding:2px 6px;" @onclick="EnterTodoEditMode"><img src="icons/pencil.svg" class="icon-line" style="width:14px;height:14px;" /> 수정</button>
                }
            </div>
        </div>

        @foreach (var item in _todoItems)
        {
            <div style="display:flex; align-items:center; gap:6px; padding:6px 0; border-bottom:1px solid var(--border);">
                <input type="checkbox" checked="@item.Done"
                       @onchange="async () => { item.Done = !item.Done; await SaveTodos(); }"
                       style="width:14px; height:14px; accent-color:#2a5a26; cursor:pointer; flex-shrink:0;" />
                @if (_todoEditMode)
                {
                    <input class="form-control" style="flex:1; font-size:0.78rem; padding:2px 6px; height:28px; min-height:unset; line-height:1.4;"
                           value="@item.Text"
                           @onchange="async e => { item.Text = e.Value?.ToString() ?? item.Text; await SaveTodos(); }" />
                    <button class="btn btn-danger btn-sm" style="padding:1px 4px; font-size:0.7rem;"
                            @onclick="async () => { _todoItems.Remove(item); await SaveTodos(); }">✕</button>
                }
                else
                {
                    <span style="flex:1; font-size:0.78rem; @(item.Done ? "text-decoration:line-through; color:var(--text-light);" : "color:var(--text-dark);")">@item.Text</span>
                }
            </div>
        }

        @if (_todoItems.Count > 0)
        {
            var done = _todoItems.Count(t => t.Done);
            var total = _todoItems.Count;
            <div style="height:4px; background:#e8e8e8; border-radius:2px; margin:8px 0 6px;">
                <div style="height:4px; background:#c8e6be; border-radius:2px; width:@(done * 100 / total)%;"></div>
            </div>
        }

        @if (_todoEditMode)
        {
            @if (_addingTodo)
            {
                <div style="display:flex; gap:4px; margin-top:6px;">
                    <input class="form-control" style="font-size:0.78rem; padding:4px 6px;"
                           @bind="_newTodoText" placeholder="할 일 입력" />
                    <button class="btn btn-primary btn-sm" style="padding:2px 6px;" @onclick="AddTodo">+</button>
                    <button class="btn btn-ghost btn-sm" style="padding:2px 6px;" @onclick="CancelAddTodo">✕</button>
                </div>
            }
            else
            {
                <button class="btn btn-ghost btn-sm" style="margin-top:6px; font-size:0.78rem;" @onclick="StartAddTodo">+ 항목 추가</button>
            }
        }
    </div>

    @* ── 진행중 프로젝트 ── *@
    @if (_recentProjects.Count > 0)
    {
        <h2 class="home-section-title">지금 뜨고 있어요</h2>
        <div class="grid-3">
            @foreach (var proj in _recentProjects)
            {
                var isOnHold     = proj.Status == ProjectStatus.일시중단;
                var statusText   = isOnHold ? "일시중단" : "진행중";
                var statusBg     = isOnHold ? "var(--ivory-mid)" : "var(--theme-pale)";
                var statusColor  = isOnHold ? "var(--text-mid)"  : "var(--theme-active)";

                <a href="projects/@proj.Id" class="card home-proj-card" style="text-decoration:none;display:block;">
                    @* 상단: 제목 + D-day *@
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:4px;">
                        <div class="card-title" style="margin-bottom:0;font-size:1rem;">@proj.Title</div>
                        @if (proj.EndDate.HasValue)
                        {
                            var days = (proj.EndDate.Value.Date - DateTime.Today).Days;
                            var (ddayText, ddayColor, ddayBg) = days switch
                            {
                                < 0   => ($"D+{-days}", "var(--text-light)", "var(--ivory-mid)"),
                                0     => ("D-Day",      "#c03030",            "#fff0f0"),
                                <= 7  => ($"D-{days}",  "#c03030",            "#fff0f0"),
                                _     => ($"D-{days}",  "var(--theme-active)","var(--theme-pale)")
                            };
                            <span style="font-size:0.72rem;font-weight:700;color:@ddayColor;
                                         background:@ddayBg;border-radius:20px;
                                         padding:2px 8px;white-space:nowrap;flex-shrink:0;">@ddayText</span>
                        }
                    </div>

                    @* 도안명 *@
                    @if (!string.IsNullOrEmpty(proj.PatternName))
                    {
                        <div style="font-size:0.8rem;color:var(--text-mid);margin-bottom:10px;">@proj.PatternName</div>
                    }

                    @* 진행률 바 (시작일~마감일 기반, 둘 다 없으면 숨김) *@
                    @if (proj.StartDate.HasValue && proj.EndDate.HasValue)
                    {
                        var total   = (proj.EndDate.Value - proj.StartDate.Value).TotalDays;
                        var elapsed = (DateTime.Today    - proj.StartDate.Value).TotalDays;
                        var pct     = total > 0 ? Math.Clamp(elapsed / total * 100, 0, 100) : 0;
                        <div style="background:var(--ivory-mid);border-radius:4px;height:4px;margin-bottom:10px;overflow:hidden;">
                            <div style="height:4px;border-radius:4px;width:@(pct.ToString("F0"))%;background:var(--theme-active);transition:width 0.3s;"></div>
                        </div>
                    }

                    @* 하단: 시작일 + 상태 칩 *@
                    <div style="display:flex;align-items:center;justify-content:space-between;">
                        <span style="font-size:0.78rem;color:var(--text-light);">
                            @(proj.StartDate.HasValue ? proj.StartDate.Value.ToString("yyyy.MM.dd") + " 시작" : "")
                        </span>
                        <span style="font-size:0.72rem;font-weight:600;
                                     color:@statusColor;background:@statusBg;
                                     border-radius:20px;padding:2px 9px;">@statusText</span>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="card" style="text-align:center;padding:40px;">
            <div style="margin-bottom:16px;opacity:0.35;">
                <img src="icons/stack.svg" class="icon-line-card" style="width:48px;height:48px;" />
            </div>
            <p style="color:var(--text-mid);margin-bottom:16px;">아직 진행중인 프로젝트가 없어요.</p>
            <a href="projects" class="btn btn-primary">첫 문어발 만들기</a>
        </div>
    }
}

<style>
    /* ── 로그인 배너 ── */
    .home-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 16px;
        border-radius: var(--radius);
        margin-bottom: 20px;
        background: var(--theme-pale);
        border: 1.5px solid var(--theme-mid);
    }

    /* ── 통계 카드 (아이콘 + 숫자 가로 배치) ── */
    .home-stat-card {
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 2px 8px var(--shadow);
        transition: box-shadow 0.18s ease, transform 0.18s ease;
    }
    .home-stat-card:hover {
        box-shadow: 0 6px 20px var(--shadow-md);
        transform: translateY(-2px);
    }
    .home-stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .home-stat-num {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1;
    }
    .home-stat-label {
        font-size: 0.78rem;
        color: var(--text-mid);
        margin-top: 3px;
    }

    /* ── 섹션 타이틀 ── */
    .home-section-title {
        font-family: 'DM Sans', 'Noto Sans KR', sans-serif;
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-mid);
        margin: 24px 0 12px;
        letter-spacing: 0.02em;
    }

    /* ── 프로젝트 카드 ── */
    .home-proj-card:hover {
        text-decoration: none !important;
    }
</style>

@code {
    async Task SignIn() => await Auth.SignInWithGoogleAsync();


    // ── 할 일 체크리스트 ──
    class TodoItem
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public string Text { get; set; } = "";
        public bool Done { get; set; } = false;
    }
    List<TodoItem> _todoItems = new();
    bool _checklistExpanded = true;
    bool _todoEditMode = false;
    bool _addingTodo = false;
    string _newTodoText = "";
    Guid? _editingTodoId = null;
    string _editingTodoText = "";

    async Task LoadTodos()
    {
        var json = await JS.InvokeAsync<string?>("localStorage.getItem", "knitlog_todos");
        if (!string.IsNullOrEmpty(json))
            try { _todoItems = System.Text.Json.JsonSerializer.Deserialize<List<TodoItem>>(json) ?? new(); } catch { }
    }
    async Task SaveTodos()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "knitlog_todos",
            System.Text.Json.JsonSerializer.Serialize(_todoItems));
        StateHasChanged();
    }
    async Task AddTodo()
    {
        if (string.IsNullOrWhiteSpace(_newTodoText)) return;
        _todoItems.Add(new TodoItem { Text = _newTodoText.Trim() });
        _newTodoText = "";
        _addingTodo = false;
        await SaveTodos();
    }
    async Task SaveTodoLabel(TodoItem item)
    {
        if (!string.IsNullOrWhiteSpace(_editingTodoText))
            item.Text = _editingTodoText.Trim();
        _editingTodoId = null;
        await SaveTodos();
    }

    void EnterTodoEditMode() { _todoEditMode = true; _editingTodoId = null; }
    void ExitTodoEditMode() { _todoEditMode = false; _editingTodoId = null; _addingTodo = false; }
    void CancelTodoEdit() { _editingTodoId = null; _editingTodoText = ""; }
    void StartAddTodo() { _addingTodo = true; }
    void CancelAddTodo() { _addingTodo = false; _newTodoText = ""; }

    // 인증 상태 변경 콜백 — 로그인 완료 후 데이터 재로딩
    async void OnAuthChanged()
    {
        _authLoading = false;
        // 로그인 상태이면 데이터를 다시 불러온다
        if (Auth.IsLoggedIn)
        {
            await LoadDataAsync();
        }
        await InvokeAsync(StateHasChanged);
    }

    bool _loading = true;
    bool _authLoading = true; // Firebase 세션 복원 대기 중

    int _inProgress, _finished, _wishlist, _yarns, _swatches, _tools;
    List<KnitProject> _recentProjects = new();

    protected override async Task OnInitializedAsync()
    {
        Auth.OnAuthChanged += OnAuthChanged;
        await LoadTodos();
        // Firebase 초기화 완료 대기 (최대 6초)
        if (!Auth.IsInitialized)
        {
            var waited = 0;
            while (!Auth.IsInitialized && waited < 60) { await Task.Delay(100); waited++; }
        }
        _authLoading = false;
        await LoadDataAsync();
    }

    // 데이터 로딩 로직을 별도 메서드로 분리
    async Task LoadDataAsync()
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);

        var projects = await Storage.GetProjectsAsync();
        _inProgress = projects.Count(p => p.Status == ProjectStatus.진행중 || p.Status == ProjectStatus.일시중단);
        _finished   = projects.Count(p => p.Status == ProjectStatus.완료);
        _wishlist   = projects.Count(p => p.Status == ProjectStatus.위시리스트);
        _recentProjects = projects
            .Where(p => p.Status == ProjectStatus.진행중 || p.Status == ProjectStatus.일시중단)
            .OrderByDescending(p => p.StartDate)
            .Take(3)
            .ToList();

        var yarns = await Storage.GetYarnsAsync();
        _yarns = yarns.Count;
        var swatches = await Storage.GetSwatchesAsync();
        _swatches = swatches.Count;
        var tools = await Storage.GetToolsAsync();
        _tools = tools.Count;

        _loading = false;
    }

    public void Dispose()
    {
        Auth.OnAuthChanged -= OnAuthChanged;
    }
}
