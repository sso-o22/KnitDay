@* =====================================================================
   Pages/Home.razor  —  홈 대시보드
   ===================================================================== *@
@page "/"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject AuthService Auth
@implements IDisposable

<div class="page-header">
    <div>
        <h1 class="page-title">나의 뜨개 공간</h1>
        <p class="page-subtitle">오늘도 즐거운 뜨개질 하세요!</p>
    </div>
</div>

@if (_authLoading)
{
    <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;
                margin-bottom:16px;background:var(--theme-pale);border:1.5px solid var(--theme-mid);">
        <span style="font-size:1.1rem;">⏳</span>
        <div style="font-size:0.85rem;color:var(--text-mid);">로그인 상태 확인 중...</div>
    </div>
}
else if (!Auth.IsLoggedIn)
{
    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;
                padding:12px 16px;border-radius:12px;margin-bottom:16px;
                background:var(--theme-pale);border:1.5px solid var(--theme-mid);">
        <div style="display:flex;align-items:center;gap:10px;">
            <span style="font-size:1.3rem;">☁️</span>
            <div>
                <div style="font-size:0.88rem;font-weight:600;color:var(--text-dark);">여러 기기에서 동기화하세요</div>
                <div style="font-size:0.78rem;color:var(--text-mid);">구글 로그인하면 데이터가 자동으로 백업돼요</div>
            </div>
        </div>
        <button class="btn btn-primary" style="white-space:nowrap;font-size:0.82rem;padding:6px 14px;" @onclick="SignIn">
            로그인
        </button>
    </div>
}

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else
{
    <!-- 요약 카드 4개 -->
    <div class="stats-grid">
        <a href="projects" class="card" style="text-decoration:none; text-align:center;">
            <div style="margin-bottom:8px;"><img src="icons/Octopus.svg" style="width:52px;height:52px;" /></div>
            <div style="font-size:2rem; font-weight:700; color:#8a6a08;">@_inProgress</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">문어발</div>
        </a>
        <a href="finished" class="card" style="text-decoration:none; text-align:center;">
            <div style="margin-bottom:8px;"><img src="icons/Done.svg" style="width:52px;height:52px;" /></div>
            <div style="font-size:2rem; font-weight:700; color:#267848;">@_finished</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">완성작</div>
        </a>
        <a href="wishlist" class="card" style="text-decoration:none; text-align:center;">
            <div style="margin-bottom:8px;"><img src="icons/Wish.svg" style="width:52px;height:52px;" /></div>
            <div style="font-size:2rem; font-weight:700; color:#4e3290;">@_wishlist</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">위시리스트</div>
        </a>
        <a href="yarns" class="card" style="text-decoration:none; text-align:center;">
            <div style="margin-bottom:8px;"><img src="icons/Yarn_ball_blue.svg" style="width:52px;height:52px;" /></div>
            <div style="font-size:2rem; font-weight:700; color:var(--text-dark);">@_yarns</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">실 창고</div>
        </a>
        <a href="swatches" class="card" style="text-decoration:none; text-align:center;">
            <div style="margin-bottom:8px;"><img src="icons/Swatch.svg" style="width:52px;height:52px;" /></div>
            <div style="font-size:2rem; font-weight:700; color:var(--text-dark);">@_swatches</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">스와치</div>
        </a>
        <a href="tools" class="card" style="text-decoration:none; text-align:center;">
            <div style="margin-bottom:8px;"><img src="icons/Tool.svg" style="width:52px;height:52px;" /></div>
            <div style="font-size:2rem; font-weight:700; color:var(--text-dark);">@_tools</div>
            <div style="color:var(--text-mid); font-size:0.88rem;">도구</div>
        </a>
    </div>

    <!-- 진행중인 프로젝트 미리보기 -->
    @if (_recentProjects.Count > 0)
    {
        <h2 style="font-family:'DM Sans','Noto Sans KR',sans-serif; font-weight:600; color:var(--text-dark); margin-bottom:16px;">지금 뜨고 있어요</h2>
        <div class="grid-3">
            @foreach (var proj in _recentProjects)
            {
                <div class="card">
                    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:8px;">
                        <div class="card-title" style="margin-bottom:0;">@proj.Title</div>
                        @if (proj.EndDate.HasValue)
                        {
                            var days = (proj.EndDate.Value.Date - DateTime.Today).Days;
                            var (ddayText, ddayColor) = days switch
                            {
                                < 0  => ($"D+{-days}", "#aaa"),
                                0    => ("D-Day", "#e05050"),
                                <= 7 => ($"D-{days}", "#e05050"),
                                _    => ($"D-{days}", "var(--theme-active)")
                            };
                            <span style="font-size:0.75rem; font-weight:700; color:@ddayColor;
                                         background:var(--theme-pale); border-radius:20px;
                                         padding:2px 8px; white-space:nowrap; flex-shrink:0;">@ddayText</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(proj.PatternName))
                    {
                        <div style="font-size:0.82rem; color:var(--text-mid); margin-bottom:8px; margin-top:4px;">도안: @proj.PatternName</div>
                    }
                    @if (proj.StartDate.HasValue)
                    {
                        <div style="font-size:0.82rem; color:var(--text-light);">시작일: @proj.StartDate.Value.ToString("yyyy.MM.dd")</div>
                    }
                    <div class="mt-2">
                        <a href="projects/@proj.Id" class="btn btn-secondary btn-sm">자세히 보기</a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card" style="text-align:center; padding:40px;">
            <div style="font-size:2.5rem; margin-bottom:12px;">📆</div>
            <p style="color:var(--text-mid); margin-bottom:16px;">아직 진행중인 프로젝트가 없어요.</p>
            <a href="projects" class="btn btn-primary">첫 문어발 만들기</a>
        </div>
    }
}

@code {
    async Task SignIn() => await Auth.SignInWithGoogleAsync();

    void OnAuthChanged()
    {
        _authLoading = false;
        InvokeAsync(StateHasChanged);
    }

    bool _loading = true;
    bool _authLoading = true; // Firebase 세션 복원 대기 중

    int _inProgress, _finished, _wishlist, _yarns, _swatches, _tools;
    List<KnitProject> _recentProjects = new();

    protected override async Task OnInitializedAsync()
    {
        Auth.OnAuthChanged += OnAuthChanged;
        // Firebase 초기화 완료 대기 (최대 6초)
        if (!Auth.IsInitialized)
        {
            var waited = 0;
            while (!Auth.IsInitialized && waited < 60) { await Task.Delay(100); waited++; }
        }
        _authLoading = false;
        var projects = await Storage.GetProjectsAsync();
        _inProgress = projects.Count(p => p.Status == ProjectStatus.진행중 || p.Status == ProjectStatus.일시중단);
        _finished   = projects.Count(p => p.Status == ProjectStatus.완료);
        _wishlist   = projects.Count(p => p.Status == ProjectStatus.위시리스트);
        _recentProjects = projects
            .Where(p => p.Status == ProjectStatus.진행중 || p.Status == ProjectStatus.일시중단)
            .OrderByDescending(p => p.StartDate)
            .Take(3)
            .ToList();

        var yarns = await Storage.GetYarnsAsync();
        _yarns = yarns.Count;
        var swatches = await Storage.GetSwatchesAsync();
        _swatches = swatches.Count;
        var tools = await Storage.GetToolsAsync();
        _tools = tools.Count;

        _loading = false;
    }

    public void Dispose()
    {
        Auth.OnAuthChanged -= OnAuthChanged;
    }
}
