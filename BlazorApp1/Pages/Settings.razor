@page "/settings"
@inject HttpClient Http
@inject IJSRuntime JS
@inject AuthService Auth
@inject StorageService Storage

<div class="page-header">
    <div>
        <h1 class="page-title"><img src="icons/Setting.svg" style="width:44px;height:44px;" />설정</h1>
        <p class="page-subtitle">앱 환경을 설정해요</p>
    </div>
</div>

<div style="max-width:480px; display:flex; flex-direction:column; gap:16px;">

    <!-- 계정 -->
    <div class="card">
        <div class="card-title" style="margin-bottom:4px;">👤 계정</div>
        @if (Auth.IsLoggedIn)
        {
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
                @if (!string.IsNullOrEmpty(Auth.CurrentUser?.PhotoURL))
                {
                    <img src="@Auth.CurrentUser.PhotoURL" style="width:44px;height:44px;border-radius:50%;object-fit:cover;" />
                }
                <div>
                    <div style="font-weight:600;">@Auth.CurrentUser?.DisplayName</div>
                    <div style="font-size:0.82rem;color:var(--text-mid);">@Auth.CurrentUser?.Email</div>
                    <div style="font-size:0.75rem;color:var(--text-light);margin-top:2px;">☁️ Firebase 동기화 중</div>
                </div>
            </div>
            <button class="btn btn-secondary" @onclick="SignOut">🚪 로그아웃</button>
        }
        else
        {
            <p style="font-size:0.85rem;color:var(--text-mid);margin-bottom:12px;">
                구글 계정으로 로그인하면 여러 기기에서 데이터를 동기화할 수 있어요.
            </p>
            <button class="btn btn-primary" @onclick="SignIn">🔑 구글 로그인</button>
        }
    </div>

    <!-- 테마 -->
    <div class="card">
        <div class="card-title" style="margin-bottom:4px;">🎨 테마 색상</div>
        @if (_isDark)
        {
            <p style="font-size:0.82rem; color:var(--text-mid); margin-bottom:12px;">다크 모드에서는 흑백 테마만 적용돼요</p>
        }
        else
        {
            <div style="margin-bottom:12px;"></div>
        }
        <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:12px;">
            @foreach (var t in _themes)
            {
                var isDisabled = _isDark && t.Id != "mono";
                <button class="settings-theme-btn @((!_isDark && _currentTheme == t.Id) || (_isDark && t.Id == "mono") ? "active" : "")"
                        style="@(isDisabled ? "opacity:0.3; cursor:not-allowed;" : "")"
                        @onclick="async () => { if (!isDisabled) await SetTheme(t.Id); }">
                    <div class="settings-theme-dot" style="background:@t.DotColor;"></div>
                    <span class="settings-theme-name">@t.Name</span>
                </button>
            }
        </div>
    </div>

    <!-- 다크모드 -->
    <div class="card">
        <div style="display:flex; align-items:center; justify-content:space-between;">
            <div>
                <div class="card-title" style="margin-bottom:4px;">
                    @if (_isDark)
                    {
                        <img src="icons/Dark.svg" style="width:20px;height:20px;vertical-align:middle;margin-right:4px;" /><span>다크 모드</span>
                    }
                    else
                    {
                        <img src="icons/Light.svg" style="width:20px;height:20px;vertical-align:middle;margin-right:4px;" /><span>라이트 모드</span>
                    }
                </div>
                <p style="font-size:0.85rem; color:var(--text-mid);">@(_isDark ? "배경/글자가 반전되고 흑백 테마로 표시돼요" : "테마 색상이 적용된 라이트 모드예요")</p>
            </div>
            <button class="dark-toggle-btn @(_isDark ? "on" : "")" @onclick="ToggleDark">
                <div class="dark-toggle-thumb"></div>
            </button>
        </div>
    </div>

    <!-- 데이터 -->
    <div class="card">
        <div class="card-title" style="margin-bottom:4px;">💾 데이터</div>
        <p style="font-size:0.85rem; color:var(--text-mid); margin-bottom:8px;">
            프로젝트, 실 창고, 도구, 스와치 데이터가 저장돼요.
        </p>
        <div style="font-size:0.82rem; padding:10px 12px; border-radius:8px; margin-bottom:16px;
                    background:var(--theme-pale); color:var(--text-mid); line-height:1.6;">
            ⚠️ <b>도안 파일과 필기 내용은 로그인만으로 다른 기기에 연동되지 않아요.</b><br>
            다른 기기로 옮기려면 <b>데이터 내보내기</b>로 백업 파일을 만들고,<br>
            새 기기에서 <b>데이터 불러오기</b>로 복원해주세요.
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <button class="btn btn-secondary" @onclick="ExportData">📤 데이터 내보내기</button>
            <button class="btn btn-secondary" @onclick="ImportDataClick">📥 데이터 불러오기</button>
        </div>
        <InputFile id="import-file-input" OnChange="ImportData" accept=".json" style="display:none;" />
        @if (_importMsg != "")
        {
            <div style="margin-top:10px; padding:10px 14px; border-radius:8px; font-size:0.88rem;"
                 class="@(_importError ? "import-msg-error" : "import-msg-ok")">
                @_importMsg
            </div>
        }
    </div>

    <!-- 버전 정보 -->
    <div class="card">
        <div class="card-title" style="margin-bottom:12px;">🆕 앱 정보</div>
        @if (_versionInfo != null)
        {
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
                <span style="font-size:0.92rem; font-weight:600; color:var(--text-dark);">니트로그 v@(_versionInfo.Version)</span>
                <span style="font-size:0.78rem; color:var(--text-light);">@(_versionInfo.Date)</span>
            </div>
            <div style="font-size:0.82rem; color:var(--text-mid); margin-bottom:6px;">이번 업데이트</div>
            <ul style="margin:0; padding-left:18px; display:flex; flex-direction:column; gap:4px;">
                @foreach (var item in _versionInfo.Updates)
                {
                    <li style="font-size:0.85rem; color:var(--text-dark);">@item</li>
                }
            </ul>
        }
        else
        {
            <div style="font-size:0.85rem; color:var(--text-light);">버전 정보를 불러오는 중...</div>
        }
    </div>

    <!-- 디버그 모드 -->
    <div class="card">
        <div style="display:flex; align-items:center; justify-content:space-between;">
            <div>
                <div class="card-title" style="margin-bottom:4px;">🐛 디버그 모드</div>
                <p style="font-size:0.85rem; color:var(--text-mid);">화면 하단에 콘솔 로그 패널을 표시해요</p>
            </div>
            <button class="dark-toggle-btn @(_debugMode ? "on" : "")" @onclick="ToggleDebug">
                <div class="dark-toggle-thumb"></div>
            </button>
        </div>
    </div>

</div>

@if (_showImportModal)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;padding:20px;box-sizing:border-box;">
        <div class="modal" style="max-width:360px;width:100%;text-align:center;max-height:80vh;overflow-y:auto;" @onclick:stopPropagation="true">
            <div style="font-size:2rem;margin-bottom:12px;">📥</div>
            <div style="font-size:1rem;font-weight:600;margin-bottom:8px;color:var(--text-dark);">어떻게 불러올까요?</div>
            <div style="font-size:0.85rem;color:var(--text-mid);margin-bottom:20px;line-height:1.6;">
                <b>덮어쓰기</b>는 현재 데이터를 파일 내용으로 완전히 교체해요.<br/>
                <b>합치기</b>는 현재 데이터를 유지하면서 파일 내용을 추가해요.<br/>
                <span style="color:#c05050;">중복 항목은 파일 쪽이 우선돼요.</span>
            </div>
            <div style="display:flex;gap:10px;justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => { _showImportModal = false; _importDoc = null; }">취소</button>
                <button class="btn btn-secondary" @onclick="() => ExecuteImport(true)">합치기</button>
                <button class="btn btn-primary" @onclick="() => ExecuteImport(false)">덮어쓰기</button>
            </div>
        </div>
    </div>
}

<style>
    .import-msg-ok    { background: var(--theme-pale); color: var(--text-dark); }
    .import-msg-error { background: #ffe0e0; color: #c00; }
</style>

@code {
    class VersionInfo
    {
        [System.Text.Json.Serialization.JsonPropertyName("version")]
        public string Version { get; set; } = "";
        [System.Text.Json.Serialization.JsonPropertyName("date")]
        public string Date { get; set; } = "";
        [System.Text.Json.Serialization.JsonPropertyName("updates")]
        public List<string> Updates { get; set; } = new();
    }

    VersionInfo? _versionInfo;

    record ThemeOption(string Id, string Name, string DotColor);

    readonly List<ThemeOption> _themes = new()
    {
        new("green",  "연두", "#c8e6be"),
        new("yellow", "노랑", "#fffdc7"),
        new("sky",    "하늘", "#d3f4ff"),
        new("pink",   "분홍", "#ffe7e7"),
        new("purple", "보라", "#e9e1ff"),
        new("mono",   "흑백", "#e0e0e0"),
    };

    string _currentTheme = "mono";
    bool _isDark = false;
    bool _debugMode = false;
    string _importMsg = "";
    bool _importError = false;
    bool _showImportModal = false;
    System.Text.Json.JsonDocument? _importDoc = null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "knitlog_theme");
            if (!string.IsNullOrEmpty(saved)) _currentTheme = saved;
            var dark = await JS.InvokeAsync<string?>("localStorage.getItem", "knitlog_dark");
            _isDark = dark == "true";
            var debug = await JS.InvokeAsync<string?>("localStorage.getItem", "knitlog_debug");
            _debugMode = debug == "1";
            try
            {
                _versionInfo = await Http.GetFromJsonAsync<VersionInfo>("version.json");
            }
            catch { }
            StateHasChanged();
        }
    }

    async Task SetTheme(string themeId)
    {
        _currentTheme = themeId;
        await JS.InvokeVoidAsync("localStorage.setItem", "knitlog_theme", themeId);
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{themeId}')");
    }

    async Task ToggleDark()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("localStorage.setItem", "knitlog_dark", _isDark.ToString().ToLower());
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-dark', '{_isDark.ToString().ToLower()}')");
    }

    async Task ToggleDebug()
    {
        _debugMode = !_debugMode;
        await JS.InvokeVoidAsync("localStorage.setItem", "knitlog_debug", _debugMode ? "1" : "0");
        // 즉시 디버그 패널 적용 (페이지 새로고침 없이)
        if (_debugMode)
            await JS.InvokeVoidAsync("eval", "localStorage.setItem('knitlog_debug','1'); location.reload();");
        else
            await JS.InvokeVoidAsync("eval", "localStorage.setItem('knitlog_debug','0'); location.reload();");
    }

    void ImportDataClick()
    {
        _ = JS.InvokeVoidAsync("eval", "document.getElementById('import-file-input').click()");
    }

    async Task ImportData(InputFileChangeEventArgs e)
    {
        _importMsg = "";
        _importError = false;
        try
        {
            using var stream = e.File.OpenReadStream(50 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var json = System.Text.Encoding.UTF8.GetString(ms.ToArray()).Trim();
            if (string.IsNullOrEmpty(json))
            {
                _importMsg = "❌ 파일이 비어있어요.";
                _importError = true;
                StateHasChanged();
                return;
            }
            // 파일 파싱만 해두고 팝업으로 선택 받기
            _importDoc = System.Text.Json.JsonDocument.Parse(json);
            _showImportModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _importMsg = "❌ 오류: " + ex.Message;
            _importError = true;
            StateHasChanged();
        }
    }

    async Task ExecuteImport(bool merge)
    {
        _showImportModal = false;
        if (_importDoc == null) return;
        try
        {
            var keys = new[] { "knittracker_projects", "knittracker_yarns", "knittracker_tools", "knittracker_swatches", "knitlog_todos" };
            int count = 0;

            if (merge)
            {
                // ── 합치기: Id 기준 merge, 파일 쪽 우선 ──
                foreach (var key in keys)
                {
                    if (!_importDoc.RootElement.TryGetProperty(key, out var fileVal)) continue;

                    var localJson = await JS.InvokeAsync<string?>("localStorage.getItem", key);
                    var localArr  = string.IsNullOrEmpty(localJson)
                        ? new List<System.Text.Json.JsonElement>()
                        : System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(localJson) ?? new();
                    var fileArr   = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(fileVal.GetRawText()) ?? new();

                    // Id 기준 merge (파일 우선)
                    var merged = new Dictionary<string, System.Text.Json.JsonElement>();
                    foreach (var item in localArr)
                    {
                        var id = GetItemId(item);
                        if (id != null) merged[id] = item;
                    }
                    foreach (var item in fileArr)
                    {
                        var id = GetItemId(item);
                        if (id != null) merged[id] = item;
                        else merged[Guid.NewGuid().ToString()] = item;
                    }

                    var mergedJson = System.Text.Json.JsonSerializer.Serialize(merged.Values.ToList());
                    await JS.InvokeVoidAsync("localStorage.setItem", key, mergedJson);
                    count++;
                }
            }
            else
            {
                // ── 덮어쓰기 ──
                foreach (var key in keys)
                {
                    if (_importDoc.RootElement.TryGetProperty(key, out var val))
                    {
                        await JS.InvokeVoidAsync("localStorage.setItem", key, val.GetRawText());
                        count++;
                    }
                }
            }

            // PDF 복원 (공통)
            if (_importDoc.RootElement.TryGetProperty("knitlog_pdfs", out var pdfs))
            {
                try
                {
                    var ok = await JS.InvokeAsync<bool>("patternViewer.importAllPdfs", pdfs.GetRawText());
                    if (ok) count++;
                }
                catch { }
            }

            _importMsg = $"✅ {(merge ? "합치기" : "덮어쓰기")} 완료! ({count}가지 데이터) 앱을 다시 시작하면 반영돼요.";
            try { await Storage.PushLocalToFirebaseAsync(); } catch { }
        }
        catch (Exception ex)
        {
            _importMsg = "❌ 오류: " + ex.Message;
            _importError = true;
        }
        _importDoc = null;
        StateHasChanged();
    }

    static string? GetItemId(System.Text.Json.JsonElement el)
    {
        foreach (var key in new[] { "Id", "id" })
            if (el.TryGetProperty(key, out var v))
                return v.ValueKind == System.Text.Json.JsonValueKind.String ? v.GetString() : v.ToString();
        return null;
    }

    async Task SignIn() => await Auth.SignInWithGoogleAsync();
    async Task SignOut() { await Auth.SignOutAsync(); StateHasChanged(); }



    async Task ExportData()
    {
        // localStorage 데이터
        await JS.InvokeVoidAsync("eval", @"
            const keys = ['knittracker_projects','knittracker_yarns','knittracker_tools','knittracker_swatches'];
            const data = {};
            keys.forEach(k => { const v = localStorage.getItem(k); if(v) data[k] = JSON.parse(v); });
            const todos = localStorage.getItem('knitlog_todos');
            if (todos) data['knitlog_todos'] = JSON.parse(todos);
            data.exportedAt = new Date().toISOString();
            window._exportData = data;
        ");
        // IndexedDB PDF 데이터 포함
        try
        {
            var pdfJson = await JS.InvokeAsync<string>("patternViewer.exportAllPdfs");
            if (!string.IsNullOrEmpty(pdfJson) && pdfJson != "{}")
            {
                // PDF JSON을 문자열로 그대로 저장 (이중 직렬화 방지)
                await JS.InvokeVoidAsync("eval",
                    $"try{{window._exportData.knitlog_pdfs=JSON.parse({System.Text.Json.JsonSerializer.Serialize(pdfJson)})}}catch(e){{}}");
            }
        }
        catch { }
        await JS.InvokeVoidAsync("eval", @"
            const blob = new Blob([JSON.stringify(window._exportData, null, 2)], {type:'application/json'});
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'knitlog_backup_' + new Date().toISOString().slice(0,10) + '.json';
            a.click();
            delete window._exportData;
        ");
    }
}
