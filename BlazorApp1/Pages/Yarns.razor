@* =====================================================================
   Pages/Yarns.razor  —  실 창고
   ===================================================================== *@
@page "/yarns"
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject IJSRuntime JS

<div class="page-header">
    <div>
        <h1 class="page-title"><img src="icons/yarn.svg" class="icon-line" style="width:36px;height:36px;" />실 창고</h1>
        <p class="page-subtitle">보유중인 실 목록</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal" style="display:inline-flex;align-items:center;gap:5px;"><img src="icons/plus.svg" class="icon-line" style="width:14px;height:14px;flex-shrink:0;" />실 추가</button>
</div>

@if (_loading)
{
    <div class="loading">불러오는 중...</div>
}
else if (_yarns.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon"><img src="icons/yarn.svg" class="icon-line" style="width:48px;height:48px;" /></div>
        <p>보유한 실이 없어요.<br/>실 정보를 추가해 보세요!</p>
    </div>
}
else
{
    <!-- 검색 -->
    <div class="form-group" style="max-width:320px; margin-bottom:12px;">
        <input class="form-control" @bind-value="_searchText" @bind-value:event="oninput"
               placeholder="실 이름, 브랜드, 색상으로 검색..." />
    </div>

    <!-- 필터 -->
    <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:20px;">
        @foreach (var (label, val) in new[]{("전체","all"),("사용 중","linked"),("미사용","unlinked"),("부족","low"),("소진","empty")})
        {
            <button class="btn btn-sm @(_filter==val?"btn-primary":"btn-ghost")"
                    @onclick='async ()=>{ _filter=val; await JS.InvokeVoidAsync("localStorage.setItem", "yarn_filter", val); }'>@label</button>
        }
    </div>

    <div class="grid-3">
        @foreach (var yarn in FilteredYarns)
        {
            <div class="card">
                <div class="flex-between mb-1">
                    <div style="display:flex; align-items:center; gap:8px;">
                        <span class="color-dot" style="background:@yarn.ColorCode;"></span>
                        <div class="card-title" style="margin-bottom:0;">@yarn.Name</div>
                    </div>
                    @{
                        decimal _used = _usedQty.TryGetValue(yarn.Id, out var _u) ? _u : 0;
                        decimal _remain = yarn.Quantity - _used;
                        string _qtyUnit = yarn.YarnType == YarnType.콘사 ? "콘" : "볼";
                    }
                    @if (yarn.Quantity > 0)
                    {
                        @if (_used > 0)
                        {
                            @if (yarn.YarnType == YarnType.콘사 && yarn.WeightGram > 0)
                            {
                                <span class="badge" style="background:var(--theme-mid);color:var(--text-dark);font-size:0.75rem;">
                                    @((yarn.WeightGram * _remain).ToString("G29"))g / @((yarn.WeightGram * yarn.Quantity).ToString("G29"))g
                                </span>
                            }
                            else
                            {
                                <span class="badge" style="background:var(--theme-mid);color:var(--text-dark);font-size:0.75rem;">
                                    @(_remain.ToString("G29")) / @(yarn.Quantity.ToString("G29")) @_qtyUnit
                                </span>
                            }
                        }
                        else
                        {
                            @if (yarn.YarnType == YarnType.콘사 && yarn.WeightGram > 0)
                            {
                                <span class="badge badge-done">@((yarn.WeightGram * yarn.Quantity).ToString("G29"))g</span>
                            }
                            else
                            {
                                <span class="badge badge-done">x @(yarn.Quantity.ToString("G29")) @_qtyUnit</span>
                            }
                        }
                    }
                </div>

                @if (!string.IsNullOrEmpty(yarn.Brand))
                {
                    <div style="font-size:0.82rem; color:var(--text-mid);">@yarn.Brand</div>
                }
                @* 카드에서 워스티드(굵기 정보) 제거 - YarnType과 색상만 표시 *@
                <div style="font-size:0.82rem; color:var(--text-mid);">@yarn.Color · @yarn.YarnType</div>

                @if (!string.IsNullOrEmpty(yarn.Material))
                {
                    <div style="font-size:0.8rem; color:var(--text-light);">@yarn.Material</div>
                }
                @{
                    // 콘사인 경우 콘당 단위, 그 외 볼당 단위
                    bool isCone = yarn.YarnType == YarnType.콘사;
                    string weightUnit = isCone ? "g/콘" : "g/볼";
                    string lengthUnit = isCone ? "m/콘" : "m/볼";
                    // 총 보유 길이 계산
                    decimal totalLength = yarn.LengthMeter * yarn.Quantity;
                }
                <div style="display:flex; gap:12px; font-size:0.78rem; color:var(--text-light); margin:6px 0 2px;">
                    @if (yarn.Ply > 0) { <span>@(yarn.Ply)합</span> }
                    @if (yarn.WeightGram > 0) { <span>@yarn.WeightGram @weightUnit</span> }
                    @if (yarn.LengthMeter > 0) { <span>@yarn.LengthMeter @lengthUnit</span> }
                    @if (yarn.Price > 0) { <span>₩@yarn.Price.ToString("N0")</span> }
                </div>
                @if (!string.IsNullOrEmpty(yarn.LotNumber))
                {
                    <div style="font-size:0.78rem; color:var(--text-light);">Lot: @yarn.LotNumber</div>
                }
                @if (totalLength > 0)
                {
                    <div style="font-size:0.8rem; color:var(--sage-dark); font-weight:600; margin-bottom:6px;">
                        총 보유: @totalLength m
                    </div>
                }

                @if (!string.IsNullOrEmpty(yarn.PurchasePlace))
                {
                    <div style="font-size:0.78rem; color:var(--text-light); margin-bottom:10px;">
                        <span style="display:inline-flex;align-items:center;gap:4px;"><img src="icons/storefront.svg" class="icon-line" style="width:13px;height:13px;flex-shrink:0;" />@yarn.PurchasePlace</span>
                        @if (yarn.PurchaseDate.HasValue)
                        {
                            <span> · @yarn.PurchaseDate.Value.ToString("yyyy.MM.dd")</span>
                        }
                    </div>
                }

                <div class="flex gap-1">
                    <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditModal(yarn)" style="display:inline-flex;align-items:center;gap:5px;"><img src="icons/pencil.svg" class="icon-line" style="width:14px;height:14px;flex-shrink:0;" />수정</button>
                    <button class="btn btn-danger btn-sm" @onclick='() => Confirm($"\"{yarn.Name}\" 실을 삭제하면 복구할 수 없어요.", async () => await DeleteYarn(yarn.Id))' style="display:inline-flex;align-items:center;"><img src="icons/trash.svg" class="icon-line" style="width:14px;height:14px;flex-shrink:0;" /></button>
                </div>
            </div>
        }
    </div>
}

<!-- 추가/수정 모달 -->
@if (_showModal && _editingYarn != null)
{
    <div class="modal-backdrop">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(_editingYarn.Id == Guid.Empty ? "실 추가" : "실 수정")</h2>
                <button class="btn btn-ghost btn-sm" @onclick="CloseModal">✕</button>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">실 이름 *</label>
                    <input class="form-control" @bind="_editingYarn.Name" placeholder="예: 러스크" />
                </div>
                <div class="form-group">
                    <label class="form-label">브랜드</label>
                    <input class="form-control" @bind="_editingYarn.Brand" placeholder="예: 솜솜뜨개" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">색상명</label>
                    <input class="form-control" @bind="_editingYarn.Color" placeholder="예: 아이보리" />
                </div>
                <div class="form-group">
                    <label class="form-label">색상 코드</label>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <input type="color" class="form-control" style="width:50px; padding:4px; height:40px;"
                               @bind="_editingYarn.ColorCode" />
                        <input class="form-control" @bind="_editingYarn.ColorCode" placeholder="#ffffff" style="flex:1;" />
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">실 종류</label>
                    <select class="form-control" @bind="_editingYarn.YarnType">
                        @foreach (var t in Enum.GetValues<YarnType>())
                        { <option value="@t">@t</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">소재</label>
                    <input class="form-control" @bind="_editingYarn.Material" placeholder="예: 울 100%" />
                </div>
            </div>

            @* ── 무게 / 길이 / 가격 ── *@
            @if (_editingYarn.YarnType == YarnType.콘사)
            {
                <div class="form-row-3">
                    <div class="form-group">
                        <label class="form-label">무게 (g/콘)</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 100"
                               value="@(_editingYarn.WeightGram == 0 ? "" : _editingYarn.WeightGram.ToString())"
                               @onchange="e => _editingYarn.WeightGram = int.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">길이 (m/콘)</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 225"
                               value="@(_editingYarn.LengthMeter == 0 ? "" : _editingYarn.LengthMeter.ToString())"
                               @onchange="e => _editingYarn.LengthMeter = int.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">가격 (원/콘)</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 10000"
                               value="@(_editingYarn.Price == 0 ? "" : _editingYarn.Price.ToString())"
                               @onchange="e => _editingYarn.Price = decimal.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                    </div>
                </div>
            }
            else
            {
                <div class="form-row-3">
                    <div class="form-group">
                        <label class="form-label">무게 (g/볼)</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 100"
                               value="@(_editingYarn.WeightGram == 0 ? "" : _editingYarn.WeightGram.ToString())"
                               @onchange="e => _editingYarn.WeightGram = int.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">길이 (m/볼)</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 225"
                               value="@(_editingYarn.LengthMeter == 0 ? "" : _editingYarn.LengthMeter.ToString())"
                               @onchange="e => _editingYarn.LengthMeter = int.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">가격 (원/볼)</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 10000"
                               value="@(_editingYarn.Price == 0 ? "" : _editingYarn.Price.ToString())"
                               @onchange="e => _editingYarn.Price = decimal.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                    </div>
                </div>
            }

            @* ── Lot번호 / 합수 / 수량 ── *@
            @if (_editingYarn.YarnType == YarnType.콘사)
            {
                <div class="form-row-3">
                    <div class="form-group">
                        <label class="form-label">Lot 번호</label>
                        <input class="form-control" @bind="_editingYarn.LotNumber" placeholder="예: 1234" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">합수</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 2"
                               value="@(_editingYarn.Ply == 0 ? "" : _editingYarn.Ply.ToString())"
                               @onchange="e => _editingYarn.Ply = int.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">수량 (콘)</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 5"
                               value="@(_editingYarn.Quantity == 0 ? "" : _editingYarn.Quantity.ToString())"
                               @onchange="e => _editingYarn.Quantity = decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var q) ? q : 0" />
                    </div>
                </div>
            }
            else
            {
                <div class="form-row-3">
                    <div class="form-group">
                        <label class="form-label">Lot 번호</label>
                        <input class="form-control" @bind="_editingYarn.LotNumber" placeholder="예: 1234" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">합수</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 2"
                               value="@(_editingYarn.Ply == 0 ? "" : _editingYarn.Ply.ToString())"
                               @onchange="e => _editingYarn.Ply = int.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">수량 (볼)</label>
                        <input type="number" class="form-control" min="0" placeholder="예: 5"
                               value="@(_editingYarn.Quantity == 0 ? "" : _editingYarn.Quantity.ToString())"
                               @onchange="e => _editingYarn.Quantity = decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var q) ? q : 0" />
                    </div>
                </div>
            }


            @{
                decimal previewTotal = _editingYarn.LengthMeter * _editingYarn.Quantity;
            }
            @if (previewTotal > 0)
            {
                <div style="font-size:0.85rem; color:var(--text-dark); font-weight:600; margin-bottom:12px; padding:8px 12px; background:var(--mint-pale); border-radius:var(--radius-sm); border:1px solid var(--mint-light);">
                    총 보유 길이: @previewTotal m
                </div>
            }

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">구매처</label>
                    <input class="form-control" @bind="_editingYarn.PurchasePlace" placeholder="예: 솜솜뜨개" />
                </div>
                <div class="form-group">
                    <label class="form-label">구매일</label>
                    <input type="date" class="form-control"
                           value="@_editingYarn.PurchaseDate?.ToString("yyyy-MM-dd")"
                           @onchange="e => _editingYarn.PurchaseDate = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!)" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">메모</label>
                <textarea class="form-control" rows="2" @bind="_editingYarn.Memo" placeholder="기타 메모"></textarea>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseModal">취소</button>
                <button class="btn btn-primary" @onclick="SaveYarn" disabled="@_saving">@(_saving ? "저장 중..." : "저장")</button>
            </div>
        </div>
    </div>
}

<!-- 삭제 확인 모달 -->
@if (_showConfirm)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;padding:20px;">
        <div style="background:var(--white);border-radius:16px;max-width:320px;width:100%;padding:24px 20px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,0.18);" @onclick:stopPropagation="true">
            <div style="margin-bottom:12px;display:flex;justify-content:center;"><img src="icons/trash.svg" class="icon-line" style="width:32px;height:32px;" /></div>
            <div style="font-size:1rem; font-weight:600; margin-bottom:8px; color:var(--text-dark);">정말 삭제할까요?</div>
            <div style="font-size:0.88rem; color:var(--text-mid); margin-bottom:20px;">@_confirmMsg</div>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="btn btn-ghost" @onclick="() => _showConfirm = false">취소</button>
                <button class="btn btn-danger" @onclick="ExecuteConfirm">삭제</button>
            </div>
        </div>
    </div>
}

@code {
    bool _saving = false;
    bool _showConfirm = false;
    string _confirmMsg = "";
    Func<Task>? _confirmAction;

    void Confirm(string msg, Func<Task> action)
    {
        _confirmMsg    = msg;
        _confirmAction = action;
        _showConfirm   = true;
    }

    async Task ExecuteConfirm()
    {
        _showConfirm = false;
        if (_confirmAction != null)
            await _confirmAction();
        _confirmAction = null;
    }

    bool _loading = true;
    bool _showModal = false;
    string _searchText = "";
    string _filter = "all";
    List<Yarn> _yarns = new();
    Yarn? _editingYarn;

    IEnumerable<Yarn> FilteredYarns
    {
        get
        {
            var list = _yarns.AsEnumerable();

            // 텍스트 검색
            if (!string.IsNullOrWhiteSpace(_searchText))
                list = list.Where(y =>
                    y.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                    y.Brand.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                    y.Color.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                    y.Material.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

            // 통합 필터
            list = _filter switch
            {
                "linked"   => list.Where(y => _usedQty.ContainsKey(y.Id)),
                "unlinked" => list.Where(y => !_usedQty.ContainsKey(y.Id)),
                "low"      => list.Where(y =>
                {
                    decimal used = _usedQty.TryGetValue(y.Id, out var u) ? u : 0;
                    decimal remain = y.Quantity - used;
                    return _usedQty.ContainsKey(y.Id) && y.Quantity > 0 && remain > 0 && (remain / y.Quantity) < 0.5m;
                }),
                "empty"    => list.Where(y =>
                {
                    decimal used = _usedQty.TryGetValue(y.Id, out var u) ? u : 0;
                    return (y.Quantity - used) <= 0;
                }),
                _          => list
            };

            return list;
        }
    }

    List<KnitProject> _projects = new();
    // yarnId → 총 사용량 (모든 프로젝트 합산)
    Dictionary<Guid, decimal> _usedQty = new();

    protected override async Task OnInitializedAsync()
    {
        _yarns = await Storage.GetYarnsAsync();
        _projects = await Storage.GetProjectsAsync();
        _CalcUsed();
        _filter = await JS.InvokeAsync<string?>("localStorage.getItem", "yarn_filter") ?? "all";
        _loading = false;
    }

    void _CalcUsed()
    {
        _usedQty = new();
        foreach (var p in _projects)
            foreach (var u in p.YarnUsages)
                _usedQty[u.YarnId] = (_usedQty.TryGetValue(u.YarnId, out var v) ? v : 0) + u.BallsUsed;
    }

    void OpenAddModal() { _editingYarn = new Yarn { Id = Guid.Empty, YarnType = YarnType.콘사 }; _showModal = true; }
    void OpenEditModal(Yarn yarn) { _editingYarn = yarn; _showModal = true; }
    void CloseModal() { _showModal = false; _editingYarn = null; }

    async Task SaveYarn()
    {
        _saving = true; StateHasChanged();
        if (_editingYarn == null || string.IsNullOrWhiteSpace(_editingYarn.Name)) return;
        if (_editingYarn.Id == Guid.Empty) _editingYarn.Id = Guid.NewGuid();
        await Storage.SaveYarnAsync(_editingYarn);
        _yarns = await Storage.GetYarnsAsync();
        _CalcUsed();
        CloseModal();
        _saving = false;
        await JS.InvokeVoidAsync("showToast", "저장됐어요");
        }

    async Task DeleteYarn(Guid id)
    {
        await Storage.DeleteYarnAsync(id);
        _yarns = await Storage.GetYarnsAsync();
    }
}
