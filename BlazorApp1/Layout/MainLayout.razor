@inherits LayoutComponentBase
@using KnitLog.Models
@using KnitLog.Services
@inject StorageService Storage
@inject AuthService Auth
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="app-shell">
    <nav class="sidebar">
        <div class="sidebar-brand">
            <img src="images/logo.png" class="sidebar-logo" alt="KnitLog" />
        </div>

        <ul class="nav-list">
            <li><NavLink href="" Match="NavLinkMatch.All" class="nav-item"><span class="nav-icon"><img src="icons/house-line.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">홈</span></NavLink></li>
            <li><NavLink href="schedule" class="nav-item"><span class="nav-icon"><img src="icons/calendar-dots.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">뜨케줄</span></NavLink></li>
            <li><NavLink href="projects" class="nav-item"><span class="nav-icon"><img src="icons/stack.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">문어발</span></NavLink></li>
            <li><NavLink href="finished" class="nav-item"><span class="nav-icon"><img src="icons/t-shirt.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">완성작</span></NavLink></li>
            <li><NavLink href="wishlist" class="nav-item"><span class="nav-icon"><img src="icons/shooting-star.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">위시리스트</span></NavLink></li>
            <li><NavLink href="yarns" class="nav-item"><span class="nav-icon"><img src="icons/yarn.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">실 창고</span></NavLink></li>
            <li><NavLink href="swatches" class="nav-item"><span class="nav-icon"><img src="icons/swatches.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">스와치</span></NavLink></li>
            <li><NavLink href="tools" class="nav-item"><span class="nav-icon"><img src="icons/toolbox.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">도구</span></NavLink></li>
            <li><NavLink href="stats" class="nav-item"><span class="nav-icon"><img src="icons/chart-bar.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">통계</span></NavLink></li>
            <li><NavLink href="settings" class="nav-item"><span class="nav-icon"><img src="icons/gear.svg" class="icon-line" style="width:20px;height:20px;" /></span><span class="nav-label">설정</span></NavLink></li>
        </ul>

        <!-- 사이드바 하단 통계 + 다크 토글 -->
        <div class="sidebar-stats">
            <div class="sidebar-stat-row">
                <span><img src="icons/t-shirt.svg" class="icon-line" style="width:26px;height:26px;margin-right:4px;" /> 완성작</span>
                <strong>@(_finished)개</strong>
            </div>
            <div class="sidebar-stat-row">
                <span><img src="icons/Time.svg" style="width:26px;height:26px;margin-right:4px;" /> 오늘</span>
                <strong>@_todayTime</strong>
            </div>
            <div class="sidebar-dark-toggle" @onclick="ToggleDark" title="@(_isDark ? "라이트 모드" : "다크 모드")">
                @if (_isDark)
                {
                    <img src="icons/Light.svg" style="width:32px;height:32px;" />
                }
                else
                {
                    <img src="icons/Dark.svg" style="width:32px;height:32px;" />
                }
            </div>
        </div>
    </nav>

    <main class="main-content">@Body</main>

    <nav class="bottom-nav">
        <NavLink href="" Match="NavLinkMatch.All" class="bottom-nav-item">
            <span class="bottom-nav-icon"><img src="icons/house-line.svg" class="icon-line" style="width:24px;height:24px;" /></span><span class="bottom-nav-label">홈</span>
        </NavLink>
        <NavLink href="schedule" class="bottom-nav-item">
            <span class="bottom-nav-icon"><img src="icons/calendar-dots.svg" class="icon-line" style="width:24px;height:24px;" /></span><span class="bottom-nav-label">뜨케줄</span>
        </NavLink>
        <NavLink href="stats" class="bottom-nav-item">
            <span class="bottom-nav-icon"><img src="icons/chart-bar.svg" class="icon-line" style="width:24px;height:24px;" /></span><span class="bottom-nav-label">통계</span>
        </NavLink>
        <NavLink href="settings" class="bottom-nav-item">
            <span class="bottom-nav-icon"><img src="icons/gear.svg" class="icon-line" style="width:24px;height:24px;" /></span><span class="bottom-nav-label">설정</span>
        </NavLink>
    </nav>
</div>

@code {
    string _currentTheme = "mono";
    bool _isDark = false;
    int _finished;
    string _todayTime = "0분";
    private PeriodicTimer? _sidebarTimer;
    bool _isSyncing = false;
    DotNetObjectReference<MainLayout>? _visibilityRef;

    protected override async Task OnInitializedAsync()
    {
        await RefreshStats();
        StartSidebarTimer();
        Auth.OnAuthChanged += OnAuthChanged;
    }

    void OnAuthChanged()
    {
        InvokeAsync(async () =>
        {
            StateHasChanged();
            // 로그인 직후 동기화
            if (Auth.IsLoggedIn && !_isSyncing)
            {
                _isSyncing = true;
                await Storage.SyncOnLoginAsync();
                _isSyncing = false;
                await RefreshStats();
                StateHasChanged();
            }
        });
    }

    async Task SignIn()
    {
        await Auth.SignInWithGoogleAsync();
    }

    async Task SignOut()
    {
        await Auth.SignOutAsync();
        StateHasChanged();
    }

    async Task RefreshStats()
    {
        var projects = await Storage.GetProjectsAsync();
        _finished = projects.Count(p => p.Status == ProjectStatus.완료);

        // 완료된 세션 + 현재 진행 중인 세션(실시간) 합산
        var todaySecs = projects
            .SelectMany(p => p.Sessions)
            .Where(s => s.StartTime.Date == DateTime.Today)
            .Sum(s =>
            {
                var end = s.EndTime ?? (s.IsActive ? DateTime.Now : s.StartTime);
                return (int)((end - s.StartTime).TotalSeconds);
            });
        _todayTime = FormatTime(todaySecs);
    }

    void StartSidebarTimer()
    {
        _sidebarTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = RunSidebarTimerAsync();
    }

    async Task RunSidebarTimerAsync()
    {
        try
        {
            while (_sidebarTimer is not null && await _sidebarTimer.WaitForNextTickAsync())
            {
                await RefreshStats();
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
    }

    string FormatTime(int secs)
    {
        var h = secs / 3600;
        var m = (secs % 3600) / 60;
        var s = secs % 60;
        if (h > 0) return $"{h}시간 {m:D2}분 {s:D2}초";
        if (m > 0) return $"{m}분 {s:D2}초";
        return secs > 0 ? $"{s}초" : "0분";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.InitAsync();
            var theme = await JS.InvokeAsync<string?>("localStorage.getItem", "knitlog_theme");
            if (!string.IsNullOrEmpty(theme)) _currentTheme = theme;
            var dark = await JS.InvokeAsync<string?>("localStorage.getItem", "knitlog_dark");
            _isDark = dark == "true";
            await ApplyTheme(_currentTheme);
            await ApplyDark(_isDark);
            // 앱 포그라운드 복귀 감지 등록
            _visibilityRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerVisibilitySync", _visibilityRef);
            await JS.InvokeVoidAsync("registerOnlineSync", _visibilityRef);
            StateHasChanged();
        }
    }

    async Task ToggleDark()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("localStorage.setItem", "knitlog_dark", _isDark.ToString().ToLower());
        await ApplyDark(_isDark);
    }

    async Task ApplyTheme(string id) =>
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme','{id}')");

    async Task ApplyDark(bool dark) =>
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-dark','{dark.ToString().ToLower()}')");

    [Microsoft.JSInterop.JSInvokable]
    public async Task OnAppResumed()
    {
        // 다른 기기에서 수정했을 수 있으므로 Firestore에서 최신 데이터 pull
        if (Auth.IsLoggedIn && !_isSyncing)
        {
            _isSyncing = true;
            await Storage.SyncOnLoginAsync();
            _isSyncing = false;
            await RefreshStats();
            StateHasChanged();
        }
    }

    [Microsoft.JSInterop.JSInvokable]
    public async Task OnBackOnline()
    {
        // 오프라인 중 수정한 내용을 Firebase에 push
        if (Auth.IsLoggedIn && !_isSyncing)
        {
            _isSyncing = true;
            await Storage.PushLocalToFirebaseAsync();
            _isSyncing = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _sidebarTimer?.Dispose();
        _sidebarTimer = null;
        Auth.OnAuthChanged -= OnAuthChanged;
        _visibilityRef?.Dispose();
        _visibilityRef = null;
        try { await JS.InvokeVoidAsync("unregisterOnlineSync"); } catch { }
        return;
    }
}
